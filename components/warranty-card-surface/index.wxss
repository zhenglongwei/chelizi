@import '../../styles/warranty-card-themes.wxss';

.warranty-card-body {
  position: relative;
  z-index: 1;
}

.warranty-card-pattern {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background-image: radial-gradient(
      circle at 18% 22%,
      var(--warranty-pattern-mesh) 0%,
      transparent 42%
    ),
    radial-gradient(circle at 82% 78%, var(--warranty-pattern-mesh) 0%, transparent 40%),
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 24rpx,
      rgba(30, 41, 59, 0.012) 24rpx,
      rgba(30, 41, 59, 0.012) 25rpx
    ),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 24rpx,
      rgba(30, 41, 59, 0.01) 24rpx,
      rgba(30, 41, 59, 0.01) 25rpx
    );
}

.warranty-card-watermark {
  position: absolute;
  left: 50%;
  top: 44%;
  transform: translate(-50%, -50%) rotate(-16deg);
  font-size: 76rpx;
  color: var(--warranty-watermark);
  font-weight: 700;
  letter-spacing: 10rpx;
  white-space: nowrap;
  pointer-events: none;
  z-index: 0;
}

.warranty-card-ornament {
  position: absolute;
  width: 52rpx;
  height: 52rpx;
  pointer-events: none;
  z-index: 0;
  border: 0 solid var(--warranty-ornament);
}

.warranty-card-ornament--tl {
  top: 18rpx;
  left: 18rpx;
  border-top-width: 3rpx;
  border-left-width: 3rpx;
  border-top-left-radius: 4rpx;
}

.warranty-card-ornament--br {
  bottom: 18rpx;
  right: 18rpx;
  border-bottom-width: 3rpx;
  border-right-width: 3rpx;
  border-bottom-right-radius: 4rpx;
}

.warranty-card-headline {
  text-align: center;
  margin-bottom: var(--space-sm);
  padding-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--border);
}

.warranty-card-title {
  display: block;
  font-size: 34rpx;
  letter-spacing: 6rpx;
  color: var(--text-primary);
}

.warranty-card-subtitle {
  display: block;
  margin-top: 8rpx;
}

.warranty-card-kicker {
  font-size: 24rpx;
  letter-spacing: 0.5rpx;
  margin-bottom: var(--space-md);
  text-align: center;
  line-height: 1.45;
}

.warranty-card-badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.warranty-card-preview-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--warranty-sample-bg);
  color: var(--warranty-sample-text);
}

.warranty-card-section {
  display: flex;
  margin-bottom: var(--space-lg);
  align-items: stretch;
}

.warranty-card-section--compact {
  margin-bottom: var(--space-md);
}

.warranty-card-section-bar {
  width: 6rpx;
  border-radius: 3rpx;
  background: var(--primary);
  margin-right: var(--space-md);
  flex-shrink: 0;
  opacity: 0.55;
}

.warranty-card-section-bar--secondary {
  background: var(--text-hint);
  opacity: 0.45;
}

.warranty-card-section-inner {
  flex: 1;
  min-width: 0;
}

.warranty-card-section-label {
  display: block;
  margin-bottom: 6rpx;
}

.warranty-card-shop {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
  color: var(--text-primary);
}

.warranty-card-order {
  display: block;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.warranty-card-vehicle {
  display: block;
  line-height: 1.45;
}

.warranty-card-pending {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-md);
  line-height: 1.55;
}

.warranty-card-rule-block {
  margin-bottom: var(--space-md);
}

.warranty-card-rule,
.warranty-card-start {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  display: block;
}

.warranty-card-start {
  margin-top: 8rpx;
}

.warranty-card-table-wrap {
  margin-bottom: var(--space-md);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: rgba(255, 255, 255, 0.45);
}

.warranty-card-table-title {
  padding: var(--space-sm) var(--space-md);
  background: rgba(255, 255, 255, 0.65);
  border-bottom: 1rpx solid var(--border);
  color: var(--text-secondary);
  font-weight: 600;
}

.warranty-card-table-head {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx var(--space-md) 8rpx;
  color: var(--text-primary);
  border-bottom: 1rpx solid var(--border);
  background: rgba(255, 255, 255, 0.5);
}

.warranty-card-th-wm {
  flex-shrink: 0;
  margin-left: var(--space-md);
}

.warranty-card-table-body {
  max-height: 420rpx;
}

.warranty-card-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx var(--space-md);
  border-bottom: 1rpx solid var(--border-light);
}

.warranty-card-row:last-child {
  border-bottom: none;
}

.warranty-card-cell-main {
  flex: 1;
  padding-right: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.warranty-card-row-sub {
  font-size: 24rpx;
  line-height: 1.4;
}

.warranty-card-part {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.warranty-card-wm {
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
  color: var(--text-primary);
}

.warranty-card-style-placeholder {
  padding: var(--space-md) 0;
  line-height: 1.55;
  border-top: 1rpx solid var(--border);
  border-bottom: 1rpx solid var(--border);
  margin-bottom: var(--space-md);
}

.warranty-card-seal-block {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin: var(--space-md) 0;
}

.warranty-card-seal-line {
  flex: 1;
  height: 1rpx;
  background: var(--border);
}

.warranty-card-seal-cap {
  flex-shrink: 0;
  letter-spacing: 2rpx;
}

.warranty-card-meta-block {
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: var(--space-md);
}

.warranty-card-meta-block--demo {
  border-style: dashed;
}

.warranty-card-meta-line {
  display: block;
  margin-bottom: 8rpx;
}

.warranty-card-code-row {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 8rpx;
}

.warranty-card-code {
  font-size: 24rpx;
  word-break: break-all;
  color: var(--text-primary);
  letter-spacing: 0.5rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.warranty-card-code--demo {
  color: var(--text-secondary);
}

.warranty-card-generated {
  word-break: break-all;
  line-height: 1.45;
}

.warranty-card-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: var(--space-md);
}

.warranty-card-disclaimer {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.55;
  margin-bottom: var(--space-sm);
}

.warranty-card-share-hint {
  font-size: 22rpx;
  color: var(--text-hint);
}
