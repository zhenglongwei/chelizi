/* 主评价页 - 固定问题、材料、自主评价 */
.review-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--space-lg) var(--page-padding-x);
  padding-bottom: 140rpx;
}
.review-loading, .review-error {
  padding: var(--space-2xl);
  text-align: center;
}
.review-back-btn {
  margin-top: var(--space-lg);
  color: var(--primary);
  font-size: var(--fs-body);
}
.review-compliance {
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  margin-bottom: var(--space-md);
}
.review-compliance-highlight {
  background: var(--primary-bg);
  border: 2rpx solid var(--primary);
  border-left-width: 8rpx;
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-md);
}
.review-compliance-text {
  font-size: var(--fs-body);
  color: var(--text-primary);
  font-weight: 500;
  line-height: 1.5;
}
.review-verification {
  background: var(--primary-bg);
  border-left: 4rpx solid var(--primary);
}
.review-verification-text {
  font-size: var(--fs-sm);
  line-height: 1.5;
}
.review-objective {
  margin-top: var(--space-md);
}
.review-fault-evidence {
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
}
.review-fault-evidence .review-upload-grid {
  margin-top: var(--space-sm);
}
.review-objective .fs-body { display: block; margin-bottom: var(--space-xs); }
.review-radio-group { display: flex; gap: var(--space-lg); margin-top: var(--space-xs); }
.review-radio-group label { display: flex; align-items: center; gap: var(--space-xs); font-size: var(--fs-body); }
.review-upload-row { margin-top: var(--space-md); }
.review-upload-row .fs-body { display: block; margin-bottom: var(--space-sm); }
.review-upload-single {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
}
radio{
    transform: scale(0.7);
}
.review-reward { }
.review-reward-total { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-xs); }
.review-reward-stages { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
.review-footer .btn-primary.disabled { opacity: 0.6; }
.review-success {
  text-align: center;
  padding: var(--space-2xl);
}
.review-success-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-top: var(--space-xl);
}
.review-success-actions button {
  width: 100%;
}
.review-scroll {
  padding-bottom: var(--space-lg);
}
.review-section {
  margin-bottom: var(--space-lg);
}
.review-section-title {
  margin-bottom: var(--space-md);
  color: var(--text-primary);
}
.review-plan-compare {
  margin-top: var(--space-md);
  padding: var(--space-md);
  background: var(--bg-page);
  border-radius: var(--radius-md);
  border-left: 4rpx solid var(--warning);
}
.review-plan-compare-title {
  font-size: var(--fs-body);
  font-weight: 600;
  color: var(--warning);
  margin-bottom: var(--space-sm);
}
.review-plan-compare-row {
  display: flex;
  gap: var(--space-lg);
}
.review-plan-compare-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}
.review-plan-compare-label {
  font-size: var(--fs-cap);
  color: var(--text-secondary);
  margin-bottom: var(--space-xs);
}
.review-plan-compare-item {
  font-size: var(--fs-sm);
  color: var(--text-primary);
}
.review-plan-compare-meta {
  font-size: var(--fs-cap);
  color: var(--text-hint);
  margin-top: var(--space-xs);
}
.review-repair-items {
  margin-top: var(--space-sm);
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}
.review-image-grid, .review-upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
  margin-top: var(--space-md);
}
.review-upload-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--bg-placeholder);
}
.review-thumb {
  width: 100%;
  height: 100%;
}
.review-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}
.review-del-text {
  color: #fff;
  font-size: 36rpx;
  line-height: 1;
}
.review-source-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  padding: 2rpx 8rpx;
  font-size: 20rpx;
  color: #fff;
  background: rgba(0,0,0,0.5);
}
.review-upload-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
}
.review-add-text {
  font-size: 48rpx;
  color: var(--text-hint);
  line-height: 1;
}
.review-analyze-btn {
  margin-top: var(--space-sm);
}
.review-stars {
  display: flex;
  gap: var(--space-sm);
  font-size: 48rpx;
}
.review-stars-sm {
  font-size: 36rpx;
}
.review-star {
  color: var(--text-hint);
}
.review-star.filled {
  color: var(--warning);
}
.review-sub-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
}
/* 极简指引 */
.review-guide-simple {
  background: var(--primary-bg);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-md);
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-md);
}
.review-guide-simple-title {
  display: block;
  font-size: var(--fs-body);
  font-weight: 600;
  color: var(--primary);
  margin-bottom: var(--space-xs);
}
.review-guide-simple-desc {
  display: block;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: var(--space-md);
}
.review-guide-simple-btn {
  font-size: var(--fs-sm);
  color: var(--primary);
  text-decoration: underline;
}
.review-guide-simple-btn-sm {
  margin-top: var(--space-xs);
  display: inline-block;
}
.review-guide-mini {
  background: var(--primary-bg);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-md);
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-md);
}
.review-guide-mini-text {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.5;
}
.review-guide-float {
  background: var(--primary-bg);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-sm);
  padding: var(--space-sm) var(--space-md);
  margin-bottom: var(--space-sm);
}
.review-guide-float-text {
  font-size: var(--fs-sm);
  color: var(--primary);
  line-height: 1.5;
}
.review-textarea-wrap {
  position: relative;
  margin-top: var(--space-sm);
}
.review-word-count {
  position: absolute;
  top: var(--space-md);
  right: var(--space-md);
  font-size: 28rpx;
  color: var(--text-hint);
  z-index: 1;
}
.review-textarea-placeholder {
  color: var(--text-hint);
}
.review-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: var(--space-md);
  padding-right: 100rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: var(--fs-body);
  box-sizing: border-box;
}
.review-anonymous {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.review-rebate {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}
.review-bottom-pad {
  height: var(--space-2xl);
}

/* 侧边栏：详细指引 */
.review-detail-guide-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 900;
  pointer-events: none;
  transition: background 0.25s ease;
}
.review-detail-guide-mask-show {
  background: rgba(0, 0, 0, 0.4);
  pointer-events: auto;
}
.review-detail-guide-drawer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: 85%;
  max-width: 560rpx;
  background: var(--bg-card);
  z-index: 901;
  transform: translateX(100%);
  transition: transform 0.25s ease;
  box-shadow: var(--shadow-lg);
  display: flex;
  flex-direction: column;
}
.review-detail-guide-drawer-show {
  transform: translateX(0);
}
.review-detail-guide-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg) var(--space-xl);
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}
.review-detail-guide-title {
  font-size: var(--fs-h3);
  font-weight: 600;
  color: var(--text-primary);
}
.review-detail-guide-close {
  font-size: 48rpx;
  color: var(--text-hint);
  line-height: 1;
  padding: var(--space-xs);
}
.review-detail-guide-body {
  flex: 1;
  padding: var(--space-lg);
  height: 0;
}
.review-detail-guide-part {
  margin-bottom: var(--space-xl);
}
.review-detail-guide-part-title {
  display: block;
  font-size: var(--fs-body);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-md);
}
.review-detail-guide-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}
.review-detail-guide-check,
.review-detail-guide-dot {
  flex-shrink: 0;
  font-size: var(--fs-body);
}
.review-detail-guide-check-text {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 横屏适配：侧边栏加宽便于阅读 */
@media (orientation: landscape) {
  .review-detail-guide-drawer {
    max-width: 70%;
  }
}
.review-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-lg) var(--page-padding-x);
  padding-bottom: calc(var(--space-lg) + env(safe-area-inset-bottom));
  background: var(--bg-page);
}
.review-submit-btn {
  width: 100%;
}
