/* 主评价页 - 固定问题、材料、自主评价 */
.review-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--space-lg) var(--page-padding-x);
  padding-bottom: 140rpx;
}
.review-loading, .review-error {
  padding: var(--space-2xl);
  text-align: center;
}
.review-back-btn {
  margin-top: var(--space-lg);
  color: var(--primary);
  font-size: var(--fs-body);
}
.review-compliance {
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  margin-bottom: var(--space-md);
}
.review-compliance-highlight {
  background: var(--primary-bg);
  border: 2rpx solid var(--primary);
  border-left-width: 8rpx;
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-md);
}
.review-compliance-text {
  font-size: var(--fs-body);
  color: var(--text-primary);
  font-weight: 500;
  line-height: 1.5;
}
.review-verification {
  background: var(--primary-bg);
  border-left: 4rpx solid var(--primary);
}
.review-verification-text {
  font-size: var(--fs-sm);
  line-height: 1.5;
}
.review-objective {
  margin-top: var(--space-md);
}
.review-fault-evidence {
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
}
.review-fault-evidence .review-upload-grid {
  margin-top: var(--space-sm);
}
.review-objective .fs-body { display: block; margin-bottom: var(--space-xs); }
.review-radio-group { display: flex; gap: var(--space-lg); margin-top: var(--space-xs); }
.review-radio-group label { display: flex; align-items: center; gap: var(--space-xs); font-size: var(--fs-body); }
.review-upload-row { margin-top: var(--space-md); }
.review-upload-row .fs-body { display: block; margin-bottom: var(--space-sm); }
.review-upload-single {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
}
radio{
    transform: scale(0.7);
}
.review-reward { }
.review-reward-total { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-xs); }
.review-reward-stages { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
.review-footer .btn-primary.disabled { opacity: 0.6; }
.review-success {
  text-align: center;
  padding: var(--space-2xl);
}
.review-success-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-top: var(--space-xl);
}
.review-success-actions button {
  width: 100%;
}
.review-invalid-hints {
  text-align: left;
  margin-top: var(--space-lg);
  padding: var(--space-md) var(--space-lg);
  background: var(--bg-card, #f7f8fa);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
}
.review-invalid-hint-row {
  margin-top: var(--space-xs);
  line-height: 1.5;
  padding-left: 0;
}
.review-scroll {
  padding-bottom: var(--space-lg);
}
.review-section {
  margin-bottom: var(--space-lg);
}
.review-section-title {
  margin-bottom: var(--space-md);
  color: var(--text-primary);
}
.review-v3-linear-block {
  padding-top: var(--space-lg);
  margin-top: var(--space-lg);
  border-top: 1rpx solid var(--border);
}
.review-v3-linear-block:first-of-type {
  border-top: none;
  margin-top: 0;
  padding-top: 0;
}
.review-v3-linear-q {
  display: block;
  margin-bottom: var(--space-sm);
}
.review-v3-linear-label {
  display: block;
  margin-top: var(--space-md);
  font-size: var(--fs-body);
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
}
.review-v3-linear-info {
  background: var(--bg-card, #f7f8fa);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-top: var(--space-md);
  border: 1rpx solid var(--border);
}
.review-v3-star-head {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}
.review-v3-star-head .review-v3-linear-q {
  margin-bottom: 0;
}
.review-v3-scale-hint {
  display: block;
  line-height: 1.5;
  margin-bottom: var(--space-sm);
}
.review-milestone-block {
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--border-light);
}
.review-milestone-block:last-of-type {
  border-bottom: none;
}
.review-v3-parts-sec {
  margin-top: var(--space-sm);
  color: var(--text-primary);
}
.review-expand-hint {
  margin-top: var(--space-sm);
  padding: var(--space-xs) 0;
}
.review-expand-body {
  margin-top: var(--space-md);
  padding: var(--space-md);
  background: var(--bg-placeholder, #f5f6f8);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
}
.review-evidence-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}
.review-evidence-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  background: var(--border);
}
.review-align-override {
  margin-top: var(--space-sm);
}
.review-picker-line {
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--border);
}
.review-align-note-input {
  margin-top: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: var(--fs-body);
}
.review-quote-timeline-card .review-timeline-summary {
  line-height: 1.5;
  display: block;
  margin-bottom: var(--space-xs);
}
.review-timeline-highlight {
  color: var(--warning);
  font-weight: 500;
  display: block;
  margin-top: var(--space-sm);
}
.review-timeline-bidding,
.review-timeline-fallback,
.review-timeline-bidding-caption {
  display: block;
  margin-top: var(--space-sm);
  line-height: 1.5;
}
.review-timeline-bidding-caption {
  padding: var(--space-sm) var(--space-md);
  background: var(--bg-placeholder);
  border-radius: var(--radius-sm);
}
.review-timeline-mini-compare {
  margin-top: var(--space-md);
  line-height: 1.5;
}
.review-timeline-same-tag {
  margin-left: var(--space-xs);
  color: var(--text-weak);
}
.review-timeline-toggle {
  margin-top: var(--space-md);
}
.review-plan-compare-in-timeline {
  margin-top: var(--space-md);
}
.review-timeline-proposal-hint {
  display: block;
  margin-top: var(--space-md);
  line-height: 1.5;
}
.review-plan-compare {
  margin-top: var(--space-md);
  padding: var(--space-md);
  background: var(--bg-page);
  border-radius: var(--radius-md);
  border-left: 4rpx solid var(--warning);
}
.review-plan-compare-title {
  font-size: var(--fs-body);
  font-weight: 600;
  color: var(--warning);
  margin-bottom: var(--space-sm);
}
.review-plan-compare-row {
  display: flex;
  gap: var(--space-lg);
}
.review-plan-compare-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}
.review-plan-compare-label {
  font-size: var(--fs-cap);
  color: var(--text-secondary);
  margin-bottom: var(--space-xs);
}
.review-plan-compare-item {
  font-size: var(--fs-sm);
  color: var(--text-primary);
}
.review-plan-compare-meta {
  font-size: var(--fs-cap);
  color: var(--text-hint);
  margin-top: var(--space-xs);
}
.review-repair-items {
  margin-top: var(--space-sm);
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}
.review-image-grid, .review-upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
  margin-top: var(--space-md);
}
.review-upload-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--bg-placeholder);
}
.review-thumb {
  width: 100%;
  height: 100%;
}
.review-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}
.review-del-text {
  color: #fff;
  font-size: 36rpx;
  line-height: 1;
}
.review-source-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  padding: 2rpx 8rpx;
  font-size: 20rpx;
  color: #fff;
  background: rgba(0,0,0,0.5);
}
.review-upload-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
}
.review-add-text {
  font-size: 48rpx;
  color: var(--text-hint);
  line-height: 1;
}
.review-analyze-btn {
  margin-top: var(--space-sm);
}
.review-stars {
  display: flex;
  gap: var(--space-sm);
  font-size: 48rpx;
}
.review-stars-sm {
  font-size: 36rpx;
}
.review-star {
  color: var(--text-hint);
}
.review-star.filled {
  color: var(--warning);
}
.review-sub-row {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-xs);
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--border);
}
.review-sub-row:last-child {
  border-bottom: none;
}
.review-rating-label-block {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  max-width: 100%;
}
.review-star-cap {
  color: var(--warning);
  margin-top: 2rpx;
}
.review-evidence-block {
  margin-top: var(--space-lg);
  padding-top: var(--space-lg);
  border-top: 1rpx solid var(--border);
}
.review-evidence-block:first-of-type {
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}
.review-evidence-head {
  margin-bottom: var(--space-sm);
}
.review-evidence-cell {
  margin-top: var(--space-md);
}
.review-evidence-missing {
  margin-top: var(--space-xs);
}
.review-evidence-meta {
  margin-top: var(--space-xs);
  line-height: 1.5;
}
.review-evidence-verify {
  margin-top: var(--space-xs);
  line-height: 1.5;
  color: var(--text-secondary);
}
.review-evidence-lines {
  margin-top: var(--space-xs);
}
.review-evidence-lines-hint {
  display: block;
  line-height: 1.5;
  margin-bottom: var(--space-sm);
}
.review-evidence-line {
  display: block;
  line-height: 1.55;
  padding: var(--space-xs) 0;
  border-bottom: 1rpx solid var(--border);
}
.review-evidence-line:last-child {
  border-bottom: none;
}
.review-hint-strip {
  background: var(--primary-bg);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: var(--space-lg);
}
.review-hint-item {
  line-height: 1.5;
  margin-bottom: var(--space-xs);
}
.review-hint-item:last-child {
  margin-bottom: 0;
}
.review-pay-note {
  margin: var(--space-sm) 0 var(--space-md);
  padding: var(--space-md);
  background: var(--bg-placeholder);
  border-radius: var(--radius-md);
}
.review-pay-note-input {
  margin-top: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: var(--fs-body);
}
.review-guide-dual {
  background: var(--bg-placeholder);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: var(--space-md);
  line-height: 1.6;
}
.review-submit-btn[disabled] {
  opacity: 0.55;
}
/* 极简指引 */
.review-guide-simple {
  background: var(--primary-bg);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-md);
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-md);
}
.review-guide-simple-title {
  display: block;
  font-size: var(--fs-body);
  font-weight: 600;
  color: var(--primary);
  margin-bottom: var(--space-xs);
}
.review-guide-simple-desc {
  display: block;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: var(--space-md);
}
.review-guide-simple-btn {
  font-size: var(--fs-sm);
  color: var(--primary);
  text-decoration: underline;
}
.review-guide-simple-btn-sm {
  margin-top: var(--space-xs);
  display: inline-block;
}
.review-guide-mini {
  background: var(--primary-bg);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-md);
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-md);
}
.review-guide-mini-text {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.5;
}
.review-guide-float {
  background: var(--primary-bg);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-sm);
  padding: var(--space-sm) var(--space-md);
  margin-bottom: var(--space-sm);
}
.review-guide-float-text {
  font-size: var(--fs-sm);
  color: var(--primary);
  line-height: 1.5;
}
.review-textarea-wrap {
  position: relative;
  margin-top: var(--space-sm);
}
.review-word-count {
  position: absolute;
  top: var(--space-md);
  right: var(--space-md);
  font-size: 28rpx;
  color: var(--text-hint);
  z-index: 1;
}
.review-textarea-placeholder {
  color: var(--text-hint);
}
.review-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: var(--space-md);
  padding-right: 100rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: var(--fs-body);
  box-sizing: border-box;
}
.review-anonymous {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.review-rebate {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}
.review-bottom-pad {
  height: var(--space-2xl);
}

/* 侧边栏：详细指引 */
.review-detail-guide-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 900;
  pointer-events: none;
  transition: background 0.25s ease;
}
.review-detail-guide-mask-show {
  background: rgba(0, 0, 0, 0.4);
  pointer-events: auto;
}
.review-detail-guide-drawer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: 85%;
  max-width: 560rpx;
  background: var(--bg-card);
  z-index: 901;
  transform: translateX(100%);
  transition: transform 0.25s ease;
  box-shadow: var(--shadow-lg);
  display: flex;
  flex-direction: column;
}
.review-detail-guide-drawer-show {
  transform: translateX(0);
}
.review-detail-guide-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg) var(--space-xl);
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}
.review-detail-guide-title {
  font-size: var(--fs-h3);
  font-weight: 600;
  color: var(--text-primary);
}
.review-detail-guide-close {
  font-size: 48rpx;
  color: var(--text-hint);
  line-height: 1;
  padding: var(--space-xs);
}
.review-detail-guide-body {
  flex: 1;
  padding: var(--space-lg);
  height: 0;
}
.review-detail-guide-part {
  margin-bottom: var(--space-xl);
}
.review-detail-guide-part-title {
  display: block;
  font-size: var(--fs-body);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-md);
}
.review-detail-guide-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}
.review-detail-guide-check,
.review-detail-guide-dot {
  flex-shrink: 0;
  font-size: var(--fs-body);
}
.review-detail-guide-check-text {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 横屏适配：侧边栏加宽便于阅读 */
@media (orientation: landscape) {
  .review-detail-guide-drawer {
    max-width: 70%;
  }
}
.review-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-lg) var(--page-padding-x);
  padding-bottom: calc(var(--space-lg) + env(safe-area-inset-bottom));
  background: var(--bg-page);
}
.review-submit-btn {
  width: 100%;
}

/* —— 极简 v3 —— */
.review-v3-mod1 {
  border-left: 4rpx solid var(--primary);
}
.review-v3-chart {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-end;
  min-height: 200rpx;
  padding: var(--space-md) 0;
  gap: var(--space-xs);
}
.review-v3-chart-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}
.review-v3-chart-bar-wrap {
  width: 100%;
  max-width: 56rpx;
  height: 160rpx;
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
}
.review-v3-chart-bar {
  width: 100%;
  background: linear-gradient(180deg, var(--primary), rgba(59, 130, 246, 0.45));
  border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  min-height: 8rpx;
}
.review-v3-chart-amt {
  margin-top: var(--space-xs);
  font-size: 20rpx;
  color: var(--text-secondary);
  text-align: center;
  word-break: break-all;
}
.review-v3-chart-lbl {
  margin-top: 4rpx;
  font-size: 18rpx;
  text-align: center;
  line-height: 1.2;
}
.review-v3-appearance {
  margin-top: var(--space-lg);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
}
.review-v3-pending-grid {
  margin-top: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}
.review-v3-q {
  margin-top: var(--space-lg);
}
.review-v3-q:first-of-type {
  margin-top: var(--space-sm);
}
.review-v3-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}
.review-v3-chip {
  padding: var(--space-sm) var(--space-md);
  border-radius: 999rpx;
  border: 1rpx solid var(--border);
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  background: var(--bg-page);
}
.review-v3-chip.on {
  border-color: var(--primary);
  color: var(--primary);
  background: var(--primary-bg);
}
.review-stars-lg .review-star {
  font-size: 44rpx;
  margin-right: var(--space-sm);
}
.review-v3-privacy-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--border);
}
.review-v3-privacy-row:last-child {
  border-bottom: none;
}
.review-v3-check {
  font-size: 36rpx;
  line-height: 1.2;
  color: var(--text-hint);
}
.review-v3-check.on {
  color: var(--primary);
}
.review-v3-privacy-body {
  flex: 1;
  min-width: 0;
}

.review-shop-head-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-md);
}
.review-shop-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  background: var(--bg-placeholder);
}
.review-shop-head-main {
  flex: 1;
  min-width: 0;
}
.review-shop-addr {
  display: block;
  margin-top: var(--space-xs);
  line-height: 1.4;
}

.review-tag-scroll {
  width: 100%;
  white-space: nowrap;
}
.review-tag-strip {
  display: inline-flex;
  flex-direction: row;
  gap: var(--space-sm);
  padding-bottom: var(--space-xs);
}
.review-metric-tag {
  display: inline-flex;
  flex-direction: column;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
  min-width: 140rpx;
  flex-shrink: 0;
}
.review-metric-tag--sys {
  background: var(--bg-page);
}
.review-metric-tag--ai {
  background: rgba(234, 179, 8, 0.08);
  border-color: rgba(234, 179, 8, 0.35);
}
.review-metric-tag--user {
  background: var(--primary-bg);
  border-color: rgba(37, 99, 235, 0.25);
}
.review-metric-tag-text {
  font-size: var(--fs-cap);
  color: var(--text-primary);
  font-weight: 500;
}
.review-metric-tag-sub {
  font-size: 20rpx;
  color: var(--text-weak);
  margin-top: 4rpx;
}

.review-quote-node {
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--border-light);
}
.review-quote-node:last-child {
  border-bottom: none;
}

.review-ai-disclaimer {
  display: block;
  line-height: 1.45;
  color: var(--text-weak);
}

.review-mini-btn {
  margin-top: var(--space-sm);
}
