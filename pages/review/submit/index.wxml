<!-- 主评价页 · 极简 v3（店头→四维星+折叠证据→补充与图→店端素材授权） -->
<custom-nav-bar title="评价" showBack="{{true}}" />
<view class="page-root review-page" style="{{pageRootStyle}}">
  <block wx:if="{{loading}}">
    <view class="review-loading"><text class="text-muted fs-body">加载中...</text></view>
  </block>
  <block wx:elif="{{error}}">
    <view class="review-error card">
      <text class="text-muted fs-body">{{error}}</text>
      <view class="review-back-btn" bindtap="onBack">返回</view>
    </view>
  </block>
  <block wx:elif="{{submitted}}">
    <view class="review-success card">
      <text class="fs-h3 fw-bold text-success">评价提交成功</text>
      <text class="fs-body text-muted" style="margin-top: var(--space-md);" wx:if="{{!isInvalidReview && !pendingHumanAudit}}">奖励金 {{rewardAmount}} 元已到账</text>
      <block wx:elif="{{pendingHumanAudit}}">
        <text class="fs-body fw-medium" style="margin-top: var(--space-md); display: block;">正在人工审核，请稍候</text>
        <text class="fs-body text-muted" style="margin-top: var(--space-sm); display: block;">您的评价已收到，平台将尽快完成复核。</text>
        <text class="fs-sm text-weak" style="margin-top: var(--space-md); display: block;" wx:if="{{invalidReason}}">（参考：{{invalidReason}}）</text>
      </block>
      <block wx:elif="{{isInvalidReview}}">
        <text class="fs-body text-muted" style="margin-top: var(--space-md);">未达有效标准，无法获得奖励金。</text>
        <text class="fs-body text-primary" style="margin-top: var(--space-sm); display: block;" wx:if="{{invalidReason}}">主要原因：{{invalidReason}}</text>
      </block>
      <view class="review-success-actions">
        <button class="btn-primary" wx:if="{{reviewId}}" bindtap="onToFollowup">去追评</button>
        <button class="btn-primary" bindtap="onToOrder">查看订单</button>
        <button class="btn-secondary" bindtap="onToUser">返回个人中心</button>
      </view>
    </view>
  </block>
  <block wx:else>
    <view class="review-compliance review-compliance-highlight">
      <text class="review-compliance-text">奖励与内容真实性、完整性相关，与好评/差评无关。系统留痕材料仅供对照；每行星级均需您本人确认，平台不对维修结果作鉴定结论。</text>
    </view>

    <scroll-view class="review-scroll" scroll-y style="{{scrollStyle}}">
      <!-- 1 店头 -->
      <view class="review-section card review-shop-head">
        <view class="review-shop-head-row">
          <image class="review-shop-logo" src="{{info.shop_logo || '/images/brand/brand-app-icon-zhejian.png'}}" mode="aspectFill"/>
          <view class="review-shop-head-main">
            <text class="fs-body fw-bold text-primary">{{info.shop_name || '维修厂'}}</text>
            <text class="text-muted fs-cap review-shop-addr" wx:if="{{info.shop_address_line}}">{{info.shop_address_line}}</text>
            <text class="text-weak fs-sm" wx:else>地址以门店登记为准</text>
          </view>
        </view>
      </view>

      <!-- 2 四维星级 + 折叠系统留痕 -->
      <view class="review-section card">
        <view class="review-section-title fs-body fw-bold">请您评价</view>
        <text class="text-weak fs-sm" style="display:block;margin-bottom:var(--space-md);">请完成四项星级。点各题下方可展开查看报价记录、订单侧材料与店方验真说明（仅供参考）。您在本页上传的照片将默认参与公示；店端留档图是否公开由下方授权项决定。</text>

        <!-- 1 报价透明度 -->
        <view class="review-v3-linear-block">
          <view class="review-v3-star-head">
            <text class="review-v3-linear-q fs-body fw-medium">1. 报价透明度</text>
            <view class="review-stars review-stars-lg">
              <block wx:for="{{[1,2,3,4,5]}}" wx:for-item="s" wx:key="*this">
                <text class="review-star {{s <= v3.quote_transparency_star ? 'filled' : ''}}" data-field="quote_transparency_star" data-s="{{s}}" bindtap="onV3FiveStarTap">{{s <= v3.quote_transparency_star ? '★' : '☆'}}</text>
              </block>
            </view>
          </view>
          <view class="review-expand-hint text-muted fs-sm" bindtap="onToggleExpand" data-key="quote">
            <text>{{expandQuote ? '▲ 收起' : '▼ 查看'}}报价记录与凭证图</text>
          </view>
          <view wx:if="{{expandQuote}}" class="review-expand-body">
            <text class="text-weak fs-sm">以下为订单内记录的报价节点与变动原因，供打「报价透明度」星级时对照。</text>
            <view class="review-quote-node" wx:for="{{quoteDisplayNodes}}" wx:for-item="qn" wx:for-index="qni" wx:key="qni">
              <text class="fs-body fw-medium">{{qn.short_label}}</text>
              <text class="text-muted fs-sm" style="display:block;">{{qn.amount != null ? '¥' + qn.amount : '金额 —'}}{{qn.status_text ? ' · ' + qn.status_text : ''}}</text>
              <text class="text-weak fs-cap" wx:if="{{qn.change_note}}" style="display:block;margin-top:4rpx;">变动原因：{{qn.change_note}}</text>
            </view>
            <text class="fs-body text-muted" wx:if="{{!quoteDisplayNodes.length}}">暂无报价节点记录</text>
            <text class="fs-body fw-medium" style="display:block;margin-top:var(--space-md);" wx:if="{{quoteEvidenceImages.length}}">结算单与定损材料（如有）</text>
            <view class="review-evidence-grid" wx:if="{{quoteEvidenceImages.length}}" style="margin-top:var(--space-xs);">
              <image wx:for="{{quoteEvidenceImages}}" wx:for-item="ev" wx:key="*this" class="review-evidence-thumb" src="{{ev}}" mode="aspectFill"/>
            </view>
          </view>
        </view>

        <!-- 2 故障整体修复（含外观） -->
        <view class="review-v3-linear-block">
          <view class="review-v3-star-head">
            <text class="review-v3-linear-q fs-body fw-medium">2. 故障整体修复程度</text>
            <view class="review-stars review-stars-lg">
              <block wx:for="{{[1,2,3,4,5]}}" wx:for-item="s" wx:key="*this">
                <text class="review-star {{s <= v3.repair_effect_star ? 'filled' : ''}}" data-field="repair_effect_star" data-s="{{s}}" bindtap="onV3FiveStarTap">{{s <= v3.repair_effect_star ? '★' : '☆'}}</text>
              </block>
            </view>
          </view>
          <view class="review-expand-hint text-muted fs-sm" bindtap="onToggleExpand" data-key="repair">
            <text>{{expandRepair ? '▲ 收起' : '▼ 查看'}}维修前后对照图</text>
          </view>
          <view wx:if="{{expandRepair}}" class="review-expand-body">
            <text class="text-weak fs-sm">维修前照片来自您提交竞价时的定损/上报；维修后照片来自服务商提交「维修完成」时的完工凭证。下列为订单侧留痕，供打「整体修复程度」星级时对照。</text>
            <text class="fs-body fw-medium" style="display:block;margin-top:var(--space-md);" wx:if="{{beforeEvidenceImages.length}}">维修前（竞价/定损上报）</text>
            <view class="review-evidence-grid" wx:if="{{beforeEvidenceImages.length}}" style="margin-top:var(--space-xs);">
              <image wx:for="{{beforeEvidenceImages}}" wx:for-item="ev" wx:key="*this" class="review-evidence-thumb" src="{{ev}}" mode="aspectFill"/>
            </view>
            <text class="fs-body fw-medium" style="display:block;margin-top:var(--space-md);" wx:if="{{repairEvidenceImages.length}}">维修后（服务商完工凭证）</text>
            <view class="review-evidence-grid" wx:if="{{repairEvidenceImages.length}}" style="margin-top:var(--space-xs);">
              <image wx:for="{{repairEvidenceImages}}" wx:for-item="ev" wx:key="*this" class="review-evidence-thumb" src="{{ev}}" mode="aspectFill"/>
            </view>
            <text class="text-muted fs-sm" style="display:block;margin-top:var(--space-md);" wx:if="{{!beforeEvidenceImages.length && !repairEvidenceImages.length}}">本单暂无维修前/后对照图片记录。</text>
          </view>
        </view>

        <!-- 3 配件与材料可溯源度 -->
        <view class="review-v3-linear-block">
          <view class="review-v3-star-head">
            <text class="review-v3-linear-q fs-body fw-medium">3. 配件与材料可溯源度</text>
            <view class="review-stars review-stars-lg">
              <block wx:for="{{[1,2,3,4,5]}}" wx:for-item="s" wx:key="*this">
                <text class="review-star {{s <= v3.parts_traceability_star ? 'filled' : ''}}" data-field="parts_traceability_star" data-s="{{s}}" bindtap="onV3FiveStarTap">{{s <= v3.parts_traceability_star ? '★' : '☆'}}</text>
              </block>
            </view>
          </view>
          <view class="review-expand-hint text-muted fs-sm" bindtap="onToggleExpand" data-key="parts">
            <text>{{expandParts ? '▲ 收起' : '▼ 查看'}}店端配件留档与验真说明</text>
          </view>
          <view wx:if="{{expandParts}}" class="review-expand-body">
            <text class="text-weak fs-sm">下列为店端配件留档图及店方填写的验真方式（订单侧记录），供打「配件可溯源度」星级时对照。</text>
            <view class="review-evidence-grid" wx:if="{{partsEvidenceImages.length}}">
              <image wx:for="{{partsEvidenceImages}}" wx:for-item="ev" wx:key="*this" class="review-evidence-thumb" src="{{ev}}" mode="aspectFill"/>
            </view>
            <text class="fs-body" style="display:block;margin-top:var(--space-md);">{{merchantVerifyLine}}</text>
            <button class="btn-secondary review-mini-btn" size="mini" bindtap="onOwnerVerifyTap">快捷记录验真（选填）</button>
          </view>
        </view>

        <!-- 系统提示（客观题辅助，只读） -->
        <view class="review-v3-linear-block review-v3-linear-info" wx:for="{{objectiveHintsList}}" wx:key="code">
          <text class="review-v3-linear-q fs-body fw-medium">提示（系统）</text>
          <text class="text-muted fs-sm" style="display:block;margin-top:var(--space-xs);">{{item.text}}</text>
        </view>

        <!-- 4 服务态度 -->
        <view class="review-v3-linear-block">
          <view class="review-v3-star-head">
            <text class="review-v3-linear-q fs-body fw-medium">4. 服务态度</text>
            <view class="review-stars review-stars-lg">
              <block wx:for="{{[1,2,3,4,5]}}" wx:for-item="s" wx:key="*this">
                <text class="review-star {{s <= v3.service_experience_star ? 'filled' : ''}}" data-field="service_experience_star" data-s="{{s}}" bindtap="onV3FiveStarTap">{{s <= v3.service_experience_star ? '★' : '☆'}}</text>
              </block>
            </view>
          </view>
        </view>

        <!-- 5 补充说明与图片 -->
        <view class="review-v3-linear-block">
          <text class="review-v3-linear-q fs-body fw-medium">5. 补充说明与图片（选填）</text>
        <text class="text-weak fs-sm" style="display:block;margin-bottom:var(--space-md);">补充说明不超过 200 字。图片统一在此上传（完工、结算、定损、举证等均可，最多 12 张）。</text>
        <view class="review-textarea-wrap">
          <text class="review-word-count">{{contentLength}}/200</text>
          <textarea class="review-textarea" placeholder="选填，真实细节有助于其他车主参考" value="{{module3.content}}" bindinput="onM3Content" maxlength="200" placeholder-class="review-textarea-placeholder"/>
        </view>
        <view class="review-upload-row">
          <text class="fs-body">补充图片（选填）</text>
          <view class="review-upload-grid">
            <view class="review-upload-item" wx:for="{{ownerExtraImages}}" wx:for-index="oidx" wx:key="oidx">
              <image class="review-thumb" src="{{item}}" mode="aspectFill" data-current="{{item}}" bindtap="onPreviewOwnerExtraImages"/>
              <view class="review-del" data-index="{{oidx}}" catchtap="onOwnerExtraDel"><text class="review-del-text">×</text></view>
            </view>
            <view class="review-upload-btn" wx:if="{{ownerExtraImages.length < 12}}" bindtap="onChooseOwnerExtra">
              <text class="review-add-text">+</text>
              <text class="text-muted fs-cap">上传</text>
            </view>
          </view>
        </view>
        </view>
      </view>

      <!-- 对外授权 -->
      <view class="review-section card">
        <view class="review-section-title fs-body fw-bold">对外展示授权</view>
        <text class="text-weak fs-sm" style="display:block;margin-bottom:var(--space-md);">您在本页上传的照片视为同意参与公示（由服务端写入公示列表）。下列三项仅控制店端留档、维修前后对照、结算单据位等订单侧素材是否在店铺评价列表、口碑流中公开展示；若订单中暂无对应图片，勾选后对外也不会出现该部分内容。提交后不可改。</text>
        <view class="review-v3-privacy-row" bindtap="onPublicMediaToggle" data-key="exterior_before_after">
          <text class="review-v3-check {{review_public_media.exterior_before_after ? 'on' : ''}}">{{review_public_media.exterior_before_after ? '☑' : '☐'}}</text>
          <view class="review-v3-privacy-body">
            <text class="fs-body">公开维修前/后对照图</text>
            <text class="text-weak fs-cap">订单侧维修前/后对照类素材是否对外展示</text>
          </view>
        </view>
        <view class="review-v3-privacy-row" bindtap="onPublicMediaToggle" data-key="parts_contrast">
          <text class="review-v3-check {{review_public_media.parts_contrast ? 'on' : ''}}">{{review_public_media.parts_contrast ? '☑' : '☐'}}</text>
          <view class="review-v3-privacy-body">
            <text class="fs-body">公开店端配件留档图</text>
            <text class="text-weak fs-cap">店端配件留档类素材是否对外展示</text>
          </view>
        </view>
        <view class="review-v3-privacy-row" bindtap="onPublicMediaToggle" data-key="settlement_docs">
          <text class="review-v3-check {{review_public_media.settlement_docs ? 'on' : ''}}">{{review_public_media.settlement_docs ? '☑' : '☐'}}</text>
          <view class="review-v3-privacy-body">
            <text class="fs-body">公开结算单据图</text>
            <text class="text-weak fs-cap">对外结算单据位相关图是否展示（首张补充图等规则以后端为准）</text>
          </view>
        </view>
      </view>

      <view class="review-section card review-reward" wx:if="{{rewardPreview}}">
        <view class="review-section-title fs-body fw-bold">奖励金预估</view>
        <view class="review-reward-total">
          <text class="text-muted fs-sm">预计可获（以实际审核为准）</text>
          <text class="fs-body text-gold fw-bold">¥{{rewardPreview.total_reward}}</text>
        </view>
      </view>

      <view class="review-section card">
        <view class="review-anonymous">
          <text class="fs-body">匿名评价</text>
          <switch checked="{{isAnonymous}}" bindchange="onAnonymousChange" color="var(--primary)"/>
        </view>
      </view>

      <view class="review-bottom-pad"></view>
    </scroll-view>

    <view class="review-footer">
      <button class="btn-primary review-submit-btn" bindtap="onSubmit" disabled="{{submitting || !canSubmit}}">
        {{submitting ? '提交中...' : '提交评价 (' + progressText + ')'}}
      </button>
    </view>
  </block>
</view>
