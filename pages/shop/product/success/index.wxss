.product-success-page {
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  box-sizing: border-box;
  background: #f8fafc;
}

.ps-hero {
  text-align: center;
  padding: 48rpx 24rpx 40rpx;
}

.ps-icon-wrap {
  width: 112rpx;
  height: 112rpx;
  line-height: 112rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: rgba(22, 163, 74, 0.15);
  color: #15803d;
  font-size: 56rpx;
  font-weight: 700;
}

.ps-title {
  display: block;
  margin-bottom: 12rpx;
}

.ps-sub {
  display: block;
  line-height: 1.5;
  padding: 0 16rpx;
}

.ps-card {
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.ps-label {
  display: block;
  margin-bottom: 8rpx;
}

.ps-label.ps-gap {
  margin-top: 24rpx;
}

.ps-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid var(--border-light, #e2e8f0);
}

.ps-actions {
  padding: 0 8rpx;
}

.ps-btn {
  width: 100%;
}

.ps-btn-second {
  margin-top: 24rpx;
}
