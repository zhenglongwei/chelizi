.product-confirm-page {
  min-height: 100vh;
  padding: 24rpx 32rpx 48rpx;
  box-sizing: border-box;
  background: #f8fafc;
}

.pc-card {
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.pc-shop {
  display: block;
  margin-bottom: 12rpx;
}

.pc-name {
  display: block;
  margin-bottom: 8rpx;
}

.pc-cat {
  display: block;
  margin-bottom: 16rpx;
}

.pc-price {
  display: block;
}

.pc-desc {
  display: block;
  margin-top: 20rpx;
  line-height: 1.5;
}

.pc-qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pc-stepper {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.pc-step-btn {
  min-width: 64rpx !important;
  padding: 0 16rpx !important;
  margin: 0 !important;
  line-height: 56rpx !important;
}

.pc-qty-num {
  min-width: 48rpx;
  text-align: center;
  font-weight: 600;
}

.pc-total {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
}

.pc-pay-wrap {
  padding: 0 8rpx;
}

.pc-pay-btn {
  width: 100%;
}
