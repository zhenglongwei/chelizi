<!-- 维修厂详情页 - 04-维修厂详情页 -->
<custom-nav-bar title="维修厂详情" showBack="{{true}}" />
<view class="page-root shop-detail-page" style="{{pageRootStyle}}">
  <block wx:if="{{loading}}">
    <view class="detail-loading text-muted fs-body">加载中...</view>
  </block>
  <block wx:elif="{{shop}}">
    <scroll-view
      class="detail-scroll"
      scroll-y
      style="{{scrollStyle}}"
      bindscrolltolower="loadReviews"
    >
      <!-- 维修厂信息区 -->
      <view class="detail-header card">
        <view class="detail-top">
          <image class="detail-logo" src="{{shop.logo}}" mode="aspectFill"/>
          <view class="detail-main">
            <text class="detail-name text-primary fs-h3 fw-bold">{{shop.name}}</text>
            <view class="detail-rating">
              <text class="detail-stars text-star fs-cap">{{shop.starsDisplay}}</text>
              <text class="detail-rating-txt text-muted fs-cap">{{shop.avgRating}} · {{shop.totalReviews}}条 · {{shop.total_orders}}单</text>
            </view>
            <view class="detail-tags" wx:if="{{shop.categories.length}}">
              <text class="detail-tag fs-cap" wx:for="{{shop.categories}}" wx:key="*this">{{item}}</text>
            </view>
          </view>
          <image
            class="detail-fav"
            src="{{favored ? '/images/icon/checked.png' : '/images/icon/unchecked.png'}}"
            mode="aspectFit"
            bindtap="onFavorite"
          />
        </view>
        <view class="detail-info">
          <view class="detail-row" wx:if="{{shop.address}}">
            <image class="detail-row-icon" src="/images/icon/location.png" mode="aspectFit"/>
            <text class="detail-row-txt text-muted fs-body">{{shop.address}}</text>
          </view>
          <view class="detail-row" wx:if="{{shop.business_hours}}">
            <image class="detail-row-icon" src="/images/icon/clock.png" mode="aspectFit"/>
            <text class="detail-row-txt text-muted fs-body">{{shop.business_hours}}</text>
          </view>
          <view class="detail-row" wx:if="{{shop.phone}}">
            <image class="detail-row-icon" src="/images/icon/phone.png" mode="aspectFit"/>
            <text class="detail-row-txt text-muted fs-body">{{shop.phone}}</text>
          </view>
        </view>
      </view>

      <!-- 店内标品（已审核上架） -->
      <view class="detail-section card" wx:if="{{shop.products && shop.products.length}}">
        <view class="detail-section-title fs-body fw-bold">店内服务 · 标品</view>
        <view class="detail-product-list">
          <view
            class="detail-product"
            wx:for="{{shop.products}}"
            wx:key="product_id"
            bindtap="onProductTap"
            data-id="{{item.product_id}}"
          >
            <image class="detail-product-cover" src="{{item.cover}}" mode="aspectFill" wx:if="{{item.cover}}"/>
            <view class="detail-product-cover detail-product-cover-ph" wx:else></view>
            <view class="detail-product-main">
              <text class="detail-product-name fs-body fw-bold">{{item.name}}</text>
              <text class="text-muted fs-cap">{{item.category}}</text>
              <text class="detail-product-price fs-body fw-bold text-primary">¥{{item.priceText}}</text>
            </view>
            <text class="detail-product-buy fs-cap text-primary">购买</text>
          </view>
        </view>
      </view>

      <!-- 用户评价（评价为核心：置顶，紧接店铺信息） -->
      <view class="detail-section card">
        <view class="detail-section-title fs-body fw-bold">用户评价</view>
        <view class="detail-review-summary" wx:if="{{shop.totalReviews > 0}}">
          <view class="detail-review-score">
            <text class="detail-score-num text-primary">{{shop.avgRating}}</text>
            <text class="text-muted fs-cap"> · {{shop.totalReviews}}条真实评价</text>
          </view>
          <text class="detail-review-summary-hint text-weak fs-sm" wx:if="{{shop.totalReviews >= 5}}">按内容质量、发布时间排序</text>
        </view>
        <view class="detail-no-review text-muted fs-body" wx:else>暂无评价</view>
      </view>

      <!-- 历史偏差率 -->
      <view class="detail-section card" wx:if="{{shop.deviation_rate != null}}">
        <view class="detail-section-title fs-body fw-bold">报价偏差率</view>
        <view class="detail-deviation">
          <text class="detail-deviation-value {{shop.deviationClass}}">{{shop.deviationRate}}%</text>
          <text class="detail-deviation-desc text-muted fs-cap">历史报价与实际金额偏差，越低越准</text>
        </view>
      </view>

      <!-- 评价列表 -->
      <view class="detail-section card">
        <view class="detail-review-filter" wx:if="{{repairProjectKeys.length > 0}}">
          <text class="detail-filter-label fs-cap text-muted">按维修项目</text>
          <view class="detail-filter-chips">
            <view class="detail-filter-chip {{!repairProjectKey ? 'active' : ''}}" bindtap="onRepairProjectFilter" data-key="">全部</view>
            <view class="detail-filter-chip {{repairProjectKey === item ? 'active' : ''}}" wx:for="{{repairProjectKeys}}" wx:key="*this" bindtap="onRepairProjectFilter" data-key="{{item}}">{{item}}</view>
          </view>
        </view>
        <view class="detail-review-list" wx:if="{{reviews.length}}">
          <view
            class="detail-review-item {{item.expanded ? 'detail-review-item-expanded' : ''}}"
            wx:for="{{reviews}}"
            wx:key="review_id"
            id="review-{{item.review_id}}"
            data-review-id="{{item.review_id}}"
          >
            <view class="detail-review-head">
              <text class="detail-review-user text-primary fs-body">{{item.user.nickname}}</text>
              <text class="detail-review-date text-weak fs-cap">{{item.dateText}}</text>
            </view>
            <view class="detail-review-section" wx:if="{{item.repair_items.length || item.amountText || (item.part_promise_lines && item.part_promise_lines.length)}}">
              <text class="detail-review-section-label text-muted fs-cap">本单信息</text>
              <view class="detail-review-meta" wx:if="{{item.repair_items.length}}">
                <text class="detail-review-meta-label text-muted fs-cap">维修项目</text>
                <view class="detail-review-meta-tags">
                  <text class="detail-review-meta-tag fs-cap" wx:for="{{item.repair_items}}" wx:for-item="ritem" wx:for-index="ridx" wx:key="ridx">{{ritem}}</text>
                </view>
              </view>
              <view class="detail-review-meta-fallback text-weak fs-sm" wx:elif="{{item.amountText || (item.part_promise_lines && item.part_promise_lines.length)}}">维修项目：暂无结构化记录，请以方案承诺、新配件留档与文字描述为准</view>
              <view class="detail-review-meta" wx:if="{{item.part_promise_lines && item.part_promise_lines.length}}">
                <text class="detail-review-meta-label text-muted fs-cap">方案配件承诺（订单）</text>
                <text class="detail-review-meta-label-sub text-weak fs-sm">含「修/换」及换件时的配件等级（如原厂、大厂件），可与下方新配件留档图对照</text>
                <view class="detail-review-meta-tags">
                  <text class="detail-review-meta-tag detail-review-meta-tag--promise fs-cap" wx:for="{{item.part_promise_lines}}" wx:for-item="pline" wx:for-index="pidx" wx:key="pidx">{{pline}}</text>
                </view>
              </view>
              <view class="detail-review-meta" wx:if="{{item.amountText}}">
                <text class="detail-review-meta-label text-muted fs-cap">结算金额</text>
                <text class="detail-review-meta-val fs-body fw-bold">¥{{item.amountText}}</text>
              </view>
            </view>
            <view class="detail-review-section" wx:if="{{item.rating}}">
              <text class="detail-review-section-label text-muted fs-cap">总体星级</text>
              <view class="detail-review-stars text-star fs-cap">{{item.ratingText}}</view>
            </view>
            <view class="detail-review-objectives" wx:if="{{item.hasObjectives}}">
              <view class="detail-review-obj-head">
                <text class="detail-review-obj-section-title fs-body fw-bold">车主核验</text>
                <text class="detail-review-obj-help text-primary fs-sm" bindtap="onObjectiveReaderTip">新手怎么读</text>
              </view>
              <text class="detail-review-obj-sub text-muted fs-sm">平台必答 · 与定损/发票无关 · 建议与实拍、正文对照</text>
              <view class="detail-review-obj-summary" wx:if="{{item.objectiveSummary}}">
                <text class="detail-review-obj-summary-text fs-cap">{{item.objectiveSummary}}</text>
              </view>
              <view class="detail-review-obj-card" wx:if="{{item.objQ1 != null}}">
                <view class="detail-review-obj-num">1</view>
                <view class="detail-review-obj-body">
                  <text class="detail-review-obj-title fs-body">方案与进度是否透明</text>
                  <text class="detail-review-obj-hint text-muted fs-sm">进度、增项与费用是否及时告知；有无未经同意的加价或先斩后奏</text>
                  <view class="detail-review-obj-pill {{item.objQ1 ? 'pill-yes' : 'pill-no'}}">
                    <text class="detail-review-obj-pill-label fs-sm">车主确认</text>
                    <text class="detail-review-obj-pill-val fs-cap">{{item.objQ1 ? '是' : '否'}}</text>
                  </view>
                </view>
              </view>
              <view class="detail-review-obj-card" wx:if="{{item.objQ2 != null}}">
                <view class="detail-review-obj-num">2</view>
                <view class="detail-review-obj-body">
                  <text class="detail-review-obj-title fs-body">配件是否当面核对</text>
                  <text class="detail-review-obj-hint text-muted fs-sm">换下件/装配件是否当面核对；另可对照本单「新配件留档」与上方配件等级承诺（标识、包装是否相符）</text>
                  <view class="detail-review-obj-pill {{item.objQ2 ? 'pill-yes' : 'pill-no'}}">
                    <text class="detail-review-obj-pill-label fs-sm">车主确认</text>
                    <text class="detail-review-obj-pill-val fs-cap">{{item.objQ2 ? '是' : '否'}}</text>
                  </view>
                </view>
              </view>
              <view class="detail-review-obj-card" wx:if="{{item.objQ3 != null}}">
                <view class="detail-review-obj-num">3</view>
                <view class="detail-review-obj-body">
                  <text class="detail-review-obj-title fs-body">本次送修问题是否修好</text>
                  <text class="detail-review-obj-hint text-muted fs-sm">针对本次症状/部位是否排除，非笼统「车没问题」</text>
                  <view class="detail-review-obj-pill {{item.objQ3 ? 'pill-yes' : 'pill-no'}}">
                    <text class="detail-review-obj-pill-label fs-sm">车主确认</text>
                    <text class="detail-review-obj-pill-val fs-cap">{{item.objQ3 ? '是' : '否'}}</text>
                  </view>
                </view>
              </view>
              <text class="detail-review-obj-foot text-weak fs-sm">由完成本单评价的车主作答，供浏览时交叉验证</text>
            </view>
            <view class="detail-review-section" wx:if="{{(item.before_images && item.before_images.length) || (item.after_images && item.after_images.length) || (item.completion_images && item.completion_images.length) || (item.material_photos && item.material_photos.length)}}">
              <text class="detail-review-section-label text-muted fs-cap">实拍对照</text>
              <view class="detail-review-images-wrap detail-review-images-wrap--in-section">
              <view class="detail-review-img-group" wx:if="{{item.before_images && item.before_images.length}}">
                <text class="detail-review-img-label text-muted fs-cap">维修前（车主）</text>
                <view class="detail-review-images">
                  <image class="detail-review-img" wx:for="{{item.before_images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" show-menu-by-longpress="{{true}}"/>
                </view>
              </view>
              <view class="detail-review-img-group" wx:if="{{item.after_images && item.after_images.length}}">
                <text class="detail-review-img-label text-muted fs-cap">维修后（车主）</text>
                <view class="detail-review-images">
                  <image class="detail-review-img" wx:for="{{item.after_images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" show-menu-by-longpress="{{true}}"/>
                </view>
              </view>
              <view class="detail-review-img-group" wx:elif="{{item.completion_images && item.completion_images.length}}">
                <text class="detail-review-img-label text-muted fs-cap">完工实拍（车主）</text>
                <view class="detail-review-images">
                  <image class="detail-review-img" wx:for="{{item.completion_images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" show-menu-by-longpress="{{true}}"/>
                </view>
              </view>
              <view class="detail-review-img-group" wx:if="{{item.material_photos && item.material_photos.length}}">
                <text class="detail-review-img-label text-muted fs-cap">新配件留档（服务商上传）</text>
                <text class="detail-review-img-sublabel text-muted fs-sm">完工凭证中的新配件实拍；请对照上方「方案配件承诺」中的等级（原厂/大厂件等），查看包装、标签、型号是否一致。</text>
                <view class="detail-review-images">
                  <image class="detail-review-img" wx:for="{{item.material_photos}}" wx:for-item="mimg" wx:for-index="midx" wx:key="midx" src="{{mimg}}" mode="aspectFill" show-menu-by-longpress="{{true}}"/>
                </view>
              </view>
              </view>
            </view>
            <view class="detail-review-section" wx:if="{{item.content}}">
              <text class="detail-review-section-label text-muted fs-cap">文字评价</text>
              <view class="detail-review-content-wrap">
                <text class="detail-review-content text-muted fs-body {{item.expanded ? '' : 'detail-review-content-collapsed'}}">{{item.expanded ? item.content : item.contentPreview}}</text>
                <text class="detail-review-expand-btn text-primary fs-sm" wx:if="{{!item.expanded && item.content.length > 60}}" bindtap="onExpandReview" data-index="{{index}}">展开</text>
              </view>
            </view>
            <view class="detail-review-badge text-weak fs-sm" wx:if="{{item.isLowRating}}">该用户已完成全部评价要求，全额领取对应奖励</view>
            <view class="detail-review-appeal" wx:if="{{item.is_my_review && item.order_id}}" bindtap="onAppealTap" data-order-id="{{item.order_id}}">
              <text class="text-primary fs-sm">对维修有异议？发起申诉</text>
            </view>
            <view class="detail-review-owner-verify text-danger fs-sm" wx:if="{{item.has_owner_verify_badge}}">车主验证・真实避坑</view>
            <view class="detail-review-actions">
              <view class="detail-review-like" wx:if="{{!item.is_my_review}}" bindtap="onLikeReview" data-index="{{index}}" data-review-id="{{item.review_id}}">
                <image class="detail-review-like-icon" src="{{item.liked ? '/images/icon/liked.png' : '/images/icon/like.png'}}" mode="aspectFit"/>
                <text class="text-muted fs-cap">{{item.like_count || 0}} 点赞</text>
                <text class="text-weak fs-sm" wx:if="{{item.post_verify_count > 0}}"> · {{item.post_verify_count}}位车主验证有用</text>
              </view>
              <view class="detail-review-like text-weak fs-cap" wx:else>
                <text>{{item.like_count || 0}} 点赞</text>
              </view>
              <view class="detail-review-dislike {{item.disliked ? 'disliked' : ''}}" wx:if="{{!item.is_my_review && !item.liked}}" bindtap="onDislikeReview" data-index="{{index}}" data-review-id="{{item.review_id}}">
                <text class="detail-review-dislike-icon">👎</text>
                <text class="text-muted fs-cap">{{item.dislike_count || 0}} 踩</text>
              </view>
              <view class="detail-review-dislike disliked" wx:elif="{{!item.is_my_review && item.disliked}}">
                <text class="detail-review-dislike-icon">👎</text>
                <text class="text-weak fs-cap">{{item.dislike_count || 0}} 踩</text>
              </view>
            </view>
          </view>
        </view>
        <view class="detail-more text-muted fs-cap" wx:if="{{loadingReviews}}">加载更多...</view>
        <view class="detail-more text-muted fs-cap" wx:elif="{{!hasMoreReviews && reviews.length > 0}}">— 没有更多了 —</view>
        <view class="detail-no-review text-muted fs-body" wx:elif="{{!loadingReviews && reviews.length === 0}}">暂无评价</view>
      </view>

      <!-- 服务项目 -->
      <view class="detail-section card" wx:if="{{shop.services && shop.services.length}}">
        <view class="detail-section-title fs-body fw-bold">服务项目</view>
        <view class="detail-services">
          <view class="detail-service" wx:for="{{shop.services}}" wx:key="name">
            <text class="fs-body">{{item.name}}</text>
            <text class="text-muted fs-cap" wx:if="{{item.min_price || item.max_price}}">{{item.min_price || 0}}-{{item.max_price || 0}}元</text>
          </view>
        </view>
      </view>

      <view class="detail-bottom-pad"></view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="detail-footer">
      <view class="detail-footer-btn" bindtap="onCall">
        <image class="detail-footer-icon" src="/images/icon/phone.png" mode="aspectFit"/>
        <text class="fs-cap">电话</text>
      </view>
      <view class="detail-footer-btn" bindtap="onNavigate">
        <image class="detail-footer-icon" src="/images/icon/location.png" mode="aspectFit"/>
        <text class="fs-cap">导航</text>
      </view>
      <view class="detail-footer-btn detail-footer-book" bindtap="onBook">
        <text class="fs-body fw-bold">立即预约</text>
      </view>
    </view>
  </block>
</view>
