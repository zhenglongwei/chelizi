.merchant-warranty-style {
  min-height: 100vh;
  padding: var(--space-md);
  padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.warranty-style-loading {
  padding: var(--space-xl);
  text-align: center;
}

.warranty-style-intro {
  display: block;
  margin-top: var(--space-sm);
  line-height: 1.6;
}

.warranty-style-section-title {
  margin-bottom: var(--space-md);
}

.warranty-style-opt {
  padding: var(--space-md);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--bg-placeholder);
  margin-bottom: var(--space-sm);
}

.warranty-style-opt--on {
  border-color: var(--accent);
  background: rgba(234, 179, 8, 0.08);
}

.warranty-style-opt-inner {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  width: 100%;
}

.warranty-style-opt-radio {
  width: 48rpx;
  font-size: 28rpx;
  color: var(--warning);
  flex-shrink: 0;
}

.warranty-style-opt-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.warranty-style-preview-section {
  margin-top: var(--space-md);
}

.warranty-style-preview-hint {
  display: block;
  margin-bottom: var(--space-md);
  line-height: 1.55;
}
