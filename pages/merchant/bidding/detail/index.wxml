<!-- 竞价详情与报价 - M05，报价明细：损失部位、维修方案+配件类型 -->
<custom-nav-bar title="竞价详情" showBack="{{true}}" />
<view class="page-root merchant-bidding-detail" style="{{pageRootStyle}}">
<scroll-view class="detail-scroll" scroll-y style="{{scrollStyle}}">
  <!-- 车主预报价依据：优先阅读，勿忽略 -->
  <view class="merchant-owner-evidence card" wx:if="{{bidding}}">
    <view class="merchant-evidence-head">
      <text class="merchant-evidence-title fs-h3 fw-bold">车主预报价依据</text>
      <text class="merchant-evidence-priority fs-cap">请优先根据下列照片与说明核损、填写报价</text>
    </view>
    <view class="merchant-evidence-photos-block" wx:if="{{bidding.images && bidding.images.length}}">
      <text class="merchant-evidence-block-label fs-body fw-bold">事故照片</text>
      <view class="merchant-evidence-photos-grid">
        <view class="merchant-evidence-photo-item" wx:for="{{bidding.images}}" wx:key="index" data-index="{{index}}" bindtap="onPreviewPhoto">
          <image class="merchant-evidence-photo-thumb" src="{{item}}" mode="aspectFill"/>
        </view>
      </view>
    </view>
    <view class="merchant-evidence-empty-photos text-muted fs-cap" wx:else>
      车主未上传事故照片
    </view>
    <view class="merchant-evidence-desc-block" wx:if="{{bidding.user_description}}">
      <text class="merchant-evidence-block-label fs-body fw-bold">车主补充说明</text>
      <view class="merchant-evidence-desc-body">
        <text class="fs-body merchant-evidence-desc-text">{{bidding.user_description}}</text>
      </view>
    </view>
    <view class="merchant-evidence-no-desc text-muted fs-cap" wx:elif="{{bidding.images && bidding.images.length}}">
      无补充说明
    </view>
    <view class="merchant-evidence-meta">
      <view class="detail-vehicle-row">
        <text class="text-muted fs-cap">车辆</text>
        <text class="fs-body fw-medium">{{bidding.vehicle_info.brand || ''}} {{bidding.vehicle_info.model || ''}}</text>
        <text class="text-weak fs-sm" wx:if="{{bidding.vehicle_info.plate_number}}">{{bidding.vehicle_info.plate_number}}</text>
      </view>
      <view class="detail-insurance-row">
        <text class="text-muted fs-cap">支付方式</text>
        <text class="fs-body fw-medium">{{bidding.insurance_info && bidding.insurance_info.is_insurance ? '保险支付' : '自费'}}</text>
      </view>
      <view class="detail-insurance-detail" wx:if="{{bidding.insurance_info && bidding.insurance_info.is_insurance}}">
        <view class="detail-insurance-item" wx:if="{{bidding.insurance_info.accident_type_label}}">
          <text class="text-muted fs-cap">事故类型</text>
          <text class="fs-sm">{{bidding.insurance_info.accident_type_label}}</text>
        </view>
        <view class="detail-insurance-item" wx:if="{{bidding.insurance_info.insurance_company}}">
          <text class="text-muted fs-cap">{{bidding.insurance_info.insurance_company_other ? '自家保险' : '保险公司'}}</text>
          <text class="fs-sm">{{bidding.insurance_info.insurance_company}}</text>
        </view>
        <view class="detail-insurance-item" wx:if="{{bidding.insurance_info.insurance_company_other}}">
          <text class="text-muted fs-cap">对家保险</text>
          <text class="fs-sm">{{bidding.insurance_info.insurance_company_other}}</text>
        </view>
        <view class="detail-insurance-item" wx:if="{{bidding.insurance_info.main_responsible}}">
          <text class="text-muted fs-cap">主责方</text>
          <text class="fs-sm">{{bidding.insurance_info.main_responsible}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 预报价参考：默认折叠，与车主端竞价页一致 -->
  <view class="merchant-ai-report card" wx:if="{{bidding && reportHasAnalysisSection}}">
    <view class="merchant-ai-report-head" bindtap="toggleAiReport">
      <view class="merchant-ai-report-head-text">
        <text class="fs-body fw-bold">预报价参考</text>
        <text class="merchant-ai-report-hint text-muted fs-cap">仅供参考 · 点击展开</text>
      </view>
      <view class="merchant-ai-report-head-right">
        <view class="detail-card-badge merchant-ai-badge" wx:if="{{bidding.complexity_level}}">
          <text class="fs-sm">{{bidding.complexity_level}}</text>
        </view>
        <image class="merchant-ai-report-arrow" src="/images/icon/zhedie.png" mode="aspectFit" style="transform: rotate({{aiReportExpanded ? 180 : 0}}deg);"/>
      </view>
    </view>
    <view class="merchant-ai-report-body" wx:if="{{aiReportExpanded}}">
      <accident-report-view vm="{{reportVm}}" />
    </view>
  </view>

  <!-- 报价明细 -->
  <view class="bidding-quote-card card" wx:if="{{bidding && !bidding.my_quote}}">
    <view class="quote-card-header">
      <text class="quote-card-title fs-h3 fw-bold">报价明细</text>
      <text class="quote-card-hint text-weak fs-sm">与 Excel 模板中「报价明细」表一致：每项须含损失部位、维修方式、配件类型（换件必填五类之一）、分项金额（元）、项目质保（月）。模板内「使用说明」含完整中文填写与导入步骤。完工物料照应能佐证配件类型。</text>
      <view class="merchant-quote-toolbar">
        <view class="merchant-quote-toolbar-row merchant-quote-toolbar-row--dual">
          <button class="merchant-quote-tool-btn merchant-quote-tool-btn--half" bindtap="onDownloadQuoteTemplateExcel">下载 Excel 模板</button>
          <button class="merchant-quote-tool-btn merchant-quote-tool-btn--half" bindtap="onChooseImportExcel" disabled="{{importBusy}}">导入 Excel</button>
        </view>
        <view class="merchant-quote-toolbar-row merchant-quote-toolbar-row--dual" wx:if="{{hasAiSuggestions}}">
          <button class="merchant-quote-tool-btn merchant-quote-tool-btn--half merchant-quote-tool-btn--outline" bindtap="onUseAiSuggestions">采用 AI 建议</button>
          <button class="merchant-quote-tool-btn merchant-quote-tool-btn--half merchant-quote-tool-btn--ghost" bindtap="onAnalyzeQuotePhoto" disabled="{{importBusy}}">拍照识别</button>
        </view>
        <view class="merchant-quote-toolbar-row" wx:else>
          <button class="merchant-quote-tool-btn merchant-quote-tool-btn--full merchant-quote-tool-btn--ghost" bindtap="onAnalyzeQuotePhoto" disabled="{{importBusy}}">拍照识别</button>
        </view>
      </view>
      <text class="quote-import-hint text-weak fs-sm">下载的模板含中文说明，填好后保存为 .xlsx，通过微信发到手机，在此「导入 Excel」选择文件即可。纸质/截图可用拍照识别（需服务端配置 AI）。</text>
    </view>
    <view class="mqf-section">
      <text class="mqf-section-title fs-body fw-bold">维修项目</text>
    <view class="mqf-items-list">
      <view class="mqf-item-block" wx:for="{{quoteItems}}" wx:key="id">
        <view class="mqf-line">
          <text class="mqf-label">损失部位</text>
          <input class="mqf-input" placeholder="如：前保险杠、左前翼子板" value="{{item.damage_part}}" data-id="{{item.id}}" data-field="damage_part" bindinput="onItemFieldInput"/>
        </view>
        <view class="mqf-line mqf-line--repair">
          <text class="mqf-label">维修方式</text>
          <picker mode="selector" range="{{repairTypeOptions}}" range-key="label" value="{{item.repairTypeIndex === undefined ? 0 : item.repairTypeIndex}}" data-id="{{item.id}}" bindchange="onRepairTypeChange">
            <view class="mqf-picker">{{item.repair_type || '请选择'}}</view>
          </picker>
        </view>
        <view class="mqf-line" wx:if="{{item.repair_type === '换'}}">
          <text class="mqf-label">配件类型</text>
          <picker mode="selector" range="{{partsTypeOptions}}" range-key="label" value="{{item.partsTypeIndex === undefined || item.partsTypeIndex < 0 ? 0 : item.partsTypeIndex}}" data-id="{{item.id}}" bindchange="onPartsTypeChange">
            <view class="mqf-picker mqf-picker--parts">{{item.parts_type || '请选择'}}</view>
          </picker>
        </view>
        <view class="mqf-line" wx:else>
          <text class="mqf-label">配件类型</text>
          <text class="mqf-static text-muted fs-cap">不涉及换件</text>
        </view>
        <view class="mqf-line">
          <text class="mqf-label">分项金额（元）</text>
          <input class="mqf-input" type="digit" placeholder="必填" value="{{item.line_price}}" data-id="{{item.id}}" bindinput="onLinePriceInput"/>
        </view>
        <view class="mqf-line">
          <text class="mqf-label">项目质保（月）</text>
          <input class="mqf-input" type="number" placeholder="必填" value="{{item.line_warranty}}" data-id="{{item.id}}" bindinput="onLineWarrantyInput"/>
        </view>
        <view class="mqf-actions">
          <view class="mqf-del" data-id="{{item.id}}" bindtap="onDelItem">删除</view>
        </view>
      </view>
      <view class="mqf-item-add" bindtap="onAddItem">
        <text class="text-primary fs-body">+ 添加项目</text>
      </view>
    </view>
    </view>
    <view class="mqf-section mqf-value-added-compact">
      <view class="mqf-value-added-compact-head">
        <text class="mqf-section-title fs-body fw-bold">增值服务</text>
        <view class="mqf-value-added-go-btn fs-body" bindtap="onOpenQuoteValueAdded">去选择</view>
      </view>
      <view class="mqf-va-chosen-wrap" wx:if="{{vaChosenLabels.length}}">
        <text class="mqf-va-chosen-chip fs-cap" wx:for="{{vaChosenLabels}}" wx:for-item="vlab" wx:for-index="vix" wx:key="vix">{{vlab}}</text>
      </view>
      <text wx:else class="text-muted fs-cap mqf-va-chosen-empty">尚未选择；点「去选择」勾选模板或补充说明</text>
    </view>
    <view class="mqf-summary-section">
      <view class="mqf-total-block">
        <text class="mqf-total-label fs-cap text-muted">总报价（元）*</text>
        <text class="mqf-total-sum-hint text-weak fs-cap">根据已填「损失部位」行的分项金额自动合计，与提交金额一致</text>
        <view class="mqf-total-input-wrap mqf-total-input-wrap--readonly">
          <text class="mqf-total-prefix">¥</text>
          <text class="mqf-total-input mqf-total-readonly">{{amount || '—'}}</text>
        </view>
      </view>
      <view class="mqf-extra-block">
        <view class="mqf-extra-item">
          <text class="mqf-extra-label text-muted fs-cap">预计工期*</text>
          <view class="mqf-extra-input-wrap">
            <input class="mqf-extra-input" type="number" placeholder="天数" value="{{duration}}" bindinput="onDurationInput"/>
            <text class="mqf-extra-unit">天</text>
          </view>
        </view>
      </view>
      <view class="quote-validity-row">
        <text class="quote-validity-label text-muted fs-cap">报价有效期</text>
        <view class="quote-validity-picker">{{quoteValidityOptions[0].label || '24 小时'}}</view>
      </view>
      <view class="quote-remark-row">
        <input class="quote-remark-input" placeholder="备注（选填）" value="{{remark}}" bindinput="onRemarkInput"/>
      </view>
      <view class="mqf-disassembly-section">
        <text class="mqf-section-title fs-body fw-bold">拆解检测费（预报价披露）*</text>
        <text class="mqf-disassembly-intro text-muted fs-cap">与维修总价分列展示，保障车主选厂知情权；到店后线下支付，平台不代收。</text>
        
        <view wx:if="{{!disassembly_fee_waived}}" class="mqf-disassembly-fee-row">
          <text class="mqf-extra-label text-muted fs-cap">金额（元）*</text>
          <input class="mqf-extra-input mqf-disassembly-fee-input" type="digit" placeholder="如 200" value="{{disassembly_fee}}" bindinput="onDisassemblyFeeInput"/>
        </view>  
        <view class="mqf-disassembly-waive-row">
          <switch checked="{{disassembly_fee_waived}}" bindchange="onDisassemblyWaivedChange"/>
          <text class="fs-cap text-muted">本店承诺本次到店拆解检测免费</text>
        </view>     
      </view>
      <view class="quote-submit-tip">
        <text class="quote-submit-tip-text">预报价仅供参考，不代表最终服务与价格。预报价越接近最终成交价，在平台推荐时排名越靠前。</text>
      </view>
    </view>
    <button class="btn-primary quote-submit-btn" disabled="{{submitting}}" bindtap="onSubmit">{{submitting ? '提交中...' : '提交报价'}}</button>
  </view>

  <!-- 已报价 -->
  <view class="bidding-quoted-card card" wx:if="{{bidding && bidding.my_quote}}">
    <view class="quoted-header">
      <text class="text-success fs-body fw-bold">您已提交报价</text>
      <text class="quoted-status-tag won" wx:if="{{bidding.status === 1 && bidding.my_quote.quote_status === 1}}">成交</text>
      <text class="quoted-status-tag invalid" wx:if="{{bidding.status === 1 && bidding.my_quote.quote_status === 2}}">已失效</text>
    </view>
    <view class="quoted-amount">
      <text class="fs-h2 fw-bold text-primary">¥{{bidding.my_quote.amount}}</text>
    </view>
    <view class="quoted-disassembly fs-cap text-muted" wx:if="{{bidding.my_quote.disassembly_fee_waived == 1}}">
      <text class="quoted-disassembly-title fw-medium">拆解检测费：本次免费</text>
    </view>
    <view class="quoted-disassembly fs-cap text-muted" wx:elif="{{bidding.my_quote.disassembly_fee != null && bidding.my_quote.disassembly_fee !== ''}}">
      <text class="quoted-disassembly-title fw-medium">拆解检测费 ¥{{bidding.my_quote.disassembly_fee_display}}</text>
    </view>
    <view class="quoted-items" wx:if="{{bidding.my_quote.items && bidding.my_quote.items.length}}">
      <view class="quoted-item-block" wx:for="{{bidding.my_quote.items}}" wx:key="index">
        <view class="quoted-item-line1 fs-body fw-bold">{{item.damage_part || item.name || item.item}}</view>
        <view class="quoted-item-line2 fs-cap text-muted">{{item.repair_type || '维修'}}{{item.repair_type === '换' && item.parts_type ? ' · ' + item.parts_type : ''}}{{item.price != null ? ' · ¥' + item.price : ''}}{{item.warranty_months != null ? ' · 质保' + item.warranty_months + '月' : ''}}</view>
      </view>
    </view>
    <view class="quoted-value-added" wx:if="{{myQuoteVaDisplay && myQuoteVaDisplay.show}}">
      <text class="quoted-value-added-title fs-cap fw-bold">增值服务</text>
      <view class="quoted-va-owner-wrap">
        <text class="quoted-va-owner-intro fs-body fw-bold">{{myQuoteVaDisplay.intro}}</text>
        <view class="quoted-va-owner-block" wx:for="{{myQuoteVaDisplay.blocks}}" wx:for-item="blk" wx:key="headline">
          <text class="quoted-va-owner-headline fs-body fw-medium">{{blk.headline}}</text>
          <text class="quoted-va-owner-line fs-cap text-muted" wx:for="{{blk.lines}}" wx:for-item="ln" wx:for-index="li" wx:key="li">· {{ln}}</text>
        </view>
        <view class="quoted-va-disclaimer">
          <text class="quoted-va-disclaimer-line text-weak fs-cap" wx:for="{{myQuoteVaDisplay.disclaimerLines}}" wx:for-item="dln" wx:for-index="di" wx:key="di">{{dln}}</text>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
</view>
