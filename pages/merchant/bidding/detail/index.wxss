/* 竞价详情与报价 - M05；报价明细表单与订单「修改报价单」共用 merchant-quote-form */
@import '/styles/design-system.wxss';
@import '/styles/merchant-quote-form.wxss';

.merchant-bidding-detail {
  padding: var(--page-padding-x);
  padding-bottom: var(--space-2xl);
}

/* 卡片通用 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  padding: var(--space-lg);
  margin-bottom: var(--space-lg);
}

.detail-card-badge {
  padding: 4rpx var(--space-sm);
  background: var(--accent-bg);
  color: var(--accent);
  border-radius: var(--radius-sm);
}

/* 车主定损依据（优先阅读） */
.merchant-owner-evidence {
  border: 2rpx solid var(--primary);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.merchant-evidence-head {
  margin-bottom: var(--space-lg);
  padding-bottom: var(--space-md);
  border-bottom: 1rpx solid var(--border-light);
}

.merchant-evidence-title {
  display: block;
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
}

.merchant-evidence-priority {
  display: block;
  color: var(--primary);
  font-weight: 500;
  line-height: 1.5;
}

.merchant-evidence-block-label {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.merchant-evidence-photos-block {
  margin-bottom: var(--space-lg);
}

.merchant-evidence-photos-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.merchant-evidence-photo-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--bg-placeholder);
  border: 1rpx solid var(--border);
}

.merchant-evidence-photo-thumb {
  width: 100%;
  height: 100%;
}

.merchant-evidence-empty-photos {
  margin-bottom: var(--space-lg);
  padding: var(--space-md);
  background: var(--bg-page);
  border-radius: var(--radius-sm);
}

.merchant-evidence-desc-block {
  margin-bottom: var(--space-lg);
}

.merchant-evidence-desc-body {
  padding: var(--space-md);
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  border-left: 6rpx solid var(--primary);
}

.merchant-evidence-desc-text {
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-word;
  line-height: 1.6;
}

.merchant-evidence-no-desc {
  margin-bottom: var(--space-lg);
}

.merchant-evidence-meta {
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border-light);
}

/* AI 分析报告（折叠） */
.merchant-ai-report-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-xs) 0;
}

.merchant-ai-report-head-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.merchant-ai-report-hint {
  line-height: 1.4;
}

.merchant-ai-report-head-right {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex-shrink: 0;
}

.merchant-ai-badge {
  flex-shrink: 0;
}

.merchant-ai-report-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.6;
  transition: transform 0.2s;
}

.merchant-ai-report-body {
  padding-top: var(--space-md);
  margin-top: var(--space-sm);
  border-top: 1rpx solid var(--border-light);
}

.merchant-ai-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-xs) 0;
  margin-bottom: var(--space-sm);
}

.merchant-ai-human-block {
  margin-bottom: var(--space-md);
}

.merchant-ai-human-title {
  display: block;
  margin-bottom: var(--space-xs);
  color: var(--text-primary);
}

.merchant-ai-line {
  padding: 6rpx 0;
  line-height: 1.5;
  color: var(--text-secondary);
}

.merchant-ai-disclaimer {
  margin-top: var(--space-lg);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border-light);
  line-height: 1.5;
}

/* 报价工具条（Excel / AI / 拍照） */
.merchant-quote-toolbar {
  margin-top: var(--space-md);
}

.merchant-quote-toolbar-row {
  margin-top: var(--space-sm);
}

.merchant-quote-toolbar-row--dual {
  display: flex;
  flex-direction: row;
  gap: var(--space-sm);
}

.merchant-quote-tool-btn {
  margin: 0;
  font-size: var(--fs-cap);
  line-height: 1.45;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
}

.merchant-quote-tool-btn--half {
  flex: 1;
  min-width: 0;
}

.merchant-quote-tool-btn--full {
  width: 100%;
}

.merchant-quote-tool-btn--outline {
  color: var(--primary);
  background: var(--accent-bg);
  border: 1rpx solid var(--primary);
}

.merchant-quote-tool-btn--ghost {
  color: var(--text-secondary);
  background: var(--bg-page);
  border: 1rpx solid var(--border);
}

.detail-vehicle-row,
.detail-insurance-row,
.detail-damages,
.detail-repair-suggestions {
  margin-bottom: var(--space-md);
}

.detail-insurance-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.detail-insurance-row .text-muted {
  flex-shrink: 0;
}

.detail-insurance-detail {
  margin-bottom: var(--space-md);
  padding: var(--space-sm);
  background: var(--bg-page);
  border-radius: var(--radius-sm);
}

.detail-insurance-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-xs) 0;
}

.detail-insurance-item .text-muted {
  flex-shrink: 0;
  width: 140rpx;
}

.detail-vehicle-row text {
  margin-right: var(--space-sm);
}

.detail-damage-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}

.detail-damage-tag {
  padding: var(--space-xs) var(--space-sm);
  background: var(--bg-placeholder);
  border-radius: var(--radius-sm);
  font-size: var(--fs-sm);
  color: var(--text-secondary);
}

.detail-suggestion-list {
  margin-top: var(--space-xs);
}

.detail-suggestion-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--border-light);
  font-size: var(--fs-sm);
}

.detail-suggestion-item:last-child {
  border-bottom: none;
}

/* 报价明细卡片 */
.bidding-quote-card .quote-card-header {
  margin-bottom: var(--space-lg);
  padding-bottom: var(--space-lg);
  border-bottom: 1rpx solid var(--border-light);
}

.bidding-quote-card .quote-card-hint {
  display: block;
  margin-top: var(--space-xs);
}

/* quote-ai-*、quote-import-* 见 merchant-quote-form.wxss */

.quoted-value-added {
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border-light);
}
.quoted-value-added-title {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--text-secondary);
}
.quoted-value-added-item {
  padding: var(--space-xs) 0;
}

.quote-remark-row {
  margin-bottom: var(--space-md);
}

.quote-validity-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
}

.quote-validity-label {
  flex-shrink: 0;
  width: 140rpx;
}

.quote-validity-picker {
  flex: 1;
  padding: var(--space-sm) var(--space-md);
  font-size: var(--fs-body);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-page);
  color: var(--text-primary);
}

.quote-remark-input {
  width: 100%;
  padding: var(--space-md) var(--space-lg);
  font-size: var(--fs-body);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  background: var(--bg-page);
}

.quote-submit-tip {
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-lg);
  background: var(--primary-bg);
  border-left: 6rpx solid var(--primary);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}

.quote-submit-tip-text {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

.quote-submit-btn {
  width: 100%;
  padding: var(--space-lg);
  font-size: var(--fs-body);
  font-weight: 500;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: 0 0;
}

/* 已报价展示 */
.bidding-quoted-card .quoted-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.quoted-status-tag.won {
  color: var(--success);
  font-size: var(--fs-sm);
  font-weight: 500;
  padding: 4rpx var(--space-sm);
  background: var(--accent-bg);
  border-radius: var(--radius-sm);
}

.quoted-status-tag.invalid {
  color: var(--text-secondary);
  font-size: var(--fs-sm);
  padding: 4rpx var(--space-sm);
  background: var(--bg-placeholder);
  border-radius: var(--radius-sm);
}

.bidding-quoted-card .quoted-amount {
  margin-bottom: var(--space-lg);
}

.quoted-items {
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
}

.quoted-item-block {
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.quoted-item-block:last-child {
  border-bottom: none;
}

.quoted-item-line1 {
  font-weight: 600;
  margin-bottom: var(--space-xs);
}

.quoted-item-line2 {
  margin-bottom: 0;
}

.fw-bold { font-weight: 600; }
.fw-medium { font-weight: 500; }
