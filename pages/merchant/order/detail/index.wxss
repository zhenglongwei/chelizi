/* 服务商订单详情 - M07，以《设计规范.md》、design-system 为准 */
.merchant-order-detail {
  padding: var(--space-lg) var(--page-padding-x);
  padding-bottom: 200rpx; /* 底部固定操作区占位 */
}

/* 环节分区：概览 / 车况与约定 / 维修过程（关键节点 + 完工） */
.merchant-phase-card.merchant-phase-rail {
  border-left: 6rpx solid var(--primary);
}

.merchant-phase-header {
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-sm);
  border-bottom: 1rpx solid var(--border-light);
}

.merchant-phase-kicker {
  font-size: var(--fs-sm);
  color: var(--text-hint);
  font-weight: 500;
  letter-spacing: 0.06em;
}

/* 环节标题下紧跟的第一个小节标题，避免与 kicker 区双重留白 */
.merchant-phase-card .merchant-phase-header + .section-head .section-title,
.merchant-phase-card .merchant-flow-hint + .section-head .section-title {
  margin-top: var(--space-xs);
}

.merchant-flow-hint {
  display: block;
  margin-bottom: var(--space-md);
  line-height: 1.55;
}

.merchant-phase-progress-hint {
  margin-bottom: var(--space-sm);
}

.merchant-owner-photo-hint {
  display: block;
  line-height: 1.5;
  margin-bottom: var(--space-sm);
}

.merchant-owner-photo-empty {
  display: block;
  margin-bottom: var(--space-lg);
}

.merchant-owner-photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
}

.merchant-owner-photo-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-placeholder);
}

.merchant-context-subcard {
  margin-top: var(--space-lg);
  padding: var(--space-lg);
  background: var(--bg-placeholder);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
}

.merchant-context-subcard--owner {
  background: var(--primary-bg);
  border-color: rgba(37, 99, 235, 0.2);
}

.merchant-subcard-kicker {
  font-size: var(--fs-cap);
  color: var(--text-hint);
  font-weight: 600;
  letter-spacing: 0.05em;
  margin-bottom: var(--space-md);
}

.merchant-quote-summary {
  margin-bottom: var(--space-xs);
}

.merchant-repair-items--inset {
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border-light);
}

.merchant-subcard-empty {
  display: block;
  margin-top: var(--space-xs);
}

.value-added-list--inset .value-added-item {
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.value-added-list--inset .value-added-item:last-child {
  border-bottom: none;
}

.merchant-phase-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
  margin-top: var(--space-lg);
}

.merchant-phase-btn {
  flex: 1;
  min-width: 240rpx;
  margin: 0;
}

.material-audit-block-text {
  display: block;
  margin-top: var(--space-sm);
}

.evidence-hint-block {
  display: block;
  margin-bottom: var(--space-sm);
}

.evidence-footnote {
  display: block;
  margin-top: var(--space-sm);
}

.evidence-footnote--tight {
  margin-top: var(--space-xs);
}

.merchant-leadtech-row {
  margin-bottom: var(--space-md);
}

.parts-verify-skip-row {
  margin-top: var(--space-md);
}

.parts-verify-other-input {
  margin-top: var(--space-sm);
}

.warranty-desc {
  display: block;
  line-height: 1.55;
  margin-top: var(--space-xs);
}

.detail-section {
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
}

.section-title {
  font-size: var(--fs-body);
  margin-bottom: var(--space-xs);
  margin-top: var(--space-lg);
  font-weight: 500;
}

.section-head:first-child .section-title,
.section-title:first-child {
  margin-top: 0;
}
.section-head-with-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.section-head-with-action .section-more {
  flex-shrink: 0;
  font-size: var(--fs-cap);
  color: var(--primary);
}
.section-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
  justify-content: flex-end;
  align-items: center;
}

.status-text {
  display: inline-block;
  padding: var(--space-xs) var(--space-md);
  font-size: var(--fs-cap);
  font-weight: 500;
  color: var(--primary);
  background: var(--primary-bg);
  border-radius: var(--radius-md);
}

/* 材料转人工审核 */
.material-audit-manual {
  background: rgba(59, 130, 246, 0.06);
  border-left: 6rpx solid var(--primary);
  padding-left: var(--space-md);
}

/* 审核未通过提示：从订阅消息进入时避免误解为提交失败 */
.material-audit-rejected .reject-banner {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}
.material-audit-rejected .reject-title {
  color: var(--danger);
}
.material-audit-rejected .reject-desc {
  color: var(--text-secondary);
}
.material-audit-rejected .reject-reason {
  padding: var(--space-md);
  background: rgba(239, 68, 68, 0.08);
  border-radius: var(--radius-md);
  color: var(--text-primary);
}

.link {
  color: var(--primary);
  margin-left: var(--space-sm);
}

.action-btns {
  margin-top: var(--space-lg);
}
.action-btns-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
}
.action-btns-fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  margin-top: 0;
  padding: var(--space-lg) var(--page-padding-x);
  background: var(--bg-card);
  box-shadow: var(--shadow-top);
}

.evidence-upload {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.evidence-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.evidence-label {
  color: var(--text-secondary);
}

.evidence-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.evidence-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
  background: var(--bg-placeholder);
}

.evidence-thumb image {
  width: 100%;
  height: 100%;
}

.evidence-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: var(--overlay-dark);
  color: var(--bg-card);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.evidence-add {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-sm);
  background: var(--accent-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-hint);
}

.cancel-reason {
  margin-top: var(--space-xs);
}

/* 工期计时器 */
.duration-timer-wrap {
  margin-bottom: var(--space-sm);
}
.duration-timer {
  padding: var(--space-md);
  background: var(--bg-placeholder);
  border-radius: var(--radius-sm);
  margin-top: var(--space-xs);
}
.duration-timer.expired .duration-timer-main {
  opacity: 0.7;
}
.duration-timer-main {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  align-items: center;
}
.duration-days {
  font-size: var(--fs-body);
  font-weight: 500;
  color: var(--primary);
}
.duration-deadline {
  font-size: var(--fs-cap);
  color: var(--text-secondary);
}
.duration-countdown {
  margin-top: var(--space-sm);
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--border);
}
.duration-countdown.expired .countdown-value {
  color: var(--danger);
}
.countdown-label {
  font-size: var(--fs-cap);
  color: var(--text-secondary);
  margin-right: var(--space-xs);
}
.countdown-value {
  font-size: var(--fs-body);
  font-weight: 600;
  color: var(--primary);
}

/* 损伤情况、维修建议、增值服务 */
.damage-summary,
.damage-list,
.repair-items,
.value-added-list {
  margin-top: var(--space-xs);
}
.damage-item {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--border);
}
.repair-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--border);
}
.damage-item:last-child,
.repair-item:last-child {
  border-bottom: none;
}
.damage-item-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: var(--space-sm);
  flex: 1;
  min-width: 0;
}
.damage-item-row text:first-child {
  flex-shrink: 0;
}
.damage-item-row text:last-child {
  flex: 1;
  min-width: 0;
  text-align: right;
}
.damage-sub {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-xs) 0 var(--space-xs) var(--space-md);
}
.value-added-item {
  padding: var(--space-xs) 0;
  color: var(--text-secondary);
}
.quote-info {
  line-height: 1.5;
}

.parts-verify-chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}
.parts-verify-chip {
  padding: var(--space-xs) var(--space-md);
  font-size: var(--fs-cap);
  color: var(--text-secondary);
  background: var(--bg-page);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
}
.parts-verify-chip.on {
  color: var(--primary);
  border-color: var(--primary);
  background: var(--primary-bg);
}

/* 增值服务：与车主订单详情 order-va-owner-* 一致（结构化 + 免责） */
.order-va-owner-wrap--inset {
  margin-top: 0;
}
.order-va-owner-wrap {
  margin-top: var(--space-xs);
}
.order-va-owner-intro {
  display: block;
  margin-bottom: var(--space-md);
  color: var(--text-primary);
}
.order-va-owner-block {
  margin-bottom: var(--space-lg);
}
.order-va-owner-headline {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--primary);
}
.order-va-owner-line {
  display: block;
  line-height: 1.55;
  margin-bottom: 6rpx;
  padding-left: 4rpx;
}
.order-va-disclaimer {
  margin-top: var(--space-lg);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border-light);
}
.order-va-disclaimer-line {
  display: block;
  line-height: 1.5;
  margin-bottom: 6rpx;
}
