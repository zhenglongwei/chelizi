/* 修改维修方案 / 修改报价单 - M07；表单与 M05 共用 merchant-quote-form，车主定损+AI+工具条样式与 M05 对齐 */
@import '/styles/merchant-quote-form.wxss';
@import '/pages/merchant/bidding/detail/index.wxss';

.repair-plan-edit {
  padding: var(--space-lg) var(--page-padding-x);
  padding-bottom: 160rpx;
}

.edit-tip {
  margin-bottom: var(--space-md);
  padding: var(--space-md);
}
.edit-tip.insurance-risk {
  background: rgba(245, 158, 11, 0.08);
  border-left: 6rpx solid var(--warning, #f59e0b);
}
.edit-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: var(--space-md);
  font-size: var(--fs-body);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}
.edit-scroll {
  width: 100%;
}
.edit-card {
  padding: var(--space-xl);
}
.edit-section {
  margin-bottom: var(--space-xl);
}
.edit-section-title {
  display: block;
  margin-bottom: var(--space-md);
}
.edit-bottom-pad {
  height: var(--space-2xl);
}
.edit-submit-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-lg) var(--page-padding-x);
  background: var(--bg-card);
  box-shadow: var(--shadow-top);
}
.edit-submit {
  width: 100%;
}

/* 证明材料（与设计变量一致） */
.rp-evidence-hint {
  display: block;
  margin-bottom: var(--space-sm);
}
.rp-evidence-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
  margin-top: var(--space-md);
}
.rp-evidence-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
  background: var(--bg-placeholder);
}
.rp-evidence-img {
  width: 100%;
  height: 100%;
}
.rp-loss-note-title {
  display: block;
  margin-top: var(--space-lg);
  margin-bottom: var(--space-md);
}
.evidence-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: var(--overlay-dark);
  color: var(--bg-card);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.evidence-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-sm);
  background: var(--accent-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-hint);
  box-sizing: border-box;
}
