/* 服务商工作台 - M03，按《设计规范.md》 */
.merchant-home {
  padding: var(--space-lg) var(--page-padding-x);
  padding-bottom: var(--space-2xl);
}

.merchant-home-section {
  margin-bottom: var(--space-2xl);
}

.merchant-home-section-last {
  margin-bottom: 0;
}

/* 资质未完善提示条：醒目、可点击 */
.merchant-qualification-alert {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-lg);
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.12) 0%, rgba(234, 179, 8, 0.08) 100%);
  border-left: 6rpx solid var(--warning);
}

.qualification-alert-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-full);
  background: var(--warning);
  color: var(--bg-card);
  font-size: var(--fs-body);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.qualification-alert-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.qualification-alert-title {
  color: var(--text-primary);
}

.qualification-alert-desc {
  color: var(--text-secondary);
}

.qualification-alert-arrow {
  font-size: var(--fs-cap);
  color: var(--primary);
  font-weight: 500;
  flex-shrink: 0;
}

/* 资质驳回：红色强调 */
.merchant-qualification-rejected {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(220, 38, 38, 0.06) 100%);
  border-left-color: var(--danger);
}

.merchant-qualification-rejected .qualification-alert-icon {
  background: var(--danger);
}

/* 店铺身份条 */
.merchant-identity-bar {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-lg) var(--space-xl);
}

.merchant-identity-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-identity-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.merchant-identity-name {
  max-width: 100%;
}

.merchant-identity-wallet,
.merchant-identity-hint {
  display: block;
  line-height: 1.45;
}

.merchant-identity-arrow {
  flex-shrink: 0;
  font-weight: 500;
}

/* 店铺综合得分（首页精简） */
.merchant-score-compact {
  padding: var(--space-lg) var(--space-xl);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  border-left: 6rpx solid var(--border);
}

.merchant-score-compact-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
}

.merchant-score-compact-main {
  display: flex;
  align-items: baseline;
  gap: var(--space-xs);
}

.merchant-score-compact-num {
  line-height: 1.1;
}

.merchant-score-compact-suffix {
  color: var(--text-secondary);
  line-height: 1.2;
}

.merchant-score-compact-chevron {
  flex-shrink: 0;
  font-weight: 500;
}

.merchant-score-compact-stars {
  color: var(--accent);
  letter-spacing: 2rpx;
}

.merchant-score-compact-tip {
  line-height: 1.5;
  color: var(--text-secondary);
}

.merchant-score-tier-high {
  border-left-color: var(--success);
}

.merchant-score-tier-high .merchant-score-compact-num {
  color: var(--success);
}

.merchant-score-tier-high .merchant-score-compact-tip {
  color: var(--text-secondary);
}

.merchant-score-tier-mid {
  border-left-color: var(--warning);
}

.merchant-score-tier-mid .merchant-score-compact-num {
  color: var(--warning);
}

.merchant-score-tier-low {
  border-left-color: var(--danger);
}

.merchant-score-tier-low .merchant-score-compact-num {
  color: var(--danger);
}

/* 得分详情页分项着色 */
.merchant-score-val-pos {
  color: var(--success);
}

.merchant-score-val-neg {
  color: var(--danger);
}

.merchant-score-val-zero {
  color: var(--text-secondary);
}

/* 店铺名旁状态标签 */
.merchant-qual-badge {
  padding: 4rpx var(--space-sm);
  border-radius: var(--radius-sm);
  font-size: var(--fs-sm);
  font-weight: 500;
  flex-shrink: 0;
}

.merchant-qual-badge-pending {
  background: rgba(245, 158, 11, 0.15);
  color: var(--warning);
}

.merchant-qual-badge-rejected {
  background: rgba(239, 68, 68, 0.15);
  color: var(--danger);
}

.merchant-qual-badge-approved {
  background: rgba(34, 197, 94, 0.15);
  color: var(--success);
}

.merchant-section-title {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--text-primary);
}

.merchant-section-sub {
  display: block;
  margin-bottom: var(--space-md);
  line-height: 1.5;
}

.merchant-stats {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
}

.merchant-stat-card {
  flex: 1;
  min-width: 140rpx;
  padding: var(--space-xl);
  text-align: center;
}

.merchant-stat-card .stat-num {
  color: var(--primary);
}

.stat-num {
  display: block;
  font-size: var(--fs-h2);
  font-weight: 600;
}

.stat-label {
  color: var(--text-secondary);
}

.merchant-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.merchant-action {
  display: flex;
  align-items: center;
  gap: var(--space-xl);
  padding: var(--space-xl);
}

.merchant-action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-bg);
}

.merchant-action-icon .action-img {
  width: 48rpx;
  height: 48rpx;
}

.merchant-action-icon-wrap {
  position: relative;
}

.merchant-action-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: var(--radius-full);
  background: var(--danger);
  color: var(--bg-card);
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.merchant-action-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.merchant-action-arrow {
  font-size: var(--fs-h2);
  color: var(--text-hint);
}
