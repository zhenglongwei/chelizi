<custom-nav-bar title="商品订单" showBack="{{true}}" />
<view class="page-root mpo-page" style="{{pageRootStyle}}">
  <view class="text-muted fs-body mpo-loading" wx:if="{{loading}}">加载中...</view>
  <view class="text-muted fs-body mpo-empty" wx:elif="{{!list.length}}">暂无车主商品订单</view>
  <scroll-view wx:else class="mpo-scroll" scroll-y style="{{scrollStyle}}">
    <view class="mpo-card card" wx:for="{{list}}" wx:key="product_order_id">
      <view class="mpo-row">
        <text class="fs-body fw-bold">{{item.product_name}}</text>
        <text class="mpo-status fs-cap {{item.paid ? 'mpo-paid' : ''}}">{{item.statusLabel}}</text>
      </view>
      <text class="text-muted fs-cap" wx:if="{{item.user_nickname}}">买家 {{item.user_nickname}}</text>
      <view class="mpo-row mpo-meta">
        <text class="text-muted fs-cap">×{{item.quantity}}</text>
        <text class="fs-body fw-bold text-primary">¥{{item.amountText}}</text>
      </view>
      <text class="text-weak fs-sm">{{item.createdText}}</text>
    </view>
  </scroll-view>
</view>
