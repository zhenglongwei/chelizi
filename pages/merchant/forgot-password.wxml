<!-- 服务商找回密码 -->
<custom-nav-bar title="找回密码" showBack="{{true}}" />
<view class="page-root merchant-login-page" style="{{pageRootStyle}}">
  <view class="merchant-login-content">
    <view class="merchant-login-form card">
      <text class="text-muted fs-cap merchant-forgot-desc">请使用与服务商账号已绑定的微信，在本页完成重置。若从未绑定微信，请先使用原密码登录一次。</text>
      <view class="merchant-form-item">
        <text class="merchant-form-label fs-body">手机号</text>
        <input class="merchant-form-input" type="number" placeholder="注册手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11"/>
      </view>
      <view class="merchant-form-item">
        <text class="merchant-form-label fs-body">新密码</text>
        <input class="merchant-form-input" type="password" placeholder="至少 6 位" value="{{newPassword}}" bindinput="onNewPasswordInput"/>
      </view>
      <view class="merchant-form-item">
        <text class="merchant-form-label fs-body">确认新密码</text>
        <input class="merchant-form-input" type="password" placeholder="再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput"/>
      </view>
      <button class="btn-primary merchant-login-btn" disabled="{{loading}}" bindtap="onSubmit">
        {{loading ? '提交中...' : '确认重置'}}
      </button>
    </view>
  </view>
</view>
