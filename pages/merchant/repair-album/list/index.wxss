.page-root { padding-left: 24rpx; padding-right: 24rpx; padding-bottom: 48rpx; }
.toolbar { margin-bottom: 24rpx; }
.btn-primary { background: var(--color-primary, #EAB308); color: #111; font-size: 28rpx; padding: 16rpx 32rpx; border-radius: 12rpx; }
.hint { color: #64748b; font-size: 26rpx; line-height: 1.6; }
.list { display: flex; flex-direction: column; gap: 20rpx; }
.card.item { background: #fff; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.title { font-weight: 600; font-size: 30rpx; display: block; }
.meta { font-size: 24rpx; color: #64748b; display: block; margin-top: 8rpx; }
