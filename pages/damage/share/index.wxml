<!-- AI分析报告分享摘要页（公共，无需登录） -->
<custom-nav-bar title="损失报告（AI）摘要" showBack="{{true}}" />
<view class="page-root share-page" style="{{pageRootStyle}}">
  <block wx:if="{{loading}}">
    <view class="share-loading">
      <text class="text-muted fs-body">加载中...</text>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="share-error card">
      <text class="text-muted fs-body">{{error}}</text>
      <navigator class="share-link" url="/pages/index/index">回到首页</navigator>
    </view>
  </block>
  <block wx:elif="{{report}}">
    <scroll-view class="share-scroll" scroll-y style="{{scrollStyle}}">
      <view class="share-card card">
        <view class="share-title fs-h3 fw-bold">损失报告（AI）摘要</view>
        <view class="share-subtitle text-muted fs-sm">这是损失报告（AI）摘要，不含维修商实时报价。</view>
        <accident-report-view vm="{{reportVm}}" />
      </view>

      <view class="share-actions">
        <navigator class="share-btn btn-primary" url="/pages/damage/upload/index">
          <text class="fs-body fw-bold">获取维修商报价</text>
        </navigator>
        <button class="share-btn share-btn-secondary" open-type="share">
          <text class="fs-body fw-bold">转发给朋友</text>
        </button>
      </view>

      <view class="share-bottom-pad"></view>
    </scroll-view>
  </block>
</view>

