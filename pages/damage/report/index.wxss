/* 定损报告详情页 */
.report-page { min-height: 100vh; background: var(--bg-page); }
.report-loading, .report-error { padding: var(--space-2xl); text-align: center; }
.report-error { display: flex; flex-direction: column; align-items: center; gap: var(--space-lg); margin: var(--space-2xl) var(--page-padding-x); padding: var(--space-2xl); }
.report-link { color: var(--primary); font-size: var(--fs-body); }
.report-scroll { padding: var(--space-lg) var(--page-padding-x); }
.report-card { margin-bottom: var(--space-lg); padding: var(--space-xl); }
.report-title { margin-bottom: var(--space-lg); }
.report-subtitle { margin-top: calc(var(--space-md) * -1); margin-bottom: var(--space-md); }
.report-row { display: flex; justify-content: space-between; padding: var(--space-md) 0; border-bottom: 1rpx solid var(--border); }
.report-label { color: var(--text-secondary); }
.report-value { color: var(--text-primary); font-weight: 500; }
.report-damages, .report-repair { margin-top: var(--space-lg); }
.report-human-section { margin-top: var(--space-md); }
.report-human-title { margin-bottom: var(--space-xs); }
.report-damage-item, .report-repair-item { margin-top: var(--space-sm); color: var(--text-secondary); }
.report-disclaimer {
  margin-top: var(--space-lg);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
  line-height: 1.5;
}
.report-actions { margin-top: var(--space-lg); display: flex; flex-direction: row; gap: var(--space-md); }
.report-btn { flex: 1; height: 88rpx; line-height: 88rpx; text-align: center; border-radius: var(--radius-md); margin: 0; }
.report-btn-secondary { background: transparent; color: var(--text-primary); border: 2rpx solid var(--border); }
.report-bottom-pad { height: var(--space-2xl); }
