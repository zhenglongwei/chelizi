<!-- AI分析报告详情（从历史进入） -->
<custom-nav-bar title="AI分析报告" showBack="{{true}}" />
<view class="page-root report-page" style="{{pageRootStyle}}">
  <block wx:if="{{loading}}">
    <view class="report-loading">
      <text class="text-muted fs-body">加载中...</text>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="report-error card">
      <text class="text-muted fs-body">{{error}}</text>
      <navigator class="report-link" url="/pages/damage/history/index">返回历史</navigator>
    </view>
  </block>
  <block wx:elif="{{report}}">
    <scroll-view class="report-scroll" scroll-y style="{{scrollStyle}}">
      <view class="report-card card">
        <view class="report-title fs-h3 fw-bold">AI分析报告</view>
        <view class="report-subtitle text-muted fs-sm">以下为AI基于照片的分析结果，不代表维修商最终报价。</view>
        <view class="notice-info" style="margin-top: var(--space-lg); margin-bottom: 0;">
          <view class="notice-info__icon">i</view>
          <view class="notice-info__body">报告仅供决策参考；涉及维修范围、配件品质与价格以到店检测及书面报价为准。</view>
        </view>
        <view class="notice-info" style="margin-top: var(--space-md);" wx:if="{{report && report.status === 0}}">
          <view class="notice-info__icon">i</view>
          <view class="notice-info__body">报告正在生成中，你可以稍后再来查看；也可在本页等待自动刷新。</view>
        </view>
      </view>

      <!-- 多车：Tab 切换 -->
      <view class="report-card card" wx:if="{{vehiclesTabs && vehiclesTabs.length > 1}}">
        <view class="report-tabs">
          <view
            class="report-tab {{selectedVehicleId === item.vehicleId ? 'selected' : ''}}"
            wx:for="{{vehiclesTabs}}"
            wx:key="vehicleId"
            data-id="{{item.vehicleId}}"
            bindtap="onVehicleTabTap"
          >
            <text class="fs-body fw-bold">{{item.title}}</text>
            <text class="text-muted fs-sm" wx:if="{{item.subtitle}}">{{item.subtitle}}</text>
          </view>
        </view>
      </view>

      <view class="report-card card">
        <view class="fs-body fw-bold report-section-title">损失与维修</view>
        <accident-report-view vm="{{reportVm}}" />
      </view>

      <view class="report-card card" wx:if="{{communicationScript}}">
        <view class="report-comm-header">
          <view class="fs-body fw-bold report-section-title">到店沟通话术</view>
          <view class="report-comm-copy text-primary fs-sm" bindtap="onCopyCommunication">复制</view>
        </view>
        <view class="report-comm-body fs-body text-primary">{{communicationScript}}</view>
        <view class="report-fixed-hint text-muted fs-sm">仅供参考，最终仍应该以服务商的意见为准。</view>
      </view>

      <view class="report-card card" wx:if="{{arrivalNotes && arrivalNotes.length}}">
        <view class="fs-body fw-bold report-section-title">到店注意事项</view>
        <view class="report-note-item" wx:for="{{arrivalNotes}}" wx:key="*this">
          <text class="fs-body">· {{item}}</text>
        </view>
        <view class="report-fixed-hint text-muted fs-sm">仅供参考，最终仍应该以服务商的意见为准。</view>
      </view>
      <view class="report-actions">
        <button class="report-btn btn-brand" bindtap="onGoBidding">
          <text class="fs-body fw-bold">获取维修商报价</text>
        </button>
        <button class="report-btn report-btn-secondary" open-type="share" bindtap="onPrepareShare" wx:if="{{!caps || (caps.map && caps.map['damage.report_share'])}}">
          <text class="fs-body fw-bold">分享报告</text>
        </button>
      </view>
      <view class="report-bottom-pad"></view>
    </scroll-view>
  </block>
</view>
