<!-- 定损报告详情（从历史进入） -->
<custom-nav-bar title="定损报告" showBack="{{true}}" />
<view class="page-root report-page" style="{{pageRootStyle}}">
  <block wx:if="{{loading}}">
    <view class="report-loading">
      <text class="text-muted fs-body">加载中...</text>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="report-error card">
      <text class="text-muted fs-body">{{error}}</text>
      <navigator class="report-link" url="/pages/damage/history/index">返回历史</navigator>
    </view>
  </block>
  <block wx:elif="{{report}}">
    <scroll-view class="report-scroll" scroll-y style="{{scrollStyle}}">
      <view class="report-card card">
        <view class="report-title fs-h3 fw-bold">定损报告</view>
        <view class="report-row" wx:if="{{report.total_estimate && report.total_estimate.length >= 2}}">
          <text class="report-label">预估费用</text>
          <text class="report-value">{{report.total_estimate[0]}}-{{report.total_estimate[1]}} 元</text>
        </view>
        <view class="report-damages">
          <view class="report-human-section">
            <view class="fs-body fw-bold report-human-title">明显损伤</view>
            <block wx:if="{{report.human_display.obvious_damage && report.human_display.obvious_damage.length}}">
              <view class="report-damage-item" wx:for="{{report.human_display.obvious_damage}}" wx:key="index">
                <text class="fs-body">· {{item}}</text>
              </view>
            </block>
            <text class="text-muted fs-body" wx:else>暂无明显可见损伤</text>
          </view>
          <view class="report-human-section">
            <view class="fs-body fw-bold report-human-title">可能损伤</view>
            <block wx:if="{{report.human_display.possible_damage && report.human_display.possible_damage.length}}">
              <view class="report-damage-item" wx:for="{{report.human_display.possible_damage}}" wx:key="index">
                <text class="fs-body">· {{item}}</text>
              </view>
            </block>
            <text class="text-muted fs-body" wx:else>暂无待进一步确认项</text>
          </view>
          <view class="report-human-section">
            <view class="fs-body fw-bold report-human-title">维修建议</view>
            <block wx:if="{{report.human_display.repair_advice && report.human_display.repair_advice.length}}">
              <view class="report-damage-item" wx:for="{{report.human_display.repair_advice}}" wx:key="index">
                <text class="fs-body">· {{item}}</text>
              </view>
            </block>
            <text class="text-muted fs-body" wx:else>暂无专项建议</text>
          </view>
          <view class="report-disclaimer text-muted fs-sm">本分析结果仅供参考，具体请以实车检测与正规维修厂意见为准。</view>
        </view>
      </view>
      <view class="report-actions">
        <navigator class="report-btn btn-primary" url="/pages/damage/upload/index?id={{reportId}}">
          <text class="fs-body fw-bold">发起竞价</text>
        </navigator>
      </view>
      <view class="report-bottom-pad"></view>
    </scroll-view>
  </block>
</view>
