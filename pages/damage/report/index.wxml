<!-- AI分析报告详情（从历史进入） -->
<custom-nav-bar title="AI分析报告" showBack="{{true}}" />
<view class="page-root report-page" style="{{pageRootStyle}}">
  <block wx:if="{{loading}}">
    <view class="report-loading">
      <text class="text-muted fs-body">加载中...</text>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="report-error card">
      <text class="text-muted fs-body">{{error}}</text>
      <navigator class="report-link" url="/pages/damage/history/index">返回历史</navigator>
    </view>
  </block>
  <block wx:elif="{{report}}">
    <scroll-view class="report-scroll" scroll-y style="{{scrollStyle}}">
      <view class="report-card card">
        <view class="report-title fs-h3 fw-bold">AI分析报告</view>
        <view class="report-subtitle text-muted fs-sm">以下为AI基于照片的分析结果，不代表维修商最终报价。</view>
        <accident-report-view vm="{{reportVm}}" />
      </view>
      <view class="report-actions">
        <button class="report-btn btn-primary" bindtap="onGoBidding">
          <text class="fs-body fw-bold">获取维修商报价</text>
        </button>
        <button class="report-btn report-btn-secondary" plain bindtap="onRecreatePrequote">
          <text class="fs-body fw-bold">重新预报价</text>
        </button>
        <button class="report-btn report-btn-secondary" open-type="share" bindtap="onPrepareShare" wx:if="{{!caps || (caps.map && caps.map['damage.report_share'])}}">
          <text class="fs-body fw-bold">分享报告</text>
        </button>
      </view>
      <view class="report-bottom-pad"></view>
    </scroll-view>
  </block>
</view>
