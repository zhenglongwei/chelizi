<!-- 预报价页（原 AI定损） - 02-AI定损页 -->
<view class="page-root damage-page">
  <block wx:if="{{!hasToken}}">
    <view class="damage-empty card">
      <text class="text-muted fs-body">请先登录后再使用预报价</text>
      <navigator class="damage-login-link" url="/pages/auth/login/index?redirect=%2Fpages%2Fdamage%2Fupload%2Findex">去登录</navigator>
    </view>
  </block>
  <block wx:elif="{{step === 1}}">
    <scroll-view class="damage-scroll" scroll-y show-scrollbar="{{false}}">
      <view class="damage-hero">
        <view class="damage-hero-title fs-h3 fw-bold">发起人工预报价</view>
        <view class="damage-hero-sub text-muted fs-sm">服务商会根据你提供的照片与描述给出人工预报价。到店进行现场评估（必要时拆检）后，才能确定最终价格。</view>
      </view>

      <view class="damage-chips" wx:if="{{!analyzing}}">
        <view class="damage-chip" data-text="低速追尾，前保险杠凹陷变形" bindtap="onPromptChip">追尾 · 前杠</view>
        <view class="damage-chip" data-text="右前门刮蹭+轻微变形，需要钣金喷漆" bindtap="onPromptChip">刮蹭 · 钣喷</view>
        <view class="damage-chip" data-text="故障灯亮，怠速抖动明显；有 P0300 故障码" bindtap="onPromptChip">故障码 · 抖动</view>
      </view>

      <view class="notice-info" style="margin-left: var(--page-padding-x); margin-right: var(--page-padding-x);">
        <view class="notice-info__icon">i</view>
        <view class="notice-info__body">
          <text class="fw-medium text-primary">提示</text>：本次为服务商根据材料做的人工预报价，可能会因实际车况、配件价格、工艺方案变化而调整；到店现场评估（必要时拆检）后才是最终价。请勿在描述中填写身份证号、银行卡号等敏感信息。
        </view>
      </view>

      <!-- 主要输入区（对齐 AI 分析页） -->
      <view class="damage-composer card">
        <view class="damage-section-title fs-body fw-bold">照片与补充描述</view>
        <textarea
          class="damage-composer-input"
          placeholder="把情况简单说一下（可选）：例如 低速追尾前杠凹陷；或 故障灯亮+怠速抖动；或 P0300…"
          value="{{userDescription}}"
          bindinput="onDescInput"
          maxlength="-1"
          auto-height
          show-confirm-bar="{{false}}"
        />
        <view class="damage-composer-toolbar">
          <view class="damage-tool-plus" bindtap="onChooseImage">
            <text class="damage-tool-plus-icon">+</text>
          </view>
          <text class="damage-tool-hint text-muted fs-cap">上传事故照片（必填），最多 8 张（{{images.length}}/8）</text>
        </view>
        <view class="damage-thumb-strip" wx:if="{{images && images.length}}">
          <view class="damage-upload-item damage-upload-item--sm" wx:for="{{images}}" wx:key="index">
            <image class="damage-thumb" src="{{item}}" mode="aspectFill"/>
            <view class="damage-del" data-index="{{index}}" bindtap="onDelImage">
              <text class="damage-del-x">×</text>
            </view>
          </view>
        </view>
        <text class="damage-upload-hint text-weak fs-sm">至少 1 张，单张不超过 5MB；建议：45°全景 + 损伤特写（可加内饰/故障灯/仪表盘）</text>
      </view>

      <!-- 车辆信息（提交前预填，用于锁定车辆；避免多车选择） -->
      <view class="damage-section card">
        <view class="damage-section-title fs-body fw-bold">车辆信息</view>
        <view class="damage-field-row-inline">
          <text class="damage-label-inline fs-body">车牌号<text class="text-error">*</text></text>
          <input class="damage-input-inline" placeholder="如：京A12345（必填）" value="{{vehicleInfo.plate_number}}" bindinput="onPlateInput"/>
        </view>
        <view class="damage-field-row-inline">
          <text class="damage-label-inline fs-body">品牌</text>
          <input class="damage-input-inline" placeholder="如：宝马（可选）" value="{{vehicleInfo.brand}}" bindinput="onBrandInput"/>
        </view>
        <view class="damage-field-row-inline">
          <text class="damage-label-inline fs-body">车型</text>
          <input class="damage-input-inline" placeholder="如：3系、Model Y（可选）" value="{{vehicleInfo.model}}" bindinput="onModelInput"/>
        </view>
      </view>

      <view class="damage-section card">
        <view class="damage-section-title fs-body fw-bold">维修费用渠道<text class="text-error">*</text></view>
        <text class="text-muted fs-sm" style="display:block;margin-bottom:12rpx;">请选择自费或走保险（必选），将影响服务商匹配与材料要求。</text>
        <view class="damage-range-options">
          <view
            class="damage-range-item {{insuranceChoice === 'self' ? 'selected' : ''}}"
            data-choice="self"
            bindtap="onInsuranceChoiceTap"
          >自费</view>
          <view
            class="damage-range-item {{insuranceChoice === 'insurance' ? 'selected' : ''}}"
            data-choice="insurance"
            bindtap="onInsuranceChoiceTap"
          >走保险</view>
        </view>

        <view class="damage-insurance-block" wx:if="{{insuranceChoice === 'insurance'}}">
          <view class="damage-insurance-tip">
            <text class="damage-insurance-tip-icon">!</text>
            <text class="damage-insurance-tip-text">请先选择事故类型，再选择对应保险公司</text>
          </view>
          <view class="damage-insurance-hint">
            <text class="fs-body">{{accidentTypes[accidentTypeIndex].hint}}</text>
            <text class="damage-insurance-main-note" wx:if="{{accidentTypes[accidentTypeIndex].mainNote}}">{{accidentTypes[accidentTypeIndex].mainNote}}</text>
          </view>
          <view class="damage-field-row-inline">
            <text class="damage-label-inline fs-body">事故类型</text>
            <picker mode="selector" range="{{accidentTypes}}" range-key="label" value="{{accidentTypeIndex}}" bindchange="onAccidentChange">
              <view class="damage-input-inline damage-picker-inline">{{accidentTypes[accidentTypeIndex].label}}</view>
            </picker>
          </view>
          <view class="damage-field-row-inline" wx:if="{{accidentTypes[accidentTypeIndex].needSelf}}">
            <text class="damage-label-inline fs-body">自家保险公司</text>
            <picker mode="selector" range="{{insuranceCompanies}}" value="{{insuranceCompanyIndex}}" bindchange="onInsuranceCompanyChange">
              <view class="damage-input-inline damage-picker-inline">{{insuranceCompanies[insuranceCompanyIndex]}}</view>
            </picker>
          </view>
          <view class="damage-field-row-inline" wx:if="{{accidentTypes[accidentTypeIndex].needOther}}">
            <text class="damage-label-inline fs-body">对家保险公司</text>
            <picker mode="selector" range="{{insuranceCompanies}}" value="{{insuranceCompanyOtherIndex}}" bindchange="onInsuranceCompanyOtherChange">
              <view class="damage-input-inline damage-picker-inline">{{insuranceCompanies[insuranceCompanyOtherIndex]}}</view>
            </picker>
          </view>
        </view>
      </view>

    </scroll-view>

    <view class="damage-dock">
      <view class="damage-dock-meta {{dailyQuota.remaining <= 0 ? 'text-error' : ''}}">今日剩余 {{dailyQuota.remaining}}/{{dailyQuota.limit}} 次</view>
      <button class="damage-dock-primary btn-brand" bindtap="onSubmitPreQuote" disabled="{{analyzing || dailyQuota.remaining <= 0}}">
        {{analyzing ? '提交中...' : (dailyQuota.remaining <= 0 ? '今日次数已用完' : '提交预报价')}}
      </button>
      <view class="damage-dock-primary"></view>
    </view>
  </block>

  <block wx:elif="{{step === 2}}">
    <scroll-view class="damage-scroll" scroll-y show-scrollbar="{{false}}">
      <!-- 预报价分析进度（可选） -->
      <view class="damage-progress card" wx:if="{{analyzing}}">
        <view class="damage-progress-bar">
          <view class="damage-progress-fill" style="{{progressStyle}}"></view>
        </view>
        <text class="text-muted fs-cap">正在生成预报价参考，请稍候...</text>
        <text class="text-muted fs-cap" style="display:block;margin-top:8rpx">你可暂时离开本页，稍后返回查看结果；分析完成后底部会出现「发起竞价」。</text>
      </view>

      <!-- 分析结果 / 跳过分析的表单 -->
      <view class="damage-report card" wx:elif="{{reportId}}">
        <view class="damage-report-header">
          <text class="damage-report-title fs-h3 fw-bold">{{report ? '损失报告（AI）' : '发起竞价'}}</text>
          <view class="damage-report-actions-inline">
            
            <view class="damage-report-close" bindtap="onCloseReport">
              <text class="damage-report-close-text">关闭</text>
            </view>
          </view>
        </view>

        <!-- 折叠态：仅展示主车，提示已锁定 -->
        <view class="damage-vehicle-select-hint" wx:if="{{collapsedToFocus && vehiclesAllCount > 1}}">
          <text class="fs-body fw-bold">已锁定您的车辆</text>
          <text class="text-muted fs-sm">仅展示与您填写信息一致的车辆；如需查看 AI 识别出的其它车辆，可展开核对。</text>
          <text class="text-primary fs-sm" style="display:block;margin-top:8rpx;" bindtap="onToggleAllVehicles">查看其它车辆 ({{vehiclesAllCount - 1}})</text>
        </view>

        <!-- 入口 A 进入但未声明车牌：引导填写 -->
        <view class="damage-vehicle-select-hint" wx:if="{{declarePlatePromptHint}}">
          <text class="fs-body fw-bold">请先填写您的车牌</text>
          <text class="text-muted fs-sm">{{declarePlatePromptHint}}</text>
        </view>

        <!-- 多车展开态：提示选择车辆 -->
        <view class="damage-vehicle-select-hint" wx:if="{{!collapsedToFocus && vehiclesList.length > 1}}">
          <text class="fs-body fw-bold">请选择您的车辆</text>
          <text class="text-muted fs-sm">根据车牌号、车型、颜色等综合判断（车牌号可能识别有误）</text>
        </view>

        <view class="damage-vehicle-tabs" wx:if="{{!collapsedToFocus && vehiclesList.length > 1}}">
          <view
            class="damage-vehicle-tab {{selectedVehicleIndex === index ? 'selected' : ''}}"
            wx:for="{{vehiclesList}}"
            wx:key="index"
            data-index="{{index}}"
            bindtap="onVehicleTabTap"
          >
            <text class="fs-body">{{item.vehicleId}}</text>
            <text class="text-muted fs-sm" wx:if="{{item.plateNumber || item.brand || item.model || item.color}}">{{item.plateNumber || ''}}{{item.plateNumber && (item.brand || item.model) ? ' · ' : ''}}{{item.brand || ''}}{{item.brand && item.model ? ' ' : ''}}{{item.model || ''}}{{item.color ? ' ' + item.color : ''}}</text>
          </view>
        </view>

        <!-- 展开态且已识别主车：提供「收起」入口 -->
        <view class="damage-vehicle-collapse-hint" wx:if="{{!collapsedToFocus && expandedAllVehicles && focusVehicleId && vehiclesAllCount > 1}}">
          <text class="text-primary fs-sm" bindtap="onToggleAllVehicles">收起，仅展示您的车辆</text>
        </view>

        <!-- 车辆信息（AI 完成后展示，识别结果预填，可改） -->
        <view class="damage-vehicle-info" wx:if="{{vehiclesList.length}}">
          <view class="damage-section-title fs-body fw-bold">车辆信息</view>
          <text class="text-muted fs-sm" style="display:block;margin-bottom:12rpx;">品牌、车型等为 AI 识别结果，请核对；缺项请手工填写（发起竞价前须填车牌号）。发起竞价时以您填写的车牌为准（可与 AI 识别不一致）。若已在资料中绑定车辆，点击车牌输入框时可在下方选择绑定车牌填入。</text>
          <view class="damage-plate-mismatch-hint text-warning fs-sm" wx:if="{{userDeclaredPlateHint}}">{{userDeclaredPlateHint}}</view>
          <view class="damage-plate-mismatch-hint text-warning fs-sm" wx:if="{{verifiedPlateMismatchHint}}">{{verifiedPlateMismatchHint}}</view>
          <view wx:for="{{vehiclesList}}" wx:key="index" wx:if="{{selectedVehicleIndex === index}}">
            <view class="damage-field-row-inline">
              <text class="damage-label-inline fs-body">车牌号<text class="text-error">*</text></text>
              <input class="damage-input-inline" placeholder="如：京A12345（必填）" value="{{vehicleEdits[index] && vehicleEdits[index].plate_number !== undefined ? vehicleEdits[index].plate_number : item.plateNumber}}" data-index="{{index}}" bindinput="onReportPlateInput" bindfocus="onReportPlateFocus" bindblur="onReportPlateBlur"/>
            </view>
            <view class="damage-bound-plate-suggest" wx:if="{{plateSuggestionVisible && boundPlateList.length}}">
              <text class="text-muted fs-cap damage-bound-plate-suggest-label">以下为资料中绑定车牌（非 AI 识别），点击填入</text>
              <view class="damage-bound-plate-chips">
                <view class="damage-bound-plate-chip fs-body" wx:for="{{boundPlateList}}" wx:for-item="bp" wx:key="*this" data-plate="{{bp}}" catchtap="onPickBoundPlate">{{bp}}</view>
              </view>
            </view>
            <view class="damage-field-row-inline">
              <text class="damage-label-inline fs-body">品牌</text>
              <input class="damage-input-inline" placeholder="如：宝马" value="{{vehicleEdits[index] && vehicleEdits[index].brand !== undefined ? vehicleEdits[index].brand : item.brand}}" data-index="{{index}}" bindinput="onReportBrandInput"/>
            </view>
            <view class="damage-field-row-inline">
              <text class="damage-label-inline fs-body">车型</text>
              <input class="damage-input-inline" placeholder="如：3系、Model Y（勿填 SUV 等通用类型）" value="{{vehicleEdits[index] && vehicleEdits[index].model !== undefined ? vehicleEdits[index].model : item.model}}" data-index="{{index}}" bindinput="onReportModelInput"/>
            </view>
          </view>
        </view>

        <accident-report-view vm="{{reportVm}}" />
      </view>

      <!-- 维修费用渠道：紧接在报告后，减少被默认自费漏选 -->
      <view class="damage-section card" wx:if="{{reportId}}">
        <view class="damage-section-title fs-body fw-bold">维修费用渠道<text class="text-error">*</text></view>
        <text class="text-muted fs-sm" style="display:block;margin-bottom:12rpx;">请选择自费或走保险（必选），将影响服务商匹配与材料要求。</text>
        <view class="damage-range-options">
          <view
            class="damage-range-item {{insuranceChoice === 'self' ? 'selected' : ''}}"
            data-choice="self"
            bindtap="onInsuranceChoiceTap"
          >自费</view>
          <view
            class="damage-range-item {{insuranceChoice === 'insurance' ? 'selected' : ''}}"
            data-choice="insurance"
            bindtap="onInsuranceChoiceTap"
          >走保险</view>
        </view>

        <view class="damage-insurance-block" wx:if="{{insuranceChoice === 'insurance'}}">
          <view class="damage-insurance-tip">
            <text class="damage-insurance-tip-icon">!</text>
            <text class="damage-insurance-tip-text">请先选择事故类型，再选择对应保险公司</text>
          </view>
          <view class="damage-insurance-hint">
            <text class="fs-body">{{accidentTypes[accidentTypeIndex].hint}}</text>
            <text class="damage-insurance-main-note" wx:if="{{accidentTypes[accidentTypeIndex].mainNote}}">{{accidentTypes[accidentTypeIndex].mainNote}}</text>
          </view>
          <view class="damage-field-row-inline">
            <text class="damage-label-inline fs-body">事故类型</text>
            <picker mode="selector" range="{{accidentTypes}}" range-key="label" value="{{accidentTypeIndex}}" bindchange="onAccidentChange">
              <view class="damage-input-inline damage-picker-inline">{{accidentTypes[accidentTypeIndex].label}}</view>
            </picker>
          </view>
          <view class="damage-field-row-inline" wx:if="{{accidentTypes[accidentTypeIndex].needSelf}}">
            <text class="damage-label-inline fs-body">自家保险公司</text>
            <picker mode="selector" range="{{insuranceCompanies}}" value="{{insuranceCompanyIndex}}" bindchange="onInsuranceCompanyChange">
              <view class="damage-input-inline damage-picker-inline">{{insuranceCompanies[insuranceCompanyIndex]}}</view>
            </picker>
          </view>
          <view class="damage-field-row-inline" wx:if="{{accidentTypes[accidentTypeIndex].needOther}}">
            <text class="damage-label-inline fs-body">对家保险公司</text>
            <picker mode="selector" range="{{insuranceCompanies}}" value="{{insuranceCompanyOtherIndex}}" bindchange="onInsuranceCompanyOtherChange">
              <view class="damage-input-inline damage-picker-inline">{{insuranceCompanies[insuranceCompanyOtherIndex]}}</view>
            </picker>
          </view>
        </view>
      </view>

      <!-- 询价位置（用于邀请附近服务商，必填） -->
      <view class="damage-section card">
        <view class="damage-section-title fs-body fw-bold">询价位置<text class="text-error">*</text></view>
        <view class="damage-location-block">
          <view class="damage-location-row" bindtap="onChooseBiddingLocation">
            <image class="damage-location-icon" src="/images/icon/location.png" mode="aspectFit"/>
            <view class="damage-location-content">
              <text class="fs-body {{locationAddress ? 'text-primary' : 'text-muted'}}">{{locationAddress || '请选择位置（必填），附近服务商将收到您的询价'}}</text>
              <text class="text-muted fs-sm damage-location-hint" wx:if="{{locationLat != null && locationLng != null}}">点击查看地图</text>
            </view>
            <text class="damage-location-arrow">›</text>
          </view>
          <view class="damage-location-rechoose" wx:if="{{locationLat != null && locationLng != null}}" catchtap="onRechooseBiddingLocation">
            <text class="fs-sm text-weak">重新选择</text>
          </view>
        </view>
      </view>

      <!-- 发起竞价 -->
      <view class="damage-section card">
        <view class="damage-section-title fs-body fw-bold">竞价范围</view>
        <view class="damage-range-options">
          <view
            class="damage-range-item {{rangeKm === 5 ? 'selected' : ''}}"
            data-value="{{5}}"
            bindtap="onRangeTap"
          >5km</view>
          <view
            class="damage-range-item {{rangeKm === 10 ? 'selected' : ''}}"
            data-value="{{10}}"
            bindtap="onRangeTap"
          >10km</view>
          <view
            class="damage-range-item {{rangeKm === 0 ? 'selected' : ''}}"
            data-value="{{0}}"
            bindtap="onRangeTap"
          >全市</view>
        </view>
      </view>

    </scroll-view>

    <view class="damage-dock">
      <view class="damage-dock-meta {{dailyQuota.remaining <= 0 ? 'text-error' : ''}}">今日剩余 {{dailyQuota.remaining}}/{{dailyQuota.limit}} 次</view>
      <button class="damage-dock-primary btn-brand" bindtap="onCreateBidding" disabled="{{submitting}}">
        {{submitting ? '提交中...' : '发起竞价'}}
      </button>
      <view class="damage-dock-primary"></view>
    </view>
  </block>
</view>
