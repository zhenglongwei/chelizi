/**
 * AI定损页 - 02-AI定损页
 * 以《设计规范.md》、design-system 为准
 */
.damage-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-page);
  box-sizing: border-box;
}

.damage-empty {
  margin: var(--space-2xl) var(--page-padding-x);
  padding: var(--space-2xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-lg);
}

.damage-login-link {
  color: var(--primary);
  font-size: var(--fs-body);
}

.damage-scroll {
  flex: 1;
  min-height: 0;
  padding: var(--space-lg) var(--page-padding-x);
  box-sizing: border-box;
}

/* ========== 顶部引导（对齐 AI 分析） ========== */
.damage-hero {
  text-align: center;
  padding: var(--space-xl) var(--space-md) var(--space-lg);
}

.damage-hero-title {
  margin-bottom: var(--space-sm);
  letter-spacing: 0.02em;
}

.damage-hero-sub {
  line-height: 1.6;
  max-width: 620rpx;
  margin: 0 auto;
}

/* ========== 照片上传 ========== */
.damage-section {
  margin: 0 0 var(--space-lg);
  padding: var(--space-xl);
}

.damage-section-title {
  margin-bottom: var(--space-lg);
  color: var(--text-primary);
}

/* ========== 大输入区（对齐 AI 分析页 Dock 风格） ========== */
.damage-composer {
  margin: 0 0 var(--space-lg);
  padding: var(--space-xl);
}

.damage-composer-input {
  width: 100%;
  min-height: 200rpx;
  max-height: 360rpx;
  padding: 16rpx 8rpx;
  font-size: 30rpx;
  line-height: 1.55;
  color: var(--text-primary);
  box-sizing: border-box;
}

.damage-composer-toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
  padding-top: var(--space-sm);
  border-top: 1rpx solid rgba(148, 163, 184, 0.2);
}

.damage-tool-plus {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: rgba(37, 99, 235, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.damage-tool-plus-icon {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--primary);
  line-height: 1;
}

.damage-tool-hint {
  flex: 1;
  min-width: 0;
}

.damage-thumb-strip {
  margin-top: var(--space-md);
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.damage-location-block {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.damage-location-row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-md) 0;
}

.damage-location-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.damage-location-hint {
  display: block;
}

.damage-location-rechoose {
  padding: var(--space-sm) 0;
  margin-left: calc(40rpx + var(--space-md));
}

.damage-location-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  opacity: 0.7;
}


.damage-location-arrow {
  font-size: var(--fs-h2);
  color: var(--text-hint);
  flex-shrink: 0;
}

.damage-upload-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--bg-placeholder);
}

.damage-upload-item--sm {
  width: 72rpx;
  height: 72rpx;
}

.damage-thumb {
  width: 100%;
  height: 100%;
}

.damage-del {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.damage-del-x {
  color: #fff;
  font-size: 22rpx;
  line-height: 1;
}

.damage-upload-hint {
  display: block;
  margin-top: var(--space-md);
}

/* ========== 车辆信息 ========== */
.damage-field {
  margin-bottom: var(--space-lg);
}

.damage-field:last-child {
  margin-bottom: 0;
}

.damage-label {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--text-secondary);
}

.damage-input {
  width: 100%;
  padding: var(--space-md) var(--space-lg);
  font-size: var(--fs-body);
  color: var(--text-primary);
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}

/* 车辆信息 3 行布局：左标签右输入，横线样式 */
.damage-field-row-inline {
  display: flex;
  align-items: center;
  padding: var(--space-md) 0;
  border-bottom: 1rpx solid var(--border);
  margin-bottom: 0;
}

.damage-field-row-inline:last-child {
  border-bottom: none;
}

.damage-plate-mismatch-hint {
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.damage-bound-plate-suggest {
  margin: -8rpx 0 16rpx;
  padding: 12rpx 0 8rpx;
}

.damage-bound-plate-suggest-label {
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.45;
}

.damage-bound-plate-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.damage-bound-plate-chip {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--bg-muted, #f3f4f6);
  border: 1rpx solid var(--border);
  color: var(--text-primary, #111827);
}

/* 走保险时提醒与说明 */
.damage-insurance-block {
  margin-top: var(--space-lg);
  padding-top: var(--space-lg);
  border-top: 1rpx solid var(--border);
}

.damage-insurance-tip {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-md);
  background: rgba(245, 158, 11, 0.12);
  border-radius: var(--radius-md);
  border-left: 4rpx solid var(--warning);
}

.damage-insurance-tip-icon {
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: var(--fs-body);
  font-weight: bold;
  color: var(--warning);
  background: #fff;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.damage-insurance-tip-text {
  font-size: var(--fs-body);
  color: var(--text-primary);
  font-weight: 500;
}

.damage-insurance-hint {
  margin-bottom: var(--space-lg);
  padding: var(--space-md) var(--space-lg);
  background: rgba(37, 99, 235, 0.06);
  border-radius: var(--radius-md);
}

.damage-insurance-hint .fs-body {
  color: var(--text-secondary);
}

.damage-insurance-main-note {
  display: block;
  margin-top: var(--space-xs);
  font-size: var(--fs-sm);
  color: var(--primary);
  font-weight: 500;
}

.damage-label-inline {
  flex-shrink: 0;
  width: 140rpx;
  color: var(--text-secondary);
}

.damage-input-inline {
  flex: 1;
  font-size: var(--fs-body);
  color: var(--text-primary);
  padding: 0;
  border: none;
  background: none;
}

.damage-input-inline::placeholder {
  color: var(--text-weak);
}

.damage-picker-inline {
  text-align: right;
  color: var(--text-primary);
}

.damage-picker {
  padding: var(--space-md) var(--space-lg);
  font-size: var(--fs-body);
  color: var(--text-primary);
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
}

/* ========== 竞价范围 ========== */
.damage-range-options {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
}

.damage-range-item {
  padding: var(--space-md) var(--space-xl);
  font-size: var(--fs-body);
  background: var(--bg-page);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
}

.damage-range-item.selected {
  background: rgba(37, 99, 235, 0.06);
  border-color: var(--primary);
  color: var(--primary);
}

/* ========== 分析进度 ========== */
.damage-progress {
  margin: 0 var(--page-padding-x) var(--space-lg);
  padding: var(--space-xl);
}

.damage-progress-bar {
  height: 12rpx;
  background: var(--bg-placeholder);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: var(--space-md);
}

.damage-progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* ========== 定损报告 ========== */
.damage-report {
  margin: 0 var(--page-padding-x) var(--space-lg);
  padding: var(--space-xl);
}

.damage-report-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-lg);
}

.damage-report-actions-inline {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.damage-report-share-btn {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 var(--space-lg);
  border-radius: var(--radius-md);
  background: transparent;
  color: var(--text-primary);
  border: 1rpx solid var(--border);
  font-size: var(--fs-body);
}

.damage-report-title {
  color: var(--text-primary);
}

.damage-report-close {
  padding: var(--space-sm) var(--space-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
}

.damage-report-close-text {
  font-size: var(--fs-body);
  color: var(--text-secondary);
}

.damage-report-level {
  margin-bottom: var(--space-md);
  color: var(--text-secondary);
}

.damage-report-damages,
.damage-report-repair {
  margin-bottom: var(--space-lg);
}

.damage-human-section {
  margin-bottom: var(--space-md);
}

.damage-human-title {
  margin-bottom: var(--space-xs);
}

.damage-human-empty {
  display: block;
  padding: var(--space-xs) 0;
}

.damage-disclaimer {
  margin-top: var(--space-lg);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
  line-height: 1.5;
}

.damage-report-repair {
  margin-bottom: 0;
}

/* ========== 多车选择 ========== */
.damage-vehicle-select-hint {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
}

.damage-vehicle-select-hint .text-muted {
  font-size: var(--fs-sm);
}

.damage-plate-match {
  margin-bottom: var(--space-md);
}

.damage-plate-match .damage-input-inline {
  width: 100%;
  padding: var(--space-sm) var(--space-md);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
  background: var(--bg-page);
}

.damage-vehicle-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
}

.damage-vehicle-tab {
  padding: var(--space-sm) var(--space-lg);
  font-size: var(--fs-body);
  background: var(--bg-page);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
}

.damage-vehicle-tab.selected {
  background: rgba(37, 99, 235, 0.06);
  border-color: var(--primary);
  color: var(--primary);
}

.damage-vehicle-tab .text-muted {
  display: block;
  margin-top: 2rpx;
}

.damage-vehicle-info {
  margin-bottom: var(--space-lg);
}

.damage-field-row {
  margin-bottom: var(--space-md);
}

.damage-field-row:last-child {
  margin-bottom: 0;
}

.damage-damage-item,
.damage-repair-item {
  margin-top: var(--space-sm);
  color: var(--text-secondary);
}

/* ========== 底部 ========== */

/* 新 Dock（对齐 AI 分析） */
.damage-dock {
  flex-shrink: 0;
  padding: var(--space-md) var(--page-padding-x);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(248, 250, 252, 0) 0%, var(--bg-page) 18%);
  border-top: 1rpx solid var(--border);
}

.damage-dock-meta {
  font-size: 24rpx;
  color: var(--text-weak);
  text-align: right;
  margin-bottom: var(--space-xs);
}

.damage-dock-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: var(--fs-body);
  margin: 0;
}

.damage-dock-primary::after {
  border: none;
}

.damage-dock-tip {
  margin-top: var(--space-sm);
  text-align: center;
  line-height: 1.45;
  padding: 0 var(--space-sm);
}
