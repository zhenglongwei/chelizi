<custom-nav-bar title="商品订单" showBack="{{true}}" />
<view class="page-root po-list-page" style="{{pageRootStyle}}">
  <view class="text-muted fs-body po-loading" wx:if="{{loading}}">加载中...</view>
  <view class="text-muted fs-body po-empty" wx:elif="{{!list.length}}">暂无商品订单</view>
  <scroll-view wx:else class="po-scroll" scroll-y style="{{scrollStyle}}">
    <view class="po-card card" wx:for="{{list}}" wx:key="product_order_id">
      <view class="po-row">
        <text class="fs-body fw-bold">{{item.product_name}}</text>
        <text class="po-status fs-cap {{item.paid ? 'po-paid' : ''}}">{{item.statusLabel}}</text>
      </view>
      <text class="text-muted fs-cap">{{item.shop_name}}</text>
      <view class="po-row po-meta">
        <text class="text-muted fs-cap">×{{item.quantity}}</text>
        <text class="fs-body fw-bold text-primary">¥{{item.amountText}}</text>
      </view>
      <text class="text-weak fs-sm" wx:if="{{item.paid && item.paidAtText}}">支付时间 {{item.paidAtText}}</text>
    </view>
  </scroll-view>
</view>
