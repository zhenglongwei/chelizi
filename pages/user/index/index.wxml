<!-- 个人中心 -->
<custom-nav-bar title="我的" />
<view class="page-root user-page" style="{{pageRootStyle}}">
  <!-- 用户信息区：头像左、昵称等级右、定位按钮右上角 -->
  <view class="user-header card">
    <block wx:if="{{hasToken}}">
      <view class="user-header-location" bindtap="onChooseLocation">
        <image class="user-header-location-icon" src="/images/icon/location.png" mode="aspectFit"/>
        <text class="user-header-location-text">{{locationShort || '位置'}}</text>
        <image class="user-header-location-arrow" src="/images/icon/right.png" mode="aspectFit"/>
      </view>
      <view class="user-header-inner">
        <navigator url="/pages/auth/profile/index?redirect=%2Fpages%2Fuser%2Findex%2Findex" class="user-avatar" wx:if="{{userInfo.avatar_url}}">
          <image src="{{userInfo.avatar_url}}" mode="aspectFill"/>
        </navigator>
        <navigator url="/pages/auth/profile/index?redirect=%2Fpages%2Fuser%2Findex%2Findex" class="user-avatar user-avatar-placeholder" wx:else>
          <image src="/images/icon/person.png" mode="aspectFit"/>
        </navigator>
        <view class="user-header-info">
          <text class="user-name fs-body fw-bold">{{userInfo.nickname || '用户'}}</text>
          <navigator url="/pages/user/level-detail/index" class="user-level-wrap">
            <text class="user-level text-muted fs-sm" wx:if="{{userInfo.level_name}}">{{userInfo.level_name}}</text>
            <text class="user-level-arrow fs-cap" wx:if="{{userInfo.level_name}}">›</text>
          </navigator>
          <navigator wx:if="{{userInfo.needs_verification}}" url="/pages/auth/profile/index?redirect=%2Fpages%2Fuser%2Findex%2Findex" class="user-verify-prompt fs-sm">完成实名认证和车辆绑定，可领取奖励金</navigator>
        </view>
      </view>
    </block>
    <navigator wx:else url="/pages/auth/login/index?redirect=%2Fpages%2Fuser%2Findex%2Findex" class="user-login-btn">登录</navigator>
  </view>

  <!-- 服务商入口：已有服务商 token；或车主登录后检测到 openid 已注册服务商 -->
  <view class="user-merchant-entry card" wx:if="{{hasMerchantToken || merchantOpenidBound}}">
    <navigator wx:if="{{hasMerchantToken}}" class="user-merchant-btn" url="/pages/merchant/home">
      <text class="fs-body fw-bold">进入服务商工作台</text>
      <text class="text-muted fs-cap">维修厂报价、接单、订单管理</text>
    </navigator>
    <view wx:else class="user-merchant-btn user-merchant-btn-tap" bindtap="onMerchantWechatQuickEnter">
      <text class="fs-body fw-bold">进入服务商工作台</text>
      <text class="text-muted fs-cap" wx:if="{{merchantWechatLoading}}">登录中...</text>
      <text class="text-muted fs-cap" wx:elif="{{merchantEntryPending}}">资质审核中，暂不可登录</text>
      <text class="text-muted fs-cap" wx:elif="{{merchantEntryShopName}}">{{merchantEntryShopName}} · 点击登录并进入</text>
      <text class="text-muted fs-cap" wx:else>当前微信已绑定服务商，点击登录并进入</text>
    </view>
  </view>

  <!-- 我的钱包（需登录） -->
  <navigator class="user-wallet card" wx:if="{{hasToken}}" url="/pages/user/balance/index">
    <view class="user-wallet-title fs-body fw-bold">我的钱包</view>
    <view class="user-wallet-content">
      <view class="user-wallet-item">
        <text class="text-muted fs-sm">奖励金余额</text>
        <text class="fs-h3 fw-bold text-gold">¥{{balanceText}}</text>
      </view>
      <view class="user-wallet-item">
        <text class="text-muted fs-sm">累计奖励金</text>
        <text class="fs-body">¥{{totalRebateText}}</text>
      </view>
    </view>
    <view class="user-wallet-actions">
      <button class="btn-primary user-withdraw-btn" catchtap="onWithdraw">提现</button>
    </view>
  </navigator>

  

  <!-- 我的订单：标题行=进订单列表；下方为可点的状态筛选 -->
  <view class="user-section card" wx:if="{{hasToken}}">
    <view class="user-section-header user-order-header">
      <navigator class="user-section-title-row" url="/pages/order/hub/index?tab=repair">
        <text class="fs-body fw-bold">我的订单</text>
        <view class="user-section-title-row-right">
          <text class="user-section-title-cta fs-cap">查看列表</text>
          <image class="user-section-title-arrow" src="/images/icon/right.png" mode="aspectFit" />
        </view>
      </navigator>
      <text class="user-order-book-btn text-primary fs-cap" catchtap="onUserBookTap">预约</text>
    </view>
    <view class="user-section-tabs user-section-tabs--chips">
      <navigator class="user-tab user-tab-chip" url="/pages/order/hub/index?tab=repair">全部</navigator>
      <navigator class="user-tab user-tab-chip" url="/pages/order/hub/index?tab=repair&status=to_review">待评价</navigator>
      <navigator class="user-tab user-tab-chip" url="/pages/order/hub/index?tab=repair&status=completed">已完成</navigator>
    </view>
  </view>

  <!-- 我的竞价：与订单区一致，避免整块 navigator 嵌套子 navigator -->
  <view class="user-section card" wx:if="{{hasToken}}">
    <navigator class="user-section-header user-section-title-row" url="/pages/bidding/list/index">
      <text class="fs-body fw-bold">我的竞价</text>
      <view class="user-section-title-row-right">
        <text class="user-section-title-cta fs-cap">查看列表</text>
        <image class="user-section-title-arrow" src="/images/icon/right.png" mode="aspectFit" />
      </view>
    </navigator>
    <view class="user-section-tabs user-section-tabs--chips">
      <navigator class="user-tab user-tab-chip" url="/pages/bidding/list/index?status=0">未完成</navigator>
      <navigator class="user-tab user-tab-chip" url="/pages/bidding/list/index?status=1">已关闭</navigator>
    </view>
  </view>

  <navigator class="user-section card" wx:if="{{hasToken}}" url="/pages/damage/history/index">
    <view class="user-section-header">
      <text class="fs-body fw-bold">AI分析报告</text>
      <view class="user-section-more" >全部</view>
    </view>    
  </navigator>

  <navigator class="user-section card" wx:if="{{hasToken}}" url="/pages/user/settings/index">
    <view class="user-section-header">      
      <view class="user-section-more" >
        <text class="fs-body fw-bold text-primary">设置</text>
      </view>
    </view>    
  </navigator>
  
</view>
