<!-- 奖励金余额明细页 - 14-奖励金余额明细页 -->
<custom-nav-bar title="奖励金余额" showBack="{{true}}" />
<view class="page-root balance-page" style="{{pageRootStyle}}">
  <block wx:if="{{!hasToken}}">
    <view class="balance-empty card">
      <text class="text-muted fs-body">请先登录后查看</text>
      <navigator class="balance-login-link" url="/pages/auth/login/index?redirect=%2Fpages%2Fuser%2Fbalance%2Findex">去登录</navigator>
    </view>
  </block>
  <block wx:else>
    <view class="balance-summary card">
      <view class="balance-row">
        <text class="text-muted fs-sm">可提现余额</text>
        <text class="fs-h2 fw-bold text-gold">¥{{balanceText}}</text>
      </view>
      <view class="balance-row">
        <text class="text-muted fs-sm">累计奖励金</text>
        <text class="fs-body">¥{{totalRebateText}}</text>
      </view>
      <text class="text-weak fs-sm" style="display:block; margin-top: var(--space-sm);">展示金额为税前应付；个税与实付以支付侧为准</text>
      <navigator class="balance-rules-link fs-sm" url="/pages/user/reward-rules/index">奖励规则说明</navigator>
      <button class="btn-primary balance-withdraw-btn {{canWithdraw ? '' : 'disabled'}}" bindtap="onWithdraw">提现</button>
    </view>
    <view class="balance-filter-bar">
      <picker mode="selector" range="{{monthOptions}}" range-key="label" value="{{monthIndex}}" bindchange="onMonthChange">
        <view class="balance-filter-item">
          <text class="text-muted fs-sm">{{monthOptions[monthIndex].label}}</text>
          <text class="text-weak fs-sm">▼</text>
        </view>
      </picker>
      <picker mode="selector" range="{{typeOptions}}" range-key="label" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="balance-filter-item">
          <text class="text-muted fs-sm">{{typeOptions[typeIndex].label}}</text>
          <text class="text-weak fs-sm">▼</text>
        </view>
      </picker>
    </view>
    <view class="balance-list-title fs-body fw-bold">明细记录</view>
    <view class="balance-empty-tip card" wx:if="{{!loading && list.length === 0}}">
      <text class="text-muted fs-body">暂无记录</text>
    </view>
    <scroll-view wx:else class="balance-scroll" scroll-y style="{{scrollStyle}}" bindscrolltolower="onLoadMore">
      <view class="balance-item card" wx:for="{{list}}" wx:key="transaction_id">
        <view class="balance-item-header">
          <text class="fs-body">{{item.typeLabel}}</text>
          <text class="fs-body fw-bold {{item.isIncome ? 'text-success' : 'text-muted'}}">{{item.amountText}}</text>
        </view>
        <view class="balance-item-meta">
          <text class="text-weak fs-sm">{{item.timeText}}</text>
          <text class="text-weak fs-sm" wx:if="{{item.settlement_month}}">结算月份 {{item.settlement_month}}</text>
          <text class="text-weak fs-sm" wx:if="{{item.stageLabel}}">{{item.stageLabel}}</text>
          <text class="text-weak fs-sm" wx:if="{{item.taxLabel}}">{{item.taxLabel}}</text>
          <text class="text-weak fs-sm" wx:if="{{item.description}}">{{item.description}}</text>
        </view>
        <view class="balance-item-breakdown" wx:if="{{item.rewardBreakdown}}">
          <text class="balance-breakdown-title fs-cap">奖励明细</text>
          <view class="balance-breakdown-row">
            <text class="text-weak fs-cap">订单分级</text>
            <text class="fs-cap">{{item.rewardBreakdown.tier_label}}</text>
          </view>
          <view class="balance-breakdown-row">
            <text class="text-weak fs-cap">发放阶段</text>
            <text class="fs-cap">{{item.rewardBreakdown.stage_label}}{{item.rewardBreakdown.stage_percent ? ' ' + item.rewardBreakdown.stage_percent : ''}}</text>
          </view>
          <view class="balance-breakdown-row" wx:if="{{item.rewardBreakdown.content_quality_level}}">
            <text class="text-weak fs-cap">内容评级</text>
            <text class="fs-cap">{{item.rewardBreakdown.content_quality_level}}</text>
          </view>
          <view class="balance-breakdown-row">
            <text class="text-weak fs-cap">维修复杂度</text>
            <text class="fs-cap">{{item.rewardBreakdown.complexity_level}}</text>
          </view>
          <view class="balance-breakdown-row" wx:if="{{item.rewardBreakdown.vehicle_coeff}}">
            <text class="text-weak fs-cap">车价系数</text>
            <text class="fs-cap">{{item.rewardBreakdown.vehicle_coeff}}</text>
          </view>
          <view class="balance-breakdown-row">
            <text class="text-weak fs-cap">税前</text>
            <text class="fs-cap">¥{{item.rewardBreakdown.amount_before_tax}}</text>
          </view>
          <view class="balance-breakdown-row" wx:if="{{item.rewardBreakdown.tax_deducted !== '0.00'}}">
            <text class="text-weak fs-cap">代扣个税</text>
            <text class="fs-cap">¥{{item.rewardBreakdown.tax_deducted}}</text>
          </view>
          <view class="balance-breakdown-row">
            <text class="text-weak fs-cap">实收</text>
            <text class="fs-cap text-gold">¥{{item.rewardBreakdown.amount_after_tax}}</text>
          </view>
        </view>
      </view>
      <view class="balance-load-more" wx:if="{{hasMore && !loading}}">
        <text class="text-muted fs-sm">上拉加载更多</text>
      </view>
      <view class="balance-bottom-pad"></view>
    </scroll-view>
  </block>
</view>
