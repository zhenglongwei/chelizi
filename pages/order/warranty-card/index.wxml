<custom-nav-bar title="{{card && card.card_phase === 'style_preview' ? '凭证样式预览' : '电子质保凭证'}}" showBack="{{true}}" />
<view class="page-root warranty-card-page" style="{{pageRootStyle}}">
  <block wx:if="{{loading}}">
    <view class="warranty-card-loading"><text class="text-muted fs-body">加载中...</text></view>
  </block>
  <block wx:elif="{{error}}">
    <view class="warranty-card-error card">
      <text class="fs-body text-muted">{{error}}</text>
    </view>
  </block>
  <block wx:elif="{{card}}">
    <warranty-card-surface
      card="{{card}}"
      themeClass="{{themeClass}}"
      useSampleItems="{{useSampleItems}}"
      showShareHint="{{true}}"
    />
    <navigator class="warranty-card-notice-link fs-cap text-primary" url="/pages/help/warranty-notice/index">质保责任说明</navigator>
    <button class="btn-secondary warranty-card-share-btn" wx:if="{{card.card_phase === 'official'}}" open-type="share">转发给朋友</button>
  </block>
</view>
