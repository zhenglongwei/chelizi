/* 订单详情 - 07-订单详情页（参照服务商端布局，不含佣金等专属信息） */
.order-detail-page { min-height: 100vh; background: var(--bg-page); padding: var(--space-lg) var(--page-padding-x); padding-bottom: 120rpx; }
.order-loading { padding: var(--space-2xl); text-align: center; }

.detail-section {
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
}
.section-head { margin-top: var(--space-md); }
.section-head:first-child { margin-top: 0; }
.section-title { font-size: var(--fs-body); margin-bottom: var(--space-xs); font-weight: 500; }

.status-text {
  display: inline-block;
  padding: var(--space-xs) var(--space-md);
  font-size: var(--fs-cap);
  font-weight: 500;
  color: var(--primary);
  background: var(--primary-bg);
  border-radius: var(--radius-md);
}

.duration-timer-wrap { margin-top: var(--space-md); }
.duration-timer {
  padding: var(--space-md);
  background: var(--bg-placeholder);
  border-radius: var(--radius-sm);
  margin-top: var(--space-xs);
}
.duration-timer.expired .duration-timer-main { opacity: 0.7; }
.duration-timer-main { display: flex; flex-wrap: wrap; gap: var(--space-sm); align-items: center; }
.duration-days { font-size: var(--fs-body); font-weight: 500; color: var(--primary); }
.duration-deadline { font-size: var(--fs-cap); color: var(--text-secondary); }
.duration-countdown { margin-top: var(--space-sm); padding-top: var(--space-sm); border-top: 1rpx solid var(--border); }
.duration-countdown.expired .countdown-value { color: var(--danger); }
.countdown-label { font-size: var(--fs-cap); color: var(--text-secondary); margin-right: var(--space-xs); }
.countdown-value { font-size: var(--fs-body); font-weight: 600; color: var(--primary); }

.vehicle-info { margin-top: var(--space-xs); }
.damage-list, .repair-items, .value-added-list { margin-top: var(--space-xs); }
.damage-item { display: flex; flex-direction: column; padding: var(--space-sm) 0; border-bottom: 1rpx solid var(--border); }
.repair-item { display: flex; justify-content: space-between; align-items: center; padding: var(--space-sm) 0; border-bottom: 1rpx solid var(--border); }
.damage-item:last-child, .repair-item:last-child { border-bottom: none; }
.damage-item-row { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-sm); }
.damage-sub { display: flex; justify-content: space-between; align-items: center; padding: var(--space-xs) 0 var(--space-xs) var(--space-md); }
.value-added-item { padding: var(--space-xs) 0; color: var(--text-secondary); }
.quote-info { line-height: 1.5; margin-top: var(--space-xs); }
.shop-info { margin-top: var(--space-xs); }
.shop-address { margin-top: var(--space-xs); }
.link { color: var(--primary); margin-left: var(--space-sm); }

.order-reward-preview { margin-top: var(--space-lg); }
.order-reward-title { margin-bottom: var(--space-sm); }
.order-reward-total { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-xs); }
.order-reward-stages { display: flex; flex-wrap: wrap; gap: var(--space-xs); }

.order-repair-plan-pending { margin-top: var(--space-lg); }
.repair-plan-pending-title { margin-bottom: var(--space-md); color: var(--warning); }
.repair-plan-pending-items { margin-bottom: var(--space-md); }
.repair-plan-item { display: flex; justify-content: space-between; padding: var(--space-xs) 0; font-size: var(--fs-body); }
.repair-plan-pending-actions { display: flex; gap: var(--space-md); }
.repair-plan-pending-actions button { flex: 1; }

/* 维修方案新方案展示（下方卡片） */
.repair-plan-new-wrap {
  margin-bottom: var(--space-md);
  padding: var(--space-md);
  background: var(--bg-placeholder);
  border-radius: var(--radius-md);
  border-left: 4rpx solid var(--warning);
}
.repair-plan-new-label {
  display: block;
  margin-bottom: var(--space-sm);
}
.repair-plan-new-items,
.repair-plan-new-value-added {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}
.repair-plan-new-value-added {
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border);
}
.repair-plan-value-added-label {
  display: block;
  margin-bottom: var(--space-xs);
}
.repair-plan-compare-item {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-xs) 0;
}
.repair-plan-compare-meta {
  margin-top: var(--space-md);
}
.repair-plan-diff-tag {
  font-size: var(--fs-cap);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}
.repair-plan-diff-tag.added { color: var(--success); background: rgba(34, 197, 94, 0.12); }
.repair-plan-diff-tag.modified { color: var(--warning); background: rgba(245, 158, 11, 0.12); }
.repair-plan-diff-tag.removed { color: var(--danger); background: rgba(239, 68, 68, 0.12); }

/* 待确认时展示的维修凭证照片（只读） */
.completion-evidence .evidence-view { display: flex; flex-direction: column; gap: var(--space-lg); }
.completion-evidence .evidence-item { display: flex; flex-direction: column; gap: var(--space-xs); }
.completion-evidence .evidence-label { color: var(--text-secondary); }
.completion-evidence .evidence-grid { display: flex; flex-wrap: wrap; gap: var(--space-sm); }
.completion-evidence .evidence-thumb {
  width: 120rpx; height: 120rpx; border-radius: var(--radius-sm); overflow: hidden;
  background: var(--bg-placeholder);
}
.completion-evidence .evidence-thumb image { width: 100%; height: 100%; }

.order-detail-actions { margin-top: var(--space-xl); display: flex; flex-wrap: wrap; gap: var(--space-md); }
.order-detail-actions .btn-secondary, .order-detail-actions button { flex: 1; min-width: 160rpx; }
