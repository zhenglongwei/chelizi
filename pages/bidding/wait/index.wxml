<custom-nav-bar title="分发中" showBack="{{true}}" />
<view class="page-root bid-wait-page" style="{{pageRootStyle}}">
  <view class="wait-card card">
    <text class="wait-title fs-h3 fw-bold">{{title}}</text>
    <text class="wait-sub text-muted fs-body">{{subtitle}}</text>
    <text class="wait-sub text-weak fs-sm" wx:if="{{extraHint}}">{{extraHint}}</text>

    <view class="wait-actions" wx:if="{{showBackToPrequote}}">
      <button class="btn-secondary wait-btn" bindtap="onBackToPrequote">返回预报价页</button>
    </view>
    <view class="wait-actions" wx:elif="{{showGoBiddingDetail}}">
      <button class="btn-primary wait-btn" bindtap="onGoBiddingDetail">去竞价页</button>
    </view>
  </view>
</view>

