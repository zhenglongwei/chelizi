<!-- 竞价报价页 - 03-竞价报价页 -->
<custom-nav-bar title="竞价报价" showBack="{{true}}" />
<view class="page-root bid-detail-page" style="{{pageRootStyle}}">
  <block wx:if="{{!hasToken}}">
    <view class="bid-empty card">
      <text class="text-muted fs-body">请先登录后查看报价</text>
      <navigator class="bid-login-link" url="/pages/auth/login/index?redirect={{redirectUrl}}">去登录</navigator>
    </view>
  </block>
  <block wx:elif="{{loading && !bidding}}">
    <view class="bid-loading">
      <text class="text-muted fs-body">加载中...</text>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="bid-error card">
      <text class="text-muted fs-body">{{error}}</text>
      <view class="bid-back-btn btn-secondary" bindtap="onBack">返回上一页</view>
    </view>
  </block>
  <block wx:elif="{{bidding}}">
    <scroll-view class="bid-scroll" scroll-y style="{{scrollStyle}}">
      <!-- 竞价状态 -->
      <view class="bid-status card">
        <view class="bid-status-row">
          <text class="text-muted fs-cap">竞价截止</text>
          <text class="fs-body fw-bold {{countdownExpired ? 'text-muted' : 'text-primary'}}">{{countdownText}}</text>
        </view>
        <view class="bid-status-row" wx:if="{{countdownExpired}}">
          <text class="text-muted fs-cap">说明</text>
          <text class="fs-cap text-muted">竞价截止后已报价仍有效，可随时选择</text>
        </view>
        <view class="bid-status-row" wx:if="{{!isDistributionPending && bidding.invited_count > 0}}">
          <text class="text-muted fs-cap">已通知</text>
          <text class="fs-body">{{notifiedCount}}家服务商报价</text>
        </view>
        <view class="bid-status-row">
          <text class="text-muted fs-cap">已报价</text>
          <text class="fs-body">{{bidding.quote_count}}家</text>
        </view>
        <view class="bid-subscribe-row fs-cap" wx:if="{{bidding.status === 0}}" bindtap="onTapSubscribeBiddingQuote">
          <text class="text-muted">微信提醒：每次「允许」通常仅多 1 条推送额度；多店陆续报价时请用下方列表或</text>
          <text class="text-primary bid-subscribe-link">点此订阅/再次订阅</text>
          <text class="text-muted">。</text>
        </view>
      </view>

      <!-- 预报价参考（与预报价页一致：明显/可能/维修建议，仅供参考） -->
      <view class="bid-report card" wx:if="{{bidding && reportHasAnalysisSection}}">
        <view class="bid-report-head" bindtap="toggleReport">
          <text class="fs-body fw-bold">AI参考</text>
          <image class="bid-report-arrow" src="/images/icon/zhedie.png" mode="aspectFit" style="transform: rotate({{reportExpanded ? 180 : 0}}deg);"/>
        </view>
        <view class="bid-report-body" wx:if="{{reportExpanded}}">
          <accident-report-view vm="{{reportVm}}" />
        </view>
      </view>

      <!-- 支付方式（竞价提交后不可修改） -->
      <view class="bid-sort card">
        <text class="bid-sort-label text-muted fs-cap">支付方式</text>
        <text class="bid-sort-value fs-body fw-medium">{{bidding.insurance_info && bidding.insurance_info.is_insurance ? '保险支付' : '自费'}}</text>
      </view>

      <view class="card" wx:if="{{bidding.insurance_info && bidding.insurance_info.is_insurance}}">
        <text class="text-muted fs-cap">理赔款一般由保险公司与维修厂结算，选厂时可重点看资质、案例、质保与店铺综合分，不必单纯追求最低价。</text>
      </view>
      <view class="card" wx:elif="{{bidding}}">
        <text class="text-muted fs-cap">自费维修建议核对报价明细与质保；在维修厂搜索中可选「性价比优先」或「价格最低」排序。</text>
      </view>

      <!-- 预报价轻量提示 + 跳转说明页 -->
      <view class="bid-edu-compact card">
        <view class="bid-edu-prequote-bar"/>
        <view class="bid-edu-compact-inner">
          <text class="fs-cap text-muted bid-edu-compact-line">本页为<text class="bid-edu-em">{{quoteNm.biddingPrequoteShort}}</text>（首次·据照片与描述·无实物）；到店后将有二次报价及确认报价，以订单内确认为准。</text>
          <view class="bid-edu-links">
            <navigator url="/pages/help/parts-types/index?section=prequote" class="bid-edu-link fs-cap">预报价详细说明</navigator>
            <text class="bid-edu-link-sep fs-cap text-muted"> · </text>
            <navigator url="/pages/help/parts-types/index" class="bid-edu-link fs-cap">配件类型说明</navigator>
          </view>
        </view>
      </view>

      <!-- 排序方式（07 文档：用户可选） -->
      <view class="bid-sort card" wx:if="{{quotes.length > 0}}">
        <text class="bid-sort-label text-muted fs-cap">排序</text>
        <picker mode="selector" range="{{sortOptions}}" range-key="label" value="{{sortIndex}}" bindchange="onSortChange">
          <view class="bid-sort-picker">
            <text class="bid-sort-value fs-body fw-medium">{{sortOptions[sortIndex].label}}</text>
            <image class="bid-sort-arrow" src="/images/icon/arrow-down.png" mode="aspectFit"/>
          </view>
        </picker>
      </view>

      <!-- 报价较少或邀请数不足3家时扩大范围提示 -->
      <view class="bid-expand-hint-wrap card" wx:if="{{quotes.length > 0 && bidding.invited_count < 3 && bidding.range_km > 0 && bidding.range_km < 100}}">
        <text class="text-muted fs-cap">选定范围内服务商较少，若需更多报价可扩大搜索范围后重新发起</text>
      </view>

      <view class="bid-reward-disclaimer card fs-cap text-muted" wx:if="{{rewardPreviewDisclaimer && quotes.length > 0}}">{{rewardPreviewDisclaimer}}</view>

      <!-- 报价列表 -->
      <view class="bid-list" wx:if="{{quotes.length > 0}}">
        <view class="bid-quote card" wx:for="{{quotes}}" wx:key="quote_id" bindlongpress="onQuoteLongPress" data-index="{{index}}">
          <view class="bid-quote-main">
            <image class="bid-quote-logo" src="{{item.logo || '/images/brand/brand-app-icon-zhejian.png'}}" mode="aspectFill"/>
            <view class="bid-quote-info">
              <text class="bid-quote-name fs-body fw-bold">{{item.shop_name}}</text>
              <view class="bid-quote-meta-row text-muted fs-cap">
                <block wx:if="{{item.distance != null}}">
                  <text>{{item.distance}}km</text>
                  <text wx:if="{{item.duration != null || item.validityText}}"> · </text>
                </block>
                <block wx:if="{{item.duration != null}}">
                  <text>工期 {{item.duration}}天</text>
                  <text wx:if="{{item.validityText}}"> · </text>
                </block>
                <text wx:if="{{item.validityText}}" class="{{item.is_expired ? 'text-error' : ''}}">{{item.validityText}}</text>
              </view>
              <view class="bid-quote-price-row" wx:if="{{item.saveText}}">
                <text class="bid-quote-save text-success fs-cap">{{item.saveText}}</text>
              </view>
              <view class="bid-quote-amount-row">
                <text class="bid-quote-amount fs-h3 fw-bold text-gold">¥{{item.amountText}}</text>
                <view class="bid-quote-rating-wrap">
                  <text wx:if="{{item.showPublicScore}}" class="bid-quote-stars {{item.scoreNum >= 90 ? 'star-gold' : (item.scoreNum < 60 ? 'star-orange' : '')}}">{{item.starsDisplay}}</text>
                  <text wx:if="{{!item.showPublicScore}}" class="bid-quote-rating-fallback text-muted fs-cap">{{item.rating}}</text>
                  <text class="bid-quote-good-rate text-success fs-cap" wx:if="{{item.goodRateText}}">{{item.goodRateText}}</text>
                </view>
              </view>
              <view class="bid-quote-preview fs-cap text-muted" wx:if="{{item.hasRewardPreview}}">
                <text wx:if="{{item.preview_complexity_level}}">维修复杂度 {{item.preview_complexity_level}}</text>
                <text wx:if="{{item.preview_complexity_level && item.previewRewardText}}"> · </text>
                <text wx:if="{{item.previewRewardText}}">评价奖励预估约 ¥{{item.previewRewardText}}（税前）</text>
              </view>
              <view class="bid-quote-disassembly fs-cap text-muted" wx:if="{{item.disassemblyDisplay && item.disassemblyDisplay.hasDisclosure}}">
                <text class="bid-quote-disassembly-line">{{item.disassemblyDisplay.summaryLine}}</text>
                <text wx:if="{{item.disassemblyDisplay.noteLine}}" class="bid-quote-disassembly-note">{{item.disassemblyDisplay.noteLine}}</text>
              </view>
              <view class="bid-quote-disassembly fs-cap text-muted" wx:elif="{{item.disassemblyDisplay && item.disassemblyDisplay.legacy}}">
                <text class="bid-quote-disassembly-line">本报价未单独披露拆解检测费，到店请与门店确认。</text>
              </view>
              <view class="bid-quote-items-wrap" wx:if="{{(item.items && item.items.length > 0) || (item.value_added_services && item.value_added_services.length > 0)}}">
                <view class="bid-quote-items-btn" bindtap="onOpenQuoteSheet" data-index="{{index}}">
                  <text class="bid-quote-items-btn-text fs-body fw-medium">查看报价明细</text>
                  <text class="bid-quote-items-btn-arrow">›</text>
                </view>
              </view>
            </view>
          </view>
          <text class="bid-quote-footnote text-muted fs-cap">本卡为{{quoteNm.biddingPrequoteShort}}；到店后方案与金额可能调整，以订单内{{quoteNm.finalLockedFull}}为准</text>
          <button
            class="bid-quote-btn btn-primary {{item.is_expired ? 'bid-quote-btn-disabled' : ''}}"
            disabled="{{item.is_expired || bidding.status !== 0 || selecting}}"
            loading="{{selecting && selectedShopId === item.shop_id}}"
            bindtap="onSelectTap"
            data-index="{{index}}"
          >{{item.is_expired ? '已过期' : '选择'}}</button>
        </view>
      </view>

      <!-- 无报价 -->
      <view class="bid-empty card" wx:elif="{{!loading && quotes.length === 0}}">
        <text class="text-muted fs-body" wx:if="{{isDistributionRejected}}">图片与修车无关，竞价未分发，请返回重新上传事故照片</text>
        <text class="text-muted fs-body" wx:elif="{{isDistributionPending}}">正在为你匹配服务商，请稍候</text>
        <text class="text-muted fs-body" wx:elif="{{bidding.invited_count > 0}}">已通知 {{notifiedCount}} 家服务商报价，请等待</text>
        <text class="text-muted fs-body" wx:elif="{{bidding.range_km > 0 && bidding.range_km < 100}}">您选择的范围内暂无服务商，建议扩大搜索范围（如选择全市）后重新发起竞价</text>
        <text class="text-muted fs-body" wx:else>暂无报价，请等待维修厂报价</text>
        <text class="text-muted fs-cap bid-expand-hint" wx:if="{{!isDistributionPending && bidding.invited_count > 0 && bidding.invited_count < 3 && bidding.range_km > 0 && bidding.range_km < 100}}">选定范围内服务商较少，建议扩大搜索范围后重新发起以获得更多报价</text>
        
      </view>

      <view class="bid-bottom-pad {{showOwnerActionsFooter ? 'bid-bottom-pad-owner-footer' : ''}}"></view>
    </scroll-view>

    <view class="bid-owner-footer" wx:if="{{showOwnerActionsFooter}}">
      <view class="bid-owner-footer-inner">
        <button wx:if="{{showEndRoundDetail}}" plain class="bid-owner-footer-btn btn-secondary" bindtap="onEndBiddingFromDetail">结束本轮比价</button>
        <button wx:if="{{canRecreateFromDetail}}" plain class="bid-owner-footer-btn btn-secondary" bindtap="onRecreateFromDetail">重新发起询价</button>
      </view>
    </view>

    <!-- 报价明细底部弹层 -->
    <view class="bid-quote-sheet-mask" wx:if="{{showQuoteDetailSheet}}" catchtap="onCloseQuoteSheet"/>
    <view class="bid-quote-sheet-wrap" wx:if="{{showQuoteDetailSheet && sheetQuote}}">
      <view class="bid-quote-sheet-grabber"/>
      <view class="bid-quote-sheet-header">
        <text class="bid-quote-sheet-title fs-body fw-bold">{{sheetQuote.shop_name}}</text>
        <text class="bid-quote-sheet-amount fs-h3 fw-bold text-gold">¥{{sheetQuote.amountText}}</text>
        <text class="fs-cap text-muted">工期 {{sheetQuote.duration}}天<text wx:if="{{sheetQuote.validityText}}"> · {{sheetQuote.validityText}}</text></text>
        <view class="bid-sheet-disassembly fs-cap text-muted" wx:if="{{sheetQuote.disassemblyDisplay && sheetQuote.disassemblyDisplay.hasDisclosure}}">
          <text>{{sheetQuote.disassemblyDisplay.summaryLine}}</text>
          <text wx:if="{{sheetQuote.disassemblyDisplay.noteLine}}" class="bid-sheet-disassembly-note">{{sheetQuote.disassemblyDisplay.noteLine}}</text>
        </view>
        <view class="bid-sheet-disassembly fs-cap text-muted" wx:elif="{{sheetQuote.disassemblyDisplay && sheetQuote.disassemblyDisplay.legacy}}">
          <text>本报价未单独披露拆解检测费，到店请与门店确认。</text>
        </view>
        <text class="fs-cap text-muted bid-quote-sheet-preview" wx:if="{{sheetQuote.hasRewardPreview}}">
          <text wx:if="{{sheetQuote.preview_complexity_level}}">维修复杂度 {{sheetQuote.preview_complexity_level}}</text>
          <text wx:if="{{sheetQuote.preview_complexity_level && sheetQuote.previewRewardText}}"> · </text>
          <text wx:if="{{sheetQuote.previewRewardText}}">奖励预估约 ¥{{sheetQuote.previewRewardText}}（税前）</text>
        </text>
      </view>
      <scroll-view scroll-y class="bid-quote-sheet-scroll">
        <view class="bid-quote-sheet-section" wx:if="{{sheetQuote.items && sheetQuote.items.length > 0}}">
          <text class="bid-quote-sheet-sec-title fs-cap fw-medium">分项明细</text>
          <view class="bid-sheet-item" wx:for="{{sheetQuote.items}}" wx:for-item="sub" wx:key="index">
            <text class="bid-sheet-item-part fs-body fw-medium">{{sub.damage_part || sub.name || sub.item}}</text>
            <view class="bid-sheet-item-detail fs-cap text-muted">
              <text>{{sub.repair_type || '维修'}}</text>
              <block wx:if="{{sub.repair_type === '换' && sub.parts_type}}">
                <text> · </text>
                <text class="bid-sheet-parts-link" catchtap="onOpenPartsHelp" data-type="{{sub.parts_type}}">{{sub.parts_type}}</text>
              </block>
              <text>{{sub.price != null ? ' · ¥' + sub.price : ''}}{{sub.warranty_months != null ? ' · 质保' + sub.warranty_months + '月' : ''}}</text>
            </view>
          </view>
        </view>
        <view class="bid-quote-sheet-section" wx:if="{{sheetQuote.ownerVaDisplay && sheetQuote.ownerVaDisplay.show}}">
          <text class="bid-quote-sheet-sec-title fs-cap fw-medium">增值服务</text>
          <view class="bid-va-owner-wrap">
            <text class="bid-va-owner-intro fs-body fw-bold">{{sheetQuote.ownerVaDisplay.intro}}</text>
            <view class="bid-va-owner-block" wx:for="{{sheetQuote.ownerVaDisplay.blocks}}" wx:for-item="blk" wx:key="headline">
              <text class="bid-va-owner-headline fs-body fw-medium">{{blk.headline}}</text>
              <text class="bid-va-owner-line fs-cap text-muted" wx:for="{{blk.lines}}" wx:for-item="ln" wx:for-index="li" wx:key="li">· {{ln}}</text>
            </view>
            <view class="bid-va-disclaimer">
              <text class="bid-va-disclaimer-line text-weak fs-cap" wx:for="{{sheetQuote.ownerVaDisplay.disclaimerLines}}" wx:for-item="dln" wx:for-index="di" wx:key="di">{{dln}}</text>
            </view>
          </view>
        </view>
        <text class="bid-quote-sheet-footnote fs-cap text-muted">本明细为{{quoteNm.biddingPrequoteShort}}；到店后可能调整，以订单内{{quoteNm.finalLockedFull}}为准。点换件旁的配件类型可查看说明。</text>
        <view class="bid-quote-sheet-scroll-pad"/>
      </scroll-view>
      <view class="bid-quote-sheet-footer">
        <view class="btn-secondary bid-quote-sheet-btn-close" bindtap="onCloseQuoteSheet">关闭</view>
        <button
          class="btn-primary bid-quote-sheet-btn-ok"
          disabled="{{sheetQuote.is_expired || bidding.status !== 0 || selecting}}"
          loading="{{selecting && selectedShopId === sheetQuote.shop_id}}"
          bindtap="onSelectFromSheet"
        >选这家</button>
      </view>
    </view>

    <!-- 长按差评提示弹窗 -->
    <view class="bid-modal-mask" wx:if="{{showBadReviewPopup}}" bindtap="onCloseBadReviewPopup"></view>
    <view class="bid-modal card bid-bad-review-modal" wx:if="{{showBadReviewPopup}}">
      <view class="bid-modal-title fs-body fw-bold">近 30 天差评 TOP1</view>
      <text class="bid-bad-review-text text-muted fs-body">{{badReviewPopupText}}</text>
      <view class="bid-modal-actions" style="margin-top: var(--space-lg);">
        <view class="btn-secondary bid-modal-cancel" bindtap="onCloseBadReviewPopup">关闭</view>
      </view>
    </view>

    <!-- 选择确认弹窗（中间区域 scroll-view，避免长内容顶出屏外无法阅读） -->
    <view class="bid-modal-mask" wx:if="{{showConfirm}}" bindtap="onCloseConfirm"></view>
    <view class="bid-modal card bid-modal-confirm" wx:if="{{showConfirm}}">
      <view class="bid-modal-title fs-h3 fw-bold">确认选择</view>
      <scroll-view scroll-y class="bid-modal-scroll" show-scrollbar="{{true}}">
        <view class="bid-modal-shop" wx:if="{{confirmQuote}}">
          <text class="fs-body fw-bold">{{confirmQuote.shop_name}}</text>
          <text class="fs-body text-gold">¥{{confirmQuote.amountText}}</text>
          <text class="text-muted fs-cap">工期 {{confirmQuote.duration}}天（分项质保见明细）</text>
          <text class="text-muted fs-cap" wx:if="{{confirmQuote.hasRewardPreview}}">
          <text wx:if="{{confirmQuote.preview_complexity_level}}">维修复杂度 {{confirmQuote.preview_complexity_level}}</text>
          <text wx:if="{{confirmQuote.preview_complexity_level && confirmQuote.previewRewardText}}"> · </text>
          <text wx:if="{{confirmQuote.previewRewardText}}">奖励预估约 ¥{{confirmQuote.previewRewardText}}（税前）</text>
        </text>
          <view class="bid-modal-disassembly fs-cap text-muted" wx:if="{{confirmQuote.disassemblyDisplay && confirmQuote.disassemblyDisplay.hasDisclosure}}">
            <text class="bid-modal-disassembly-line">{{confirmQuote.disassemblyDisplay.summaryLine}}</text>
            <text wx:if="{{confirmQuote.disassemblyDisplay.noteLine}}" class="bid-modal-disassembly-note">{{confirmQuote.disassemblyDisplay.noteLine}}</text>
          </view>
          <view class="bid-modal-disassembly fs-cap text-muted" wx:elif="{{confirmQuote.disassemblyDisplay && confirmQuote.disassemblyDisplay.legacy}}">
            <text class="bid-modal-disassembly-line">本报价未单独披露拆解检测费，到店请与门店确认。</text>
          </view>
          <view class="bid-modal-items" wx:if="{{confirmQuote.items && confirmQuote.items.length > 0}}">
            <text class="fs-cap fw-bold">报价明细</text>
            <view class="bid-modal-item" wx:for="{{confirmQuote.items}}" wx:key="index">
              <text class="fs-sm">{{item.damage_part || item.name || item.item}}</text>
              <view class="bid-modal-item-detail fs-sm text-muted">
                <text>{{item.repair_type || '维修'}}</text>
                <block wx:if="{{item.repair_type === '换' && item.parts_type}}">
                  <text> · </text>
                  <text class="bid-sheet-parts-link" catchtap="onOpenPartsHelp" data-type="{{item.parts_type}}">{{item.parts_type}}</text>
                </block>
                <text>{{item.price != null ? ' · ¥' + item.price : ''}}{{item.warranty_months != null ? ' · 质保' + item.warranty_months + '月' : ''}}</text>
              </view>
            </view>
          </view>
          <view class="bid-modal-items" wx:if="{{confirmQuote.ownerVaDisplay && confirmQuote.ownerVaDisplay.show}}">
            <text class="fs-cap fw-bold">增值服务</text>
            <view class="bid-va-owner-wrap bid-va-owner-wrap--compact">
              <text class="bid-va-owner-intro fs-body fw-bold">{{confirmQuote.ownerVaDisplay.intro}}</text>
              <view class="bid-va-owner-block" wx:for="{{confirmQuote.ownerVaDisplay.blocks}}" wx:for-item="blk" wx:key="headline">
                <text class="bid-va-owner-headline fs-body fw-medium">{{blk.headline}}</text>
                <text class="bid-va-owner-line fs-cap text-muted" wx:for="{{blk.lines}}" wx:for-item="ln" wx:for-index="li" wx:key="li">· {{ln}}</text>
              </view>
              <view class="bid-va-disclaimer">
                <text class="bid-va-disclaimer-line text-weak fs-cap" wx:for="{{confirmQuote.ownerVaDisplay.disclaimerLines}}" wx:for-item="dln" wx:for-index="di" wx:key="di">{{dln}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="bid-modal-prequote-block">
          <text class="fs-cap fw-medium">请您知悉</text>
          <text class="fs-cap text-muted bid-modal-prequote-line">· 当前为{{quoteNm.biddingPrequoteShort}}：到店后将有二次报价及{{quoteNm.finalPendingConfirm}}环节。</text>
          <text class="fs-cap text-muted bid-modal-prequote-line">· 配件类型含义见「报价与配件说明」页（竞价页顶部入口或明细中点击配件类型）。</text>
          <text class="fs-cap text-muted bid-modal-prequote-line">· 拆解检测费见上方披露（若有）；到店后实际费用线下支付，平台不代收，订单内可按规则上传留痕凭证。</text>
        </view>
        <view class="bid-modal-confirm-block">
          <view class="bid-modal-dwell text-muted fs-cap" wx:if="{{confirmDwellLeft > 0}}">请阅读并停留 {{confirmDwellLeft}} 秒后方可确认</view>
          <view class="bid-modal-dwell text-muted fs-cap" wx:else>请勾选以下条款后确认</view>
          <view class="bid-modal-clause" wx:for="{{confirmClauses}}" wx:key="id" data-id="{{item.id}}" bindtap="onToggleConfirmClause">
            <text class="bid-modal-check {{confirmChecks[item.id] ? 'on' : ''}}">{{confirmChecks[item.id] ? '☑' : '☐'}}</text>
            <text class="fs-cap text-muted">{{item.text}}</text>
          </view>
        </view>
        <text class="bid-modal-subscribe-hint text-muted fs-cap">确认后将申请订阅消息，以便接收维修方案更新等通知</text>
        <view class="bid-modal-scroll-pad"/>
      </scroll-view>
      <view class="bid-modal-actions bid-modal-actions--confirm">
        <view class="btn-secondary bid-modal-cancel" bindtap="onCloseConfirm">取消</view>
        <button
          class="btn-primary bid-modal-ok"
          disabled="{{selecting || confirmDwellLeft > 0 || !confirmChecks.prequote_only_visual || !confirmChecks.final_may_change || !confirmChecks.can_refuse_if_unexpected || !confirmChecks.disassembly_offline_ack}}"
          loading="{{selecting}}"
          bindtap="onConfirmSelect"
        >确认</button>
      </view>
    </view>
  </block>
</view>
