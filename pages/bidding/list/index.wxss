/**
 * 我的竞价列表 - 09-我的竞价列表页
 * 以《设计规范.md》、design-system 为准
 */
.bidding-list-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: var(--space-lg) var(--page-padding-x);
}

/* ========== Tab 筛选 ========== */
.bidding-tabs {
  display: flex;
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
  padding: var(--space-xs);
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.bidding-tab {
  flex: 1;
  padding: var(--space-md) var(--space-lg);
  border-radius: var(--radius-lg);
  font-size: var(--fs-body);
  color: var(--text-secondary);
  background: transparent;
  text-align: center;
  transition: all 0.2s ease;
}

.bidding-tab.active {
  background: var(--primary);
  color: var(--bg-card);
  font-weight: 500;
}

/* ========== 空状态 ========== */
.bidding-empty {
  padding: var(--space-2xl);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-lg);
}

.bidding-empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-lg);
  background: var(--avatar-placeholder-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bidding-empty-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.6;
}

.bidding-login-link,
.bidding-link {
  color: var(--primary);
  font-size: var(--fs-body);
  font-weight: 500;
}

/* ========== 加载态 ========== */
.bidding-loading {
  padding: var(--space-2xl);
  text-align: center;
  color: var(--text-hint);
}

/* ========== 列表 ========== */
.bidding-scroll {
  height: 100%;
}

.bidding-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.bidding-card {
  overflow: hidden;
  transition: transform 0.2s ease;
}

.bidding-card:active {
  transform: scale(0.995);
}

.bidding-card-main {
  display: flex;
  gap: var(--space-lg);
  margin-bottom: var(--space-lg);
}

.bidding-card-thumb {
  flex-shrink: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  background: var(--avatar-placeholder-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bidding-thumb-img {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.7;
}

.bidding-card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.bidding-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.bidding-card-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--text-primary);
}

.bidding-status-badge {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  font-size: var(--fs-sm);
  font-weight: 500;
}

.bidding-badge-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

/* 报价进行中：品牌蓝系，与全站主色一致 */
.bidding-status-badge.quote-ongoing {
  color: var(--primary);
  background: var(--primary-bg);
  border: 1rpx solid var(--primary-border-soft);
}

.bidding-status-badge.quote-ongoing .bidding-badge-icon {
  opacity: 0.85;
}

/* 报价截止（含窗口结束、已选厂、已关单等） */
.bidding-status-badge.quote-ended {
  color: var(--text-secondary);
  background: var(--bg-placeholder);
  border: 1rpx solid var(--border-light);
}

.bidding-status-badge.quote-ended .bidding-badge-icon {
  opacity: 0.4;
  filter: grayscale(1);
}

.bidding-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-lg);
}

.bidding-card-meta--two .bidding-meta-item {
  flex: 1;
  min-width: 0;
}

.bidding-meta-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.bidding-meta-label {
  font-size: var(--fs-sm);
  color: var(--text-hint);
}

.bidding-meta-value {
  font-size: var(--fs-cap);
  color: var(--text-secondary);
  font-weight: 500;
}

/* ========== 操作按钮 ========== */
.bidding-card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
  padding-top: var(--space-lg);
  border-top: 1rpx solid var(--border-light);
}

.bidding-btn {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  line-height: 64rpx;
  font-size: var(--fs-cap);
  font-weight: 500;
  border-radius: var(--radius-md);
  text-align: center;
  margin: 0;
}

.bidding-btn-hover {
  opacity: 0.92;
}

/* 品牌蓝主按钮：有报价时「查看报价」；无报价时「重新发起」为当前唯一主操作（设计规范 --primary） */
.bidding-btn-primary {
  background: var(--primary) !important;
  color: var(--bg-card) !important;
  border: 2rpx solid var(--primary) !important;
}

/* 无报价：主按钮置灰不可点 */
.bidding-btn-primary--disabled,
.bidding-btn-primary[disabled] {
  background: var(--bg-placeholder) !important;
  color: var(--text-hint) !important;
  border: 2rpx solid var(--border-light) !important;
}

/* 有报价时「重新发起」、查看订单：次按钮（描边 + 透明底） */
.bidding-btn-secondary {
  background: var(--bg-card) !important;
  color: var(--primary) !important;
  border: 2rpx solid var(--primary) !important;
}

.bidding-load-more {
  padding: var(--space-xl);
  text-align: center;
  color: var(--text-hint);
  font-size: var(--fs-cap);
}

.bidding-bottom-pad {
  height: var(--space-2xl);
}
