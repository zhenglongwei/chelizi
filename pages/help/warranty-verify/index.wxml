<custom-nav-bar title="质保卡核验" showBack="{{true}}" />
<view class="page-root warranty-verify-page" style="{{pageRootStyle}}">
  <view class="detail-section card">
    <text class="fs-body fw-medium">核对电子质保凭证</text>
    <text class="text-muted fs-cap verify-intro">请输入订单号与卡面存证防伪码，核对是否与订单存证一致（车主确认完工后的正式凭证才有）。样式预览阶段无存证码，无法核验。</text>
  </view>
  <view class="detail-section card">
    <view class="verify-field">
      <text class="fs-body fw-medium verify-label">订单号</text>
      <input class="verify-input" placeholder="例如 ord_xxx" value="{{orderId}}" bindinput="onOrderInput" />
    </view>
    <view class="verify-field">
      <text class="fs-body fw-medium verify-label">存证防伪码</text>
      <input class="verify-input" placeholder="卡面显示的存证防伪码" value="{{antiFakeCode}}" bindinput="onCodeInput" />
    </view>
    <button class="btn-primary verify-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="onVerify">核验</button>
  </view>
  <view class="detail-section card verify-result verify-result--ok" wx:if="{{result && result.ok}}">
    <text class="fs-body fw-bold text-success">核验通过</text>
    <text class="text-muted fs-cap verify-result-line">该存证防伪码与本订单存证一致（订单 {{result.order_id}}）</text>
    <text class="fs-body verify-result-line" wx:if="{{result.shop_name}}">维修厂：{{result.shop_name}}</text>
    <text class="text-muted fs-cap verify-result-line" wx:if="{{result.vehicle_summary}}">车辆：{{result.vehicle_summary}}</text>
    <text class="text-muted fs-cap verify-result-line" wx:if="{{result.generated_at}}">生成时间：{{result.generated_at}}</text>
  </view>
  <view class="detail-section card verify-result verify-result--fail" wx:if="{{result && !result.ok}}">
    <text class="fs-body fw-bold">未通过核验</text>
    <text class="text-muted fs-cap verify-result-line">{{result.message}}</text>
  </view>
  <navigator class="detail-section card fs-cap text-primary" url="/pages/help/warranty-notice/index">质保责任说明</navigator>
</view>
