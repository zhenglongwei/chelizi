# 辙见 API 本地开发 — 复制为 web/.env 后按需修改
# PowerShell: Copy-Item web\.env.example web\.env
# Bash:       cp web/.env.example web/.env

# ---------- 小程序 API 指向（与根目录 npm run sync:config 联动）----------
# cloud = 走 config.js 默认线上 BASE_URL；local = 生成本机 API（须开发者工具勾选不校验合法域名）
ZHEJIAN_MINIPROGRAM=cloud
# 仅当 ZHEJIAN_MINIPROGRAM=local 时生效，默认 http://127.0.0.1:3000
# ZHEJIAN_LOCAL_API_BASE=http://127.0.0.1:3000

# ---------- 数据库（必填，否则 /health 与业务接口不可用）----------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zhejian
DB_USER=root
DB_PASSWORD=

# ---------- 鉴权（开发环境可用默认值；生产必须更换）----------
JWT_SECRET=dev-local-zhejian-jwt-change-me

# ---------- 微信小程序（登录、订阅消息等；本地联调请填真实值）----------
# 小程序 AppID 见项目根目录 project.config.json
WX_APPID=
WX_SECRET=

# ---------- 可选：与小程序 config 中 BASE_URL 一致，用于部分绝对链接生成 ----------
# BASE_URL=http://127.0.0.1:3000

# ---------- 生产 CORS（本地可不配）----------
# CORS_ORIGINS=

# ---------- 阿里云 OSS（本地上传图片需配置）----------
# OSS_REGION=oss-cn-hangzhou
# OSS_BUCKET=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=

# ---------- 千问 / 定损与评价审核（未配置则相关接口不可用）----------
# ALIYUN_AI_KEY=
# DASHSCOPE_API_KEY=

# ---------- 订阅消息模板 ID（与根目录 config.js 中 SUBSCRIBE_TEMPLATE_IDS 对齐）----------
# SUBSCRIBE_TEMPLATE_ID=
