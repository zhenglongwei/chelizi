/**
 * 服务商报价明细表单（维修项目 + 增值服务 + 汇总）
 * 复用：pages/merchant/bidding/detail（首次报价）、pages/merchant/order/repair-plan-edit（修改方案/修改报价单）
 */
@import '/styles/design-system.wxss';

.mqf-section {
  margin-bottom: var(--space-xl);
}

.mqf-section-title {
  display: block;
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
  font-weight: 600;
}

.mqf-section-hint {
  display: block;
  margin-bottom: var(--space-sm);
}

/* Excel / 拍照识别（M05、M07 再次报价共用） */
.quote-ai-action {
  margin-top: var(--space-md);
}
.quote-ai-btn {
  font-size: var(--fs-body);
  color: var(--primary);
  background: var(--accent-bg);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-sm);
  padding: var(--space-sm) var(--space-lg);
}
.quote-import-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-md);
}
.quote-import-btn {
  margin: 0;
}
.quote-import-hint {
  display: block;
  margin-top: var(--space-sm);
  line-height: 1.5;
}

.mqf-items-list {
  margin-bottom: var(--space-lg);
}

.mqf-item-block {
  padding: var(--space-md);
  margin-bottom: var(--space-md);
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  position: relative;
}

.mqf-line {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.mqf-line--repair {
  flex-wrap: wrap;
}

.mqf-line--repair .mqf-picker {
  flex: 1;
  min-width: 140rpx;
}

.mqf-label {
  flex-shrink: 0;
  width: 140rpx;
  font-size: var(--fs-cap);
  color: var(--text-secondary);
}

.mqf-input {
  flex: 1;
  font-size: var(--fs-body);
  padding: var(--space-xs) var(--space-sm);
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  min-width: 0;
}

.mqf-picker {
  flex: 1;
  font-size: var(--fs-body);
  padding: var(--space-xs) var(--space-sm);
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-primary);
  min-width: 0;
}

.mqf-picker--locked {
  color: var(--text-hint);
}

.mqf-picker--parts {
  margin-left: var(--space-sm);
}

.mqf-static {
  flex: 1;
  font-size: var(--fs-cap);
  color: var(--text-hint);
}

.mqf-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: var(--space-sm);
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--border-light);
}

.mqf-del {
  font-size: var(--fs-sm);
  color: var(--danger);
  padding: var(--space-xs) var(--space-md);
}

.mqf-del:active {
  opacity: 0.7;
}

.mqf-item-add {
  padding: var(--space-md);
  text-align: center;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-sm);
}

/* 增值服务 */
.mqf-value-added {
  margin-bottom: var(--space-lg);
}

.mqf-va-list {
  margin-top: var(--space-sm);
}

.mqf-va-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.mqf-va-input {
  flex: 1;
  font-size: var(--fs-body);
  padding: var(--space-xs) var(--space-sm);
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
}

.mqf-va-del {
  font-size: var(--fs-sm);
  color: var(--danger);
  flex-shrink: 0;
}

.mqf-va-add {
  padding: var(--space-md);
  text-align: center;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-sm);
}

.mqf-va-tpl-wrap {
  margin-top: var(--space-sm);
}

.mqf-va-tpl-group {
  margin-bottom: var(--space-lg);
}

.mqf-va-tpl-group-title {
  display: block;
  color: var(--text-secondary, #374151);
  margin-bottom: var(--space-sm);
}

.mqf-va-chk-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
  border-bottom: 1rpx solid var(--border-light, #f3f4f6);
}

.mqf-va-chk-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
  border: 2rpx solid var(--border);
  border-radius: 8rpx;
  background: var(--bg-card, #fff);
  box-sizing: border-box;
}

.mqf-va-chk-icon--on {
  border-color: var(--primary);
  background: var(--primary);
  position: relative;
}

.mqf-va-chk-icon--on::after {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 4rpx;
  width: 10rpx;
  height: 16rpx;
  border: solid #fff;
  border-width: 0 3rpx 3rpx 0;
  transform: rotate(45deg);
}

.mqf-va-chk-label {
  flex: 1;
  line-height: 1.45;
  color: var(--text-primary);
}

.mqf-va-custom-title {
  display: block;
  margin-top: var(--space-md);
  margin-bottom: var(--space-xs);
}

.mqf-va-compliance-block {
  margin-top: var(--space-lg);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border-light);
}

.mqf-va-compliance-line {
  display: block;
  line-height: 1.55;
  margin-bottom: var(--space-xs);
}

/* 竞价/方案页：增值服务入口（摘要 + 跳转子页） */
.mqf-value-added-compact-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  margin-bottom: var(--space-sm);
}

.mqf-value-added-go-btn {
  flex-shrink: 0;
  padding: var(--space-xs) var(--space-lg);
  color: var(--primary);
  background: var(--accent-bg);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-sm);
}

.mqf-va-chosen-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mqf-va-chosen-chip {
  max-width: 100%;
  padding: 8rpx 16rpx;
  background: var(--bg-page);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-secondary);
  line-height: 1.4;
  word-break: break-all;
}

.mqf-va-chosen-empty {
  display: block;
  line-height: 1.5;
}

/* 汇总：总报价、工期 */
.mqf-summary-section {
  padding-top: var(--space-lg);
  margin-top: var(--space-lg);
  border-top: 1rpx solid var(--border-light);
}

.mqf-total-block {
  margin-bottom: var(--space-lg);
}

.mqf-total-label {
  display: block;
  margin-bottom: var(--space-sm);
}

.mqf-total-sum-hint {
  display: block;
  margin-bottom: var(--space-sm);
  line-height: 1.45;
}

.mqf-total-input-wrap--readonly {
  opacity: 1;
}

.mqf-total-readonly {
  display: flex;
  align-items: center;
  min-height: 48rpx;
}

.mqf-total-input-wrap {
  display: flex;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
  background: var(--primary-bg);
  border: 1rpx solid var(--primary);
  border-radius: var(--radius-md);
}

.mqf-total-prefix {
  font-size: var(--fs-h3);
  font-weight: 600;
  color: var(--primary);
  margin-right: var(--space-sm);
}

.mqf-total-input {
  flex: 1;
  font-size: var(--fs-h3);
  font-weight: 600;
  color: var(--primary);
  min-width: 0;
}

.mqf-extra-block {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  margin-bottom: var(--space-lg);
  padding: var(--space-md) var(--space-lg);
  background: var(--bg-page);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
}

.mqf-extra-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.mqf-extra-label {
  flex-shrink: 0;
}

.mqf-extra-input-wrap {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.mqf-extra-input {
  flex: 1;
  min-width: 0;
  padding: var(--space-sm) var(--space-md);
  font-size: var(--fs-body);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-card);
  text-align: center;
}

.mqf-extra-unit {
  flex-shrink: 0;
  font-size: var(--fs-cap);
  color: var(--text-secondary);
}
