<view class="tab-bar">
  <view class="tab-cluster tab-cluster-left">
    <block wx:for="{{leftList}}" wx:key="tabIndex">
      <view
        class="tab-item tab-item-cluster {{selected === item.tabIndex ? 'active' : ''}}"
        data-index="{{item.tabIndex}}"
        bindtap="switchTab"
      >
        <view class="tab-icon-wrap">
          <image class="tab-icon" src="/images/icon/{{selected === item.tabIndex ? item.selectedIconPath : item.iconPath}}.png" mode="aspectFit"/>
        </view>
        <text class="tab-text {{selected === item.tabIndex ? 'active' : ''}}">{{item.text}}</text>
      </view>
    </block>
  </view>

  <view
    class="tab-item tab-center {{selected === centerItem.tabIndex ? 'active' : ''}}"
    data-index="{{centerItem.tabIndex}}"
    bindtap="switchTab"
  >
    <view class="center-wrap">
      <view class="center-ring center-ring-1"></view>
      <view class="center-ring center-ring-2"></view>
      <view class="center-btn">
        <image class="center-icon" src="/images/icon/{{selected === centerItem.tabIndex ? centerItem.selectedIconPath : centerItem.iconPath}}.png" mode="aspectFit"/>
      </view>
    </view>
    <text class="tab-text {{selected === centerItem.tabIndex ? 'active' : ''}}">{{centerItem.text}}</text>
  </view>

  <view class="tab-cluster tab-cluster-right">
    <block wx:for="{{rightList}}" wx:key="tabIndex">
      <view
        class="tab-item tab-item-cluster {{selected === item.tabIndex ? 'active' : ''}}"
        data-index="{{item.tabIndex}}"
        bindtap="switchTab"
      >
        <view class="tab-icon-wrap">
          <image class="tab-icon" src="/images/icon/{{selected === item.tabIndex ? item.selectedIconPath : item.iconPath}}.png" mode="aspectFit"/>
          <view class="tab-badge" wx:if="{{item.tabIndex === 3 && unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
        </view>
        <text class="tab-text {{selected === item.tabIndex ? 'active' : ''}}">{{item.text}}</text>
      </view>
    </block>
  </view>
</view>
